Cell[TextData[{
 "Notice how the derivatives of the function ",
 StyleBox["a", "Input"],
 " are shown by ",
 StyleBox["TList", "Input"],
 " in the notation ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[PartialD]", 
     StyleBox["t", "TI"]], 
    StyleBox["a", "TI"]}], TraditionalForm]],ExpressionUUID->
  "8876940f-4ad5-854e-a0af-d03f19d84776"],
 " instead of a'[t]. This may not seem like much of an improvement in this \
case, but in the case of partial derivatives of functions of many arguments, \
it can greatly improve readability. Here is a simple example:"
}], "Text",ExpressionUUID->"453e85c4-b3c3-2e40-8dce-e300f93c4aa9"],

