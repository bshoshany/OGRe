Cell[TextData[{
 "We will demonstrate how to use ",
 StyleBox["TSimplify", "Input"],
 " in the next section."
}], "Text",ExpressionUUID->"9bc85993-fd8c-684f-9a85-1800c8a8a506"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Setting simplification assumptions", "Subsection",ExpressionUUID->"1e861b0c-3f6a-7c43-8582-bae5cdaf6d7e"],

Cell["\<\
Often, coordinate transformations are only invertible for a specific range of \
coordinates. For example, let us define a new scalar in Minkowski space, \
which is equal to the spatial distance from the origin:\
\>", "Text",ExpressionUUID->"75f5ba2d-5467-e54e-b242-bb9d44f59cb1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TShow", "@", 
  RowBox[{"TNewTensor", "[", 
   RowBox[{"\"\<SpatialDistance\>\"", ",", "\"\<Minkowski\>\"", 
    ",", "\"\<Cartesian\>\"", ",", 
    RowBox[{"{", "}"}], ",", 
    RowBox[{"{", 
     SqrtBox[
      RowBox[{
       SuperscriptBox["x", "2"], "+", 
       SuperscriptBox["y", "2"], "+", 
       SuperscriptBox["z", "2"]}]], "}"}], ",", "\"\<d\>\""}], 
   "]"}]}]], "Input",
 CellLabel->"In[94]:=",ExpressionUUID->"5bda27df-a3a2-1145-b051-04333a7c8164"],

Cell[BoxData[
 StyleBox[
  TemplateBox[{"\"SpatialDistance\"", "\":   \"", "\"d\"", "\"(\"", 
    TemplateBox[{",", "\",\"", "t", "x", "y", "z"}, "RowWithSeparators"], 
    "\")\"", "\" = \"", 
    SqrtBox[
     RowBox[{
       SuperscriptBox["x", "2"], "+", 
       SuperscriptBox["y", "2"], "+", 
       SuperscriptBox["z", "2"]}]]},
   "RowDefault"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"b1eee803-7556-894a-8303-a242433e3508"]
}, Open  ]],

Cell[TextData[{
 "When we convert this scalar to spherical coordinates, we expect to get ",
 Cell[BoxData[
  FormBox[
   StyleBox["r", "TI"], TraditionalForm]],ExpressionUUID->
  "051d4c0c-7e65-5f46-a349-c0b53dc80b74"],
 ", but instead we get the absolute value of ",
 Cell[BoxData[
  FormBox[
   StyleBox["r", "TI"], TraditionalForm]],ExpressionUUID->
  "017ff4f4-5b0e-3e44-b7e1-8724585503d4"],
 ":"
}], "Text",ExpressionUUID->"d1faa01b-0d90-b14b-8703-1230ae533d45"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TShow", "[", 
  RowBox[{"\"\<SpatialDistance\>\"", ",", "\"\<Spherical\>\""}], 
  "]"}]], "Input",
 CellLabel->"In[95]:=",ExpressionUUID->"5e03c828-b20a-c04b-a85e-9534769a473d"],

Cell[BoxData[
 StyleBox[
  TemplateBox[{"\"SpatialDistance\"", "\":   \"", "\"d\"", "\"(\"", 
    TemplateBox[{",", "\",\"", "t", "r", "\[Theta]", "\[Phi]"}, 
     "RowWithSeparators"], "\")\"", "\" = \"", 
    RowBox[{"Abs", "[", "r", "]"}]},
   "RowDefault"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"975a5a51-99b8-514c-80c2-9a280b4bd3a9"]
}, Open  ]],

Cell[TextData[{
 "As usual in Mathematica, such issues can be easily fixed by simplifying \
with the correct ",
 StyleBox["assumptions",
  FontWeight->Bold],
 ". By default, OGRe uses the simplification assumption that all variables \
(coordinates, parameters, etc.) are ",
 StyleBox["real",
  FontWeight->Bold],
 ". Therefore, Mathematica knows to simplify ",
 Cell[BoxData[
  FormBox[
   SqrtBox[
    SuperscriptBox[
     StyleBox["r", "TI"], "2"]], TraditionalForm]],ExpressionUUID->
  "869c664a-fc5b-3f4b-bf6f-a2398b02f392"],
 " to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{
       StyleBox["r", "TI"]}]},
    "Abs"], TraditionalForm]],ExpressionUUID->
  "46ff09b9-05c2-0d49-9aae-28ff95684f3b"],
 ". However, Mathematica doesn't automatically know that ",
 Cell[BoxData[
  FormBox[
   StyleBox["r", "TI"], TraditionalForm]],ExpressionUUID->
  "3f367499-f416-ab4c-8c45-0afe4c0bdbd9"],
 " is non-negative."
}], "Text",ExpressionUUID->"620d5721-c408-a942-9cd1-bffd20c4051b"],

Cell[TextData[{
 "The user may specify which assumptions to pass to the simplification \
function using the module ",
 StyleBox["TSetAssumptions", "Input"],
 ":"
}], "Text",ExpressionUUID->"e237f00b-4c3a-974f-9d97-9cb7c42468d1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"?", "TSetAssumptions"}]], "Input",
 CellLabel->"In[96]:=",ExpressionUUID->"fbc83146-8402-9a4d-8768-2c35e2ce0c77"],

