Cell["\<\
The FLRW metric is conformally flat, so its Weyl tensor vanishes:\
\>", "Text",ExpressionUUID->"8bf77910-7522-304f-b93d-46ef30676e27"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TList", "@", 
  RowBox[{"TWeyl", "[", "\"\<FLRW\>\"", "]"}]}]], "Input",
 CellLabel->
  "In[177]:=",ExpressionUUID->"dada8dd4-c1eb-7044-b195-6374bfda1c18"],

Cell[BoxData[
 StyleBox[
  TagBox[GridBox[{
     {
      TemplateBox[{"\"FLRW->Weyl\"", "\":\""},
       "RowDefault"]},
     {"\<\"No non-zero elements.\"\>"}
    },
    DefaultBaseStyle->"Column",
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
   "Column"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"b318e661-8f86-7345-a855-14d65d9c6cf4"]
}, Open  ]],

Cell["\<\
Since the Schwarzschild metric is Ricci-flat, the Weyl tensor is equal to the \
Riemann tensor, as we can verify by taking the difference of the two tensors:\
\>", "Text",ExpressionUUID->"6c9aa030-bf08-7248-8b85-ca18790e8125"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TList", "@", 
  RowBox[{"TCalc", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"TWeyl", "[", "\"\<Schwarzschild\>\"", "]"}], 
     "[", "\"\<\[Rho]\[Sigma]\[Mu]\[Nu]\>\"", "]"}], "-", 
    RowBox[{
     RowBox[{"TRiemann", "[", "\"\<Schwarzschild\>\"", "]"}], 
     "[", "\"\<\[Rho]\[Sigma]\[Mu]\[Nu]\>\"", "]"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[178]:=",ExpressionUUID->"63bde62f-117f-224a-b363-1c4a637e0bf5"],

Cell[BoxData[
 StyleBox[
  TagBox[GridBox[{
     {
      TemplateBox[{"\"Result\"", "\":\""},
       "RowDefault"]},
     {"\<\"No non-zero elements.\"\>"}
    },
    DefaultBaseStyle->"Column",
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
   "Column"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"222803cb-25e4-b54d-b12e-fae7897dc15c"]
}, Open  ]],

Cell[TextData[{
 "For an example where the Weyl tensor is non-zero but differs from the \
Riemann tensor, let us define the ",
 StyleBox["Schwarzschild-de Sitter metric",
  FontWeight->Bold],
 ":"
}], "Text",ExpressionUUID->"4cf3b4ff-1d9e-f743-8b89-498f6a600a77"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"TSetReservedSymbols", "[", "\[CapitalLambda]", "]"}], ";"}], "\n", 
 RowBox[{"TShow", "[", 
  RowBox[{"TNewMetric", "[", 
   RowBox[{"\"\<SchwarzschildDeSitter\>\"", ",", "\"\<Spherical\>\"", ",", 
    RowBox[{"DiagonalMatrix", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"(", 
         RowBox[{"1", "-", 
          FractionBox[
           RowBox[{"2", " ", "M"}], "r"], "-", 
          FractionBox[
           RowBox[{"\[CapitalLambda]", " ", 
            SuperscriptBox["r", "2"]}], "3"]}], ")"}]}], ",", 
       FractionBox["1", 
        RowBox[{"1", "-", 
         FractionBox[
          RowBox[{"2", " ", "M"}], "r"], "-", 
         FractionBox[
          RowBox[{"\[CapitalLambda]", " ", 
           SuperscriptBox["r", "2"]}], "3"]}]], ",", 
       SuperscriptBox["r", "2"], ",", 
       RowBox[{
        SuperscriptBox["r", "2"], " ", 
        SuperscriptBox[
         RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}]}], "}"}], "]"}]}], 
   "]"}], "]"}]}], "Input",
 CellLabel->
  "In[179]:=",ExpressionUUID->"8a7f6550-720f-e34d-a9b6-bce56412237a"],

Cell[BoxData[
 StyleBox[
  TemplateBox[{"\"SchwarzschildDeSitter\"", "\":   \"", 
    SubscriptBox["\"g\"", 
     TemplateBox[{"\"\[Mu]\"", "\"\[Nu]\""}, "RowDefault"]], "\"(\"", 
    TemplateBox[{",", "\",\"", "t", "r", "\[Theta]", "\[Phi]"}, 
     "RowWithSeparators"], "\")\"", "\" = \"", 
    TagBox[
     RowBox[{"(", "\[NoBreak]", 
       GridBox[{{
          RowBox[{
            RowBox[{"-", "1"}], "+", 
            FractionBox[
             RowBox[{"2", " ", "M"}], "r"], "+", 
            FractionBox[
             RowBox[{
               SuperscriptBox["r", "2"], " ", "\[CapitalLambda]"}], "3"]}], 
          "0", "0", "0"}, {"0", 
          RowBox[{"-", 
            FractionBox[
             RowBox[{"3", " ", "r"}], 
             RowBox[{
               RowBox[{"6", " ", "M"}], "-", 
               RowBox[{"3", " ", "r"}], "+", 
               RowBox[{
                 SuperscriptBox["r", "3"], " ", "\[CapitalLambda]"}]}]]}], 
          "0", "0"}, {"0", "0", 
          SuperscriptBox["r", "2"], "0"}, {"0", "0", "0", 
          RowBox[{
            SuperscriptBox["r", "2"], " ", 
            SuperscriptBox[
             RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}]}}, RowSpacings -> 
        1, ColumnSpacings -> 1, RowAlignments -> Baseline, ColumnAlignments -> 
        Center], "\[NoBreak]", ")"}], 
     Function[BoxForm`e$, 
      MatrixForm[BoxForm`e$]]]},
   "RowDefault"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"8ec5ce8a-44f5-cc49-b6ba-78f4e6a3cd35"]
}, Open  ]],

Cell["Its line element is:", "Text",ExpressionUUID->"5cbc6e14-3e74-9b47-ac35-53b0bd0be408"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TLineElement", "[", "\"\<SchwarzschildDeSitter\>\"", "]"}]], "Input",
 CellLabel->
  "In[181]:=",ExpressionUUID->"e8d88bf3-4a19-534e-a265-dcc282b49780"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SuperscriptBox["\[DoubleStruckD]t", "2"], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "1"}], "+", 
     FractionBox[
      RowBox[{"2", " ", "M"}], "r"], "+", 
     FractionBox[
      RowBox[{
       SuperscriptBox["r", "2"], " ", "\[CapitalLambda]"}], "3"]}], ")"}]}], "+", 
  RowBox[{"r", " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"r", " ", 
      SuperscriptBox["\[DoubleStruckD]\[Theta]", "2"]}], "-", 
     FractionBox[
      RowBox[{"3", " ", 
       SuperscriptBox["\[DoubleStruckD]r", "2"]}], 
      RowBox[{
       RowBox[{"6", " ", "M"}], "-", 
       RowBox[{"3", " ", "r"}], "+", 
       RowBox[{
        SuperscriptBox["r", "3"], " ", "\[CapitalLambda]"}]}]]}], ")"}]}], "+", 
  RowBox[{
   SuperscriptBox["r", "2"], " ", 
   SuperscriptBox["\[DoubleStruckD]\[Phi]", "2"], " ", 
   SuperscriptBox[
    RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}]}]], "Output",
 CellLabel->
  "Out[181]=",ExpressionUUID->"ad263950-1def-6246-85e0-3f1aa5e68fdc"]
}, Open  ]],

Cell["Calculating the Weyl tensor, we find:", "Text",ExpressionUUID->"fc6a6ebb-fe28-6a42-8b66-67f9c50de56f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TList", "@", 
  RowBox[{"TWeyl", "[", "\"\<SchwarzschildDeSitter\>\"", "]"}]}]], "Input",
 CellLabel->
  "In[182]:=",ExpressionUUID->"3d4b08a6-22d9-7245-b85f-637140d9ab2c"],

Cell[BoxData[
 StyleBox[
  TagBox[GridBox[{
     {
      TemplateBox[{"\"SchwarzschildDeSitter->Weyl\"", "\":\""},
       "RowDefault"]},
     {
      TagBox[GridBox[{
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"C\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"], "r", "t", "r"}, "RowDefault"], 
              TemplateBox[{"t", 
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"], 
                TemplateBox[{
