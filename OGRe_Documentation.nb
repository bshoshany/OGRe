\\\", StyleBox[\\\"ID\\\", Bold, Rule[StripOnInput, False]], \\\" to \\\", \
StyleBox[\\\"indices\\\", Bold, Rule[StripOnInput, False]], \\\".\\\\n\\\", \
StyleBox[\\\"indices\\\", Bold, Rule[StripOnInput, False]], \\\" must be a \
