    None, "OwnValues" -> None, "UpValues" -> None, "DownValues" -> 
    Information`InformationValueForm[
     DownValues, OGRe`TInfo, {
      OGRe`TInfo[] :> 
       Module[{OGRe`Private`allTensors, OGRe`Private`tensorList, 
          OGRe`Private`countCoord = 1, OGRe`Private`countMetric = 1}, 
         OGRe`Private`tensorList = OGRe`Private`PublicTensorIDs[]; 
         OGRe`Private`allTensors = DeleteCases[
            OGRe`Private`AllTensorIDs[], OGRe`Private`DefaultResultID]; 
         OGRe`Private`OGRePrint[
           Column[{
             Row[{
               Style["Total tensors created: ", Bold], 
               Length[OGRe`Private`allTensors]}], 
             Style["Coordinate Systems:", Bold], 
             Column[
              Table[
               Row[{
                 Increment[OGRe`Private`countCoord], ". ", 
                 OGRe`Private`ID}], {OGRe`Private`ID, 
                Map[OGRe`Private`InfoButton, 
                 Select[
                 OGRe`Private`tensorList, 
                  OGRe`Private`GetTensorData[#]["Role"] == 
                  "Coordinates"& ]]}]], 
             Style["Metrics:", Bold], 
             Column[
              Table[
               Row[{
                 Increment[OGRe`Private`countMetric], ". ", 
                 Style[
                  OGRe`Private`InfoButton[OGRe`Private`ID], Bold], 
                 " \[Rule] ", 
                 OGRe`Private`MetricTensorButtons[OGRe`Private`ID]}], {
               OGRe`Private`ID, 
                Select[
                OGRe`Private`tensorList, 
                 OGRe`Private`GetTensorData[#]["Role"] == "Metric"& ]}]]}]]; 
         Null], OGRe`TInfo[
         Pattern[OGRe`Private`tensorID, 
          Blank[String]]] :> 
       Module[{OGRe`Private`info}, 
         OGRe`Private`CheckIfTensorExists[OGRe`Private`tensorID]; 
         OGRe`Private`info = {
            Row[{
              Style["ID: ", Bold], 
              OGRe`Private`DisplayTensorID[OGRe`Private`tensorID]}]}; 
         AppendTo[OGRe`Private`info, 
           Row[{
             Style["Symbol: ", Bold], 
             OGRe`Private`GetTensorData[OGRe`Private`tensorID]["Symbol"]}]]; 
         AppendTo[OGRe`Private`info, 
           Row[{
             Style["Role: ", Bold], 
             OGRe`Private`GetTensorData[OGRe`Private`tensorID]["Role"]}]]; 
         AppendTo[OGRe`Private`info, 
           Row[{
             Style["Rank: ", Bold], 
             OGRe`TRank[OGRe`Private`tensorID]}]]; AppendTo[OGRe`Private`info, 
           Row[{
             Style["Dimensions: ", Bold], 
             OGRe`TDim[OGRe`Private`tensorID]}]]; If[
           And[
           OGRe`Private`GetTensorData[OGRe`Private`tensorID]["Role"] =!= 
            "Coordinates", 
            OGRe`Private`GetTensorData[OGRe`Private`tensorID]["Role"] =!= 
            "Metric"], 
           AppendTo[OGRe`Private`info, 
            Row[{
              Style["Metric: ", Bold], 
              OGRe`Private`InfoButton[
               OGRe`Private`GetTensorData[OGRe`Private`tensorID][
               "Metric"]]}]]]; 
         If[OGRe`Private`GetTensorData[OGRe`Private`tensorID]["Role"] =!= 
           "Coordinates", 
           AppendTo[OGRe`Private`info, 
            Row[{
              Style["Default Coordinates: ", Bold], 
              OGRe`Private`InfoButton[
               OGRe`Private`GetTensorData[OGRe`Private`tensorID][
               "DefaultCoords"]]}]]]; AppendTo[OGRe`Private`info, 
           Row[{
             Style["Default Indices: ", Bold], 
             OGRe`Private`GetTensorData[OGRe`Private`tensorID][
             "DefaultIndices"]}]]; 
         If[OGRe`Private`GetTensorData[OGRe`Private`tensorID]["Role"] === 
           "Coordinates", 
           AppendTo[OGRe`Private`info, 
            Row[{
              Style["Default Coordinates For: ", Bold], 
              Row[
               Map[OGRe`Private`InfoButton, 
                Select[
                 OGRe`Private`AllTensorIDs[], And[
                 OGRe`Private`GetTensorData[#]["DefaultCoords"] === 
                  OGRe`Private`tensorID, # =!= OGRe`Private`tensorID]& ]], 
               ", "]}]]]; 
         If[OGRe`Private`GetTensorData[OGRe`Private`tensorID]["Role"] === 
           "Metric", 
           AppendTo[OGRe`Private`info, 
            Row[{
              Style["Tensors Using This Metric: ", Bold], 
              OGRe`Private`MetricTensorButtons[OGRe`Private`tensorID]}]]]; 
         AppendTo[OGRe`Private`info, 
           Row[{
             Style["Components: ", Bold], 
             OGRe`Private`CreateButton["TList", 
              OGRe`TList[OGRe`Private`tensorID]], " | ", 
             OGRe`Private`CreateButton["TShow", 
              OGRe`TShow[OGRe`Private`tensorID]]}]]; OGRe`Private`OGRePrint[
           Column[OGRe`Private`info]]; Null]}], "SubValues" -> None, 
