Cell["Let us now turn it on:", "Text",ExpressionUUID->"67aa281b-bc0c-bc48-a836-46a37f7aa150"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TSetAllowOverwrite", "[", "True", "]"}]], "Input",
 CellLabel->"In[67]:=",ExpressionUUID->"12e4c010-0f6e-ec4e-846d-0abb93693050"],

Cell[BoxData[
 TemplateBox[{
  "TSetAllowOverwrite", "Notify", 
