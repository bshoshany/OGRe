    Information`InformationValueForm[
     DefaultValues, OGRe`TChangeDefaultCoords, {
      SyntaxInformation[OGRe`TChangeDefaultCoords] -> {"ArgumentsPattern" -> {
           Blank[], 
           Blank[]}}}], "NValues" -> None, "FormatValues" -> None, "Options" -> 
    None, "Attributes" -> {Protected}, "FullName" -> 
    "OGRe`TChangeDefaultCoords"|>, False]]], "Output",
 CellLabel->"Out[83]=",ExpressionUUID->"dcca0fa6-541b-294f-be88-79d41d8f5386"]
}, Open  ]],

Cell["\<\
For example, let's change the default coordinates of the perfect fluid stress \
tensor to spherical coordinates:\
\>", "Text",ExpressionUUID->"6e84c657-f79d-b143-8b39-e1eb1cce7e6c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TChangeDefaultCoords", "[", 
  RowBox[{"\"\<PerfectFluid\>\"", ",", "\"\<Spherical\>\""}], "]"}]], "Input",
 CellLabel->"In[84]:=",ExpressionUUID->"73a2526f-ab2d-f049-a03b-ad4dc18d6742"],

Cell[BoxData["\<\"PerfectFluid\"\>"], "Output",
 CellLabel->"Out[84]=",ExpressionUUID->"9de652eb-8a59-fe4a-9e93-ef87bfbfc97d"]
}, Open  ]],

Cell[TextData[{
 "Now, when we display the tensor using ",
 StyleBox["TList", "Input"],
 " with only the tensor ID (or with just a choice of indices), this is the \
coordinate system that will be used:"
}], "Text",ExpressionUUID->"55c23d8e-9b16-504f-9b1a-58f50786e699"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TList", "[", "\"\<PerfectFluid\>\"", "]"}]], "Input",
 CellLabel->"In[85]:=",ExpressionUUID->"a6fe389b-0f4f-5f42-b893-5bf635da79bf"],

Cell[BoxData[
 StyleBox[
  TagBox[GridBox[{
     {
      TemplateBox[{"\"PerfectFluid\"", "\":\""},
       "RowDefault"]},
     {
      TagBox[GridBox[{
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"T\"", 
             TemplateBox[{"t", "t"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", "\[Rho]"},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"T\"", 
             TemplateBox[{"r", "r"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", "p"},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"T\"", 
             TemplateBox[{"\[Theta]", "\[Theta]"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{"p", " ", 
           SuperscriptBox["r", "2"]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"T\"", 
             TemplateBox[{"\[Phi]", "\[Phi]"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{"p", " ", 
           SuperscriptBox["r", "2"], " ", 
           SuperscriptBox[
            RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}]}
        },
        AutoDelete->False,
        GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
        GridBoxItemSize->{
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
       "Grid"]}
    },
    DefaultBaseStyle->"Column",
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
   "Column"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"84fb3f5a-7a42-0841-b114-1c8eb8ad2f0f"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Applying replacement rules or a function to the tensor components\
\>", "Subsection",ExpressionUUID->"49bdcb5d-c62f-2343-8a73-64c7877a3bd4"],

Cell[TextData[{
 StyleBox["TList", "Input"],
 " and ",
 StyleBox["TShow", "Input"],
 " accept a rule or a list of rules as an argument. If provided, the \
replacement will be applied to each of the tensor's components, the \
components will be simplified, and the tensor will be displayed with the new \
components. Note that this only applies to displaying the components; the \
tensor data itself will not change."
}], "Text",ExpressionUUID->"a10e80b8-6670-7e4c-a903-1c1297f6ecaf"],

Cell[TextData[{
 "This can be used to replace a particular symbol in the tensor with another \
symbol or numerical value. For example, perhaps we would like to display the \
value of the Kretschmann scalar for a particular choice of ",
 Cell[BoxData[
  FormBox[
   StyleBox["M", "TI"], TraditionalForm]],ExpressionUUID->
  "b2c7b30e-023b-bb4a-aa67-f380402406c7"],
 " and ",
 Cell[BoxData[
  FormBox[
   StyleBox["r", "TI"], TraditionalForm]],ExpressionUUID->
  "7f23dcf8-0015-1e43-81d5-e0f9b20df762"],
 ":"
}], "Text",ExpressionUUID->"8409c606-55fe-1045-b884-26dfdb114a9f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TShow", "[", 
  RowBox[{"\"\<Kretschmann\>\"", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"M", "\[Rule]", "1"}], ",", 
     RowBox[{"r", "\[Rule]", "10"}]}], "}"}]}], "]"}]], "Input",
 CellLabel->"In[86]:=",ExpressionUUID->"e106eff2-4be5-f54b-9f4a-e39b6489227f"],

Cell[BoxData[
 StyleBox[
  TemplateBox[{"\"Kretschmann\"", "\":   \"", "\"K\"", "\"(\"", 
    TemplateBox[{",", "\",\"", "t", "r", "\[Theta]", "\[Phi]"}, 
     "RowWithSeparators"], "\")\"", "\" = \"", 
    FractionBox["3", "62500"]},
   "RowDefault"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"2030b46e-86e5-6640-b7cc-fcb3871e23f5"]
}, Open  ]],

Cell[TextData[{
 "Or maybe we would like to display the perfect fluid stress tensor with ",
 Cell[BoxData[
  FormBox[
   StyleBox["p", "TI"], TraditionalForm]],ExpressionUUID->
  "074b1603-9fc5-a146-b3f9-06e9a6927e7c"],
 " equal to ",
 Cell[BoxData[
  FormBox["\[Rho]", TraditionalForm]],ExpressionUUID->
  "d29f5f26-ebfd-a74a-8694-14de2c3a0505"],
 ":"
}], "Text",ExpressionUUID->"7dea0d3b-0483-f446-b9cc-02e024e3dfb6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TList", "[", 
  RowBox[{"\"\<PerfectFluid\>\"", ",", 
   RowBox[{"p", "\[Rule]", "\[Rho]"}]}], "]"}]], "Input",
 CellLabel->"In[87]:=",ExpressionUUID->"9a1301c2-a91b-db45-8527-c1ebff67f8d0"],

Cell[BoxData[
 StyleBox[
  TagBox[GridBox[{
     {
      TemplateBox[{"\"PerfectFluid\"", "\":\""},
       "RowDefault"]},
     {
      TagBox[GridBox[{
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"T\"", 
             TemplateBox[{"t", "t"}, "RowDefault"]], 
            SubscriptBox["\"T\"", 
             TemplateBox[{"r", "r"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", "\[Rho]"},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"T\"", 
             TemplateBox[{"\[Theta]", "\[Theta]"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           SuperscriptBox["r", "2"], " ", "\[Rho]"}]},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"T\"", 
             TemplateBox[{"\[Phi]", "\[Phi]"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           SuperscriptBox["r", "2"], " ", "\[Rho]", " ", 
           SuperscriptBox[
            RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}]}
        },
        AutoDelete->False,
        GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
        GridBoxItemSize->{
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
       "Grid"]}
    },
    DefaultBaseStyle->"Column",
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
   "Column"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"14f7fb18-07e1-2742-9a07-9bade2e42b0c"]
}, Open  ]],

Cell["\<\
The replacement rules can, of course, also be combined with a choice of \
indices and/or coordinates, as long as the rules come after the indices \
and/or coordinates in the argument list:\
\>", "Text",ExpressionUUID->"f0f1b0b4-398c-6546-b5ff-8149c860f7d5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TList", "[", 
  RowBox[{"\"\<PerfectFluid\>\"", ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "1"}], "}"}], ",", "\"\<Cartesian\>\"", ",", 
   RowBox[{"p", "\[Rule]", "\[Rho]"}]}], "]"}]], "Input",
 CellLabel->"In[88]:=",ExpressionUUID->"955d1e0f-902b-2e4c-b5fc-9633c64db9ae"],

Cell[BoxData[
 StyleBox[
  TagBox[GridBox[{
     {
      TemplateBox[{"\"PerfectFluid\"", "\":\""},
       "RowDefault"]},
     {
      TagBox[GridBox[{
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"T\"", 
              TemplateBox[{"t", "t"}, "RowDefault"]}, "Superscript", 
             SyntaxForm -> SuperscriptBox], 
            TemplateBox[{"\"T\"", 
              TemplateBox[{"x", "x"}, "RowDefault"]}, "Superscript", 
             SyntaxForm -> SuperscriptBox], 
            TemplateBox[{"\"T\"", 
              TemplateBox[{"y", "y"}, "RowDefault"]}, "Superscript", 
             SyntaxForm -> SuperscriptBox], 
            TemplateBox[{"\"T\"", 
              TemplateBox[{"z", "z"}, "RowDefault"]}, "Superscript", 
             SyntaxForm -> SuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", "\[Rho]"}
        },
        AutoDelete->False,
        GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
        GridBoxItemSize->{
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
       "Grid"]}
    },
    DefaultBaseStyle->"Column",
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
   "Column"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"88b1275f-2c85-ce41-94a0-1c9ebd1d0818"]
}, Open  ]],

Cell[TextData[{
 "Additionally, a function can be provided to ",
 StyleBox["TList", "Input"],
 " and ",
 StyleBox["TShow", "Input"],
 " as their last argument. If provided, the function will be applied to each \
of the tensor's components, the components will be simplified, and the tensor \
will be displayed with the new components. Providing a list of rules is \
equivalent to applying the function ",
 StyleBox["ReplaceAll", "Input"],
 " with those rules."
}], "Text",ExpressionUUID->"4c3994de-3cdf-da48-b366-0867ecf9c041"],

Cell["\<\
As an example, let's square the components of the 4-velocity:\
\>", "Text",ExpressionUUID->"95b08127-05e1-e047-b0da-c51b02dc7197"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TShow", "[", 
  RowBox[{"\"\<4-Velocity\>\"", ",", 
   RowBox[{
    SuperscriptBox["#1", "2"], "&"}]}], "]"}]], "Input",
 CellLabel->"In[89]:=",ExpressionUUID->"83af3a94-fd80-8d4b-855f-0b3bfba4c3e9"],

Cell[BoxData[
 StyleBox[
  TemplateBox[{"\"4-Velocity\"", "\":   \"", 
    TemplateBox[{"\"v\"", 
      TemplateBox[{"\"\[Mu]\""}, "RowDefault"]}, "Superscript", SyntaxForm -> 
     SuperscriptBox], "\"(\"", 
    TemplateBox[{",", "\",\"", "t", "x", "y", "z"}, "RowWithSeparators"], 
    "\")\"", "\" = \"", 
    TagBox[
     RowBox[{"(", "\[NoBreak]", 
       TagBox[
        GridBox[{{
           FractionBox["1", 
            RowBox[{"1", "-", 
              SuperscriptBox["v", "2"]}]]}, {
           FractionBox[
            SuperscriptBox["v", "2"], 
            RowBox[{"1", "-", 
              SuperscriptBox["v", "2"]}]]}, {"0"}, {"0"}}, RowSpacings -> 1, 
         ColumnAlignments -> Center, ColumnAlignments -> Left], Column], 
       "\[NoBreak]", ")"}], 
     Function[BoxForm`e$, 
      MatrixForm[BoxForm`e$]]]},
   "RowDefault"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"a2104f58-8d11-e04a-b5f5-fcceccbd82ab"]
}, Open  ]],

Cell["\<\
Indices, coordinates, replacement rules, and functions can all be combined \
together. The full syntax is:\
\>", "Text",ExpressionUUID->"fca974fe-a5e1-5e49-9fae-d3a53e46afe7"],

Cell[TextData[StyleBox["TList[ID, indices, coordinatesID, rules, function]", \
"Input"]], "Item",ExpressionUUID->"6893a165-f4d9-bf4d-8d2b-c85cb05ee381"],

Cell[TextData[StyleBox["TShow[ID, indices, coordinatesID, rules, function]", \
"Input"]], "Item",ExpressionUUID->"936019b5-debc-7740-bbcd-141e32c9e378"],

Cell[TextData[{
 "The arguments must be provided in this exact order, but any of them can be \
omitted. So we can, for example, provide just ",
 StyleBox["indices", "Input"],
 " and ",
 StyleBox["rules", "Input"],
 ", or ",
 StyleBox["coordinatesID", "Input"],
 ", ",
 StyleBox["rules", "Input"],
 ", and ",
 StyleBox["function", "Input"],
 ", and so on; any combination in the correct order will work. If both ",
 StyleBox["rules", "Input"],
 " and ",
 StyleBox["function", "Input"],
 " are given, the rules will be applied before the function."
}], "Text",ExpressionUUID->"48b3947c-3d72-764c-8cdb-1a4fb256a9af"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Customizing the simplification function", "Subsection",ExpressionUUID->"7d04c6c9-299e-1142-b9a5-641470db0ab9"],

Cell[TextData[{
 "Whenever OGRe performs an operation that creates or modifies tensor \
components, such as converting between index representations or coordinate \
systems, it automatically simplifies the result. The simplification function \
can be specified using the module ",
 StyleBox["TSetSimplifyFunc", "Input"],
 ":"
}], "Text",ExpressionUUID->"88c8809e-1827-5a44-8fb7-2b530e18c46f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"?", "TSetSimplifyFunc"}]], "Input",
 CellLabel->"In[90]:=",ExpressionUUID->"10b33550-088c-c440-a4c0-925518c06dbe"],

Cell[BoxData[
 InterpretationBox[
  StyleBox[
   FrameBox[
    DynamicModuleBox[{System`InformationDump`open$$ = False, 
     System`InformationDump`mouseOver$$ = False}, 
     PaneSelectorBox[{True->
      TagBox[GridBox[{
         {
          ItemBox[
           PaneBox[
            StyleBox[
             TagBox[
              TooltipBox[
               StyleBox["\<\" Symbol\"\>", "InformationRowLabel",
                StripOnInput->False],
               "\"Symbol\"",
               TooltipStyle->"TextStyling"],
              Annotation[#, "Symbol", "Tooltip"]& ], "InformationTitleText",
             StripOnInput->False,
             BaseStyle -> None],
            FrameMargins->{{4, 0}, {-1, 1}}],
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False]},
         {
          ItemBox[
           PaneBox[
            
            StyleBox["\<\"\\!\\(\\*InterpretationBox[Cell[TextData[{\\\"\
TSetSimplifyFunc[] shows the function used when simplifying \
expressions.\\\\nTSetSimplifyFunc[\\\", StyleBox[\\\"function\\\", Bold, \
Rule[StripOnInput, False]], \\\"] changes the simplification function. The \
function will be called as \\\", StyleBox[\\\"function\\\", Bold, \
Rule[StripOnInput, False]], \\\"[\\\", StyleBox[\\\"expression\\\", Bold, \
Rule[StripOnInput, False]], \\\", \\\", StyleBox[\\\"assumptions\\\", Bold, \
Rule[StripOnInput, False]], \\\"], where \\\", StyleBox[\\\"assumptions\\\", \
Bold, Rule[StripOnInput, False]], \\\" are the user-defined simplification \
assumptions set using TSetAssumptions[].\\\\nTSetSimplifyFunc[None] disables \
simplification completely.\\\\nTSetSimplifyFunc[Automatic] resets the \
simplification function to the default: FullSimplify.\\\"}]], \
TextCell[Row[List[\\\"TSetSimplifyFunc[] shows the function used when \
simplifying expressions.\\\\nTSetSimplifyFunc[\\\", Style[\\\"function\\\", \
Bold], \\\"] changes the simplification function. The function will be called \
as \\\", Style[\\\"function\\\", Bold], \\\"[\\\", Style[\\\"expression\\\", \
Bold], \\\", \\\", Style[\\\"assumptions\\\", Bold], \\\"], where \\\", \
Style[\\\"assumptions\\\", Bold], \\\" are the user-defined simplification \
assumptions set using TSetAssumptions[].\\\\nTSetSimplifyFunc[None] disables \
simplification completely.\\\\nTSetSimplifyFunc[Automatic] resets the \
simplification function to the default: FullSimplify.\\\"]]]]\\)\"\>", 
             "InformationUsageText",
             StripOnInput->False,
             LineSpacing->{1.5, 1.5, 3.}],
            FrameMargins->{{10, 10}, {8, 10}}],
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False]},
         {
          PaneBox[
           TagBox[GridBox[{
              {
               StyleBox[
                TagBox[
                 TooltipBox[
                  StyleBox["\<\" Definitions\"\>", "InformationRowLabel",
                   StripOnInput->False],
                  "\"Definitions\"",
                  TooltipStyle->"TextStyling"],
                 Annotation[#, "Definitions", "Tooltip"]& ], "DialogStyle",
                StripOnInput->False]},
              {
               TemplateBox[{"\"\[ThinSpace]\"", 
                 GridBox[{{
                    RowBox[{
                    RowBox[{"TSetSimplifyFunc", "[", "]"}], ":=", 
                    RowBox[{
                    RowBox[{"OGRe`Private`TensorData", "[", "Options", "]"}], 
                    "[", "\"SimplifyFunc\"", "]"}]}]}, {" "}, {
                    RowBox[{
                    RowBox[{"TSetSimplifyFunc", "[", "Automatic", "]"}], ":=", 
                    
                    RowBox[{
                    "TSetSimplifyFunc", "[", "FullSimplify", "]"}]}]}, {" "}, 
                   {
                    RowBox[{
                    
                    RowBox[{
                    "TSetSimplifyFunc", "[", "OGRe`Private`func_", "]"}], 
                    ":=", 
                    RowBox[{"(", 
                    RowBox[{
                    
                    RowBox[{
                    "Unprotect", "[", "OGRe`Private`TensorData", "]"}], ";", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"OGRe`Private`TensorData", "[", "Options", "]"}], 
                    "[", "\"SimplifyFunc\"", "]"}], "=", 
                    "OGRe`Private`func"}], ";", 
                    RowBox[{"Protect", "[", "OGRe`Private`TensorData", "]"}], 
                    ";", 
                    RowBox[{"Return", "[", "OGRe`Private`func", "]"}], ";"}], 
                    ")"}]}]}, {" "}}, 
                  GridBoxAlignment -> {"Columns" -> {{Left}}}, 
                  DefaultBaseStyle -> "Column", 
                  GridBoxItemSize -> {
                   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]},
                "RowDefault"]}
             },
             DefaultBaseStyle->"Column",
             GridBoxAlignment->{"Columns" -> {{Left}}},
             
             GridBoxItemSize->{
              "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
            "Column"],
           FrameMargins->{{6, 0}, {3, 6}}], "\<\"\"\>"},
         {
          PaneBox[GridBox[{
             {
              
              DynamicModuleBox[{System`InformationDump`open$$ = {
               False, False, False, False, False, False}}, 
               StyleBox[GridBox[{
                  {
                   TagBox[
                    TooltipBox[
                    
                    StyleBox["\<\" Default Definitions\"\>", 
                    "InformationRowLabel",
                    StripOnInput->False],
                    "\"DefaultValues\"",
                    TooltipStyle->"TextStyling"],
                    Annotation[#, "DefaultValues", "Tooltip"]& ], 
                   InterpretationBox[GridBox[{
                    {
                    RowBox[{
                    RowBox[{
                    "SyntaxInformation", "[", "TSetSimplifyFunc", "]"}], "=", 
                    RowBox[{"{", 
                    RowBox[{"\<\"ArgumentsPattern\"\>", "\[Rule]", 
                    RowBox[{"{", "_.", "}"}]}], "}"}]}]},
                    {" "}
                    },
                    BaselinePosition->{Baseline, {1, 1}},
                    
                    GridBoxAlignment->{
                    "Columns" -> {{Left}}, "Rows" -> {{Baseline}}}],
                    
                    ColumnForm[{
                    SyntaxInformation[OGRe`TSetSimplifyFunc] = {
                    "ArgumentsPattern" -> {
                    Optional[
                    Blank[]]}}, 
                    SpaceForm[1]}],
                    Editable->False]},
                  {
                   TagBox[
                    TooltipBox[
                    StyleBox["\<\" Attributes\"\>", "InformationRowLabel",
                    StripOnInput->False],
                    "\"Attributes\"",
                    TooltipStyle->"TextStyling"],
                    Annotation[#, "Attributes", "Tooltip"]& ], 
                   RowBox[{"{", "Protected", "}"}]},
                  {
                   TagBox[
                    TooltipBox[
                    StyleBox["\<\" Full Name\"\>", "InformationRowLabel",
                    StripOnInput->False],
                    "\"FullName\"",
                    TooltipStyle->"TextStyling"],
                    
                    Annotation[#, "FullName", 
                    "Tooltip"]& ], "\<\"OGRe`TSetSimplifyFunc\"\>"}
                 },
                 AutoDelete->False,
                 GridBoxAlignment->{"Columns" -> {Right, Left}},
                 GridBoxDividers->None,
                 GridBoxItemSize->{"Columns" -> {Automatic, Automatic}},
                 GridBoxSpacings->{"Columns" -> {
                    Offset[0.27999999999999997`], {
                    Offset[0.5599999999999999]}, 
                    Offset[0.27999999999999997`]}, "Rows" -> {
                    Offset[0.2], {
                    Offset[0.8]}, 
                    Offset[0.2]}}], "DialogStyle",
                StripOnInput->False],
               DynamicModuleValues:>{}]}
            },
            DefaultBaseStyle->"Column",
            GridBoxAlignment->{"Columns" -> {{Left}}},
            GridBoxDividers->{"Columns" -> {{False}}, "Rows" -> {{False}}},
            
            GridBoxItemSize->{
             "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}},
            GridBoxSpacings->{"Columns" -> {
                Offset[0.27999999999999997`], {
                 Offset[0.5599999999999999]}, 
                Offset[0.27999999999999997`]}, "Rows" -> {
                Offset[0.2], {
                 Offset[3.6]}, 
                Offset[0.2]}}],
           FrameMargins->{{6, 6}, {6, 3}}], ""},
         {
          ItemBox[
           TagBox[
            ButtonBox[
             PaneSelectorBox[{False->
              
              DynamicBox[FEPrivate`FrontEndResource[
               "FEBitmaps", "UpPointerOpener"]], True->
              
              DynamicBox[FEPrivate`FrontEndResource[
               "FEBitmaps", "UpPointerOpenerHot"]]}, Dynamic[
              System`InformationDump`mouseOver$$]],
             Alignment->Left,
             Appearance->{"Default" -> None},
             
             ButtonFunction:>FEPrivate`Set[
              System`InformationDump`open$$, False],
             Evaluator->Automatic,
             FrameMargins->{{9, 0}, {0, 0}},
             ImageMargins->0,
             ImageSize->Full,
             Method->"Preemptive"],
            
            EventHandlerTag[{
             "MouseEntered" :> 
              FEPrivate`Set[System`InformationDump`mouseOver$$, True], 
              "MouseExited" :> 
              FEPrivate`Set[System`InformationDump`mouseOver$$, False], 
              Method -> "Preemptive", PassEventsDown -> Automatic, 
              PassEventsUp -> True}]],
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False], "\[SpanFromLeft]"}
        },
        AutoDelete->False,
        FrameStyle->Directive[
          LightDarkSwitched[
           GrayLevel[0.8]], 
          Thickness[Tiny]],
        GridBoxAlignment->{"Columns" -> {Left, Right}, "Rows" -> {{Center}}},
        GridBoxDividers->{
         "Columns" -> {{None}}, "Rows" -> {False, {True}, False}},
