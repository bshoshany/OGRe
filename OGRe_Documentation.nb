              SubscriptBox["\"R\"", 
               TemplateBox[{"r", "t", "t", "r"}, "RowDefault"]]}]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{"-", 
           FractionBox[
            RowBox[{"2", " ", "M"}], 
            SuperscriptBox["r", "3"]]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"R\"", 
             TemplateBox[{"t", "\[Theta]", "t", "\[Theta]"}, "RowDefault"]], 
