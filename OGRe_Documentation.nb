Cell[TextData[{
 "To prevent breaking references, ",
 StyleBox["TDelete", "Input"],
 " will not delete a tensor object representing a metric or coordinate system \
if it is referred to by any other tensor. For example, if we try to delete \
the coordinate system ",
 StyleBox["\"Cartesian\"", "Input"],
 ", we will get an error message, since it is used as the default coordinate \
system for some tensors:"
}], "Text",ExpressionUUID->"ee956423-5d85-d447-9036-bc8ec4c9e219"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TDelete", "[", "\"\<Cartesian\>\"", "]"}]], "Input",
 CellLabel->"In[61]:=",ExpressionUUID->"6f3a2b7d-39d3-1342-93f4-a49b9f37df2f"],

Cell[BoxData[
 TemplateBox[{
  "TDelete", "ErrorCoords", 
   "\"The coordinate system \
\\\"\\!\\(\\*RowBox[{\\\"\\\\\\\"Cartesian\\\\\\\"\\\"}]\\)\\\" cannot be \
deleted, as it is the default coordinate system of the tensor \
\\\"\\!\\(\\*RowBox[{\\\"\\\\\\\"4-Velocity\\\\\\\"\\\"}]\\)\\\". To delete \
the coordinate system, first change the default coordinate system of \
\\\"\\!\\(\\*RowBox[{\\\"\\\\\\\"4-Velocity\\\\\\\"\\\"}]\\)\\\" and any \
other relevant tensors.\"", 2, 61, 3, 30274037233204585468, "Local", 
   "OGRe`TDelete"},
  "MessageTemplate2",
  BaseStyle->"MSG"]], "Message",
 CellLabel->
  "During evaluation of \
In[61]:=",ExpressionUUID->"213a5d86-64ed-1d4a-b8e0-a0402f4b8a72"],

Cell[BoxData["$Aborted"], "Output",
 CellLabel->"Out[61]=",ExpressionUUID->"5ea51763-a9cf-114f-8983-e6f721a4c6e6"]
}, Open  ]],

Cell[TextData[{
 "Similarly, we cannot delete the metric ",
 StyleBox["\"Minkowski\"", "Input"],
 " since it was used to define some tensors:"
}], "Text",ExpressionUUID->"313c8c3a-47b3-0b4b-b3c9-31d225728098"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TDelete", "[", "\"\<Minkowski\>\"", "]"}]], "Input",
 CellLabel->"In[62]:=",ExpressionUUID->"da2d0310-3d4d-5b44-b468-664ef04351cd"],

Cell[BoxData[
 TemplateBox[{
  "TDelete", "ErrorMetric", 
   "\"The metric \
\\\"\\!\\(\\*RowBox[{\\\"\\\\\\\"Minkowski\\\\\\\"\\\"}]\\)\\\" cannot be \
deleted, as it has been used to define the tensor \\\"\\!\\(\\*RowBox[{\\\"\\\
\\\\\"4-Velocity\\\\\\\"\\\"}]\\)\\\". To delete the metric, first delete \
\\\"\\!\\(\\*RowBox[{\\\"\\\\\\\"4-Velocity\\\\\\\"\\\"}]\\)\\\" and any \
other tensors defined using this metric.\"", 2, 62, 4, 30274037233204585468, 
   "Local", "OGRe`TDelete"},
  "MessageTemplate2",
  BaseStyle->"MSG"]], "Message",
 CellLabel->
  "During evaluation of \
In[62]:=",ExpressionUUID->"00158d25-257a-a74e-88e6-efa977ceb1cd"],

