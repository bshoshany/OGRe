Cell[TextData[{
 "Note that both ",
 StyleBox["TShow", "Input"],
 " and ",
 StyleBox["TList", "Input"],
 " display their outputs using the ",
 StyleBox["DisplayFormula", "Input"],
 " Notebook style. It's up to the user to decide how to define this style; in \
this notebook, I used a font size of 20, aligned to center. The style may be \
easily changed by clicking on the \"Format\" menu in Mathematica and \
selecting \"Edit Stylesheet\". Then, choose the ",
 StyleBox["DisplayFormula", "Input"],
 " style, select that cell, and modify its format using the \"Format\" menu."
}], "Text",ExpressionUUID->"25033088-0ea2-0d45-a8d9-f0d2618a6e02"],

Cell[TextData[{
 "If, as in the examples above, no additional arguments are given to ",
 StyleBox["TShow", "Input"],
 " and ",
 StyleBox["TList", "Input"],
 ", they display the tensors in their ",
 StyleBox["default indices",
  FontWeight->Bold],
 " and ",
 StyleBox["default coordinates",
  FontWeight->Bold],
 ", which are the ones first used to define the tensor (unless you change \
them later). So, for example, the default indices of the Minkowski metric are \
two lower indices, and its default coordinates are Cartesian. We will show \
later how to change these defaults, and how to display any tensor in any \
index configuration and coordinate system."
}], "Text",ExpressionUUID->"5d81420a-a093-af4c-9fe8-43ba00c6b47d"],

Cell[TextData[{
 "By default, ",
 StyleBox["TList", "Input"],
 " uses ",
 StyleBox["exact sign checks",
  FontWeight->Bold],
 " to detect when two components are the same up to a sign. This is \
controlled by ",
 StyleBox["TSetExactSignChecks[]", "Input"],
 ":"
}], "Text",ExpressionUUID->"77d3f359-7ebe-6d4d-972c-7572c18dd187"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"?", "TSetExactSignChecks"}]], "Input",
 CellLabel->"In[23]:=",ExpressionUUID->"0f4bb6a1-87e6-e24d-8358-77c6108c1045"],

