using TSetCurveParameter[].\"]]]]\)", "Documentation" -> None, "OwnValues" -> 
    None, "UpValues" -> None, "DownValues" -> 
    Information`InformationValueForm[
     DownValues, OGRe`TGeodesicFromLagrangian, {OGRe`TGeodesicFromLagrangian[
         Pattern[OGRe`Private`metricID, 
          Blank[String]]] :> 
       OGRe`Private`EnsureMetricCache[
        OGRe`Private`metricID, "GeodesicFromLagrangian"]}], "SubValues" -> 
    None, "DefaultValues" -> 
    Information`InformationValueForm[
     DefaultValues, OGRe`TGeodesicFromLagrangian, {
      SyntaxInformation[OGRe`TGeodesicFromLagrangian] -> {"ArgumentsPattern" -> {
           Blank[]}}}], "NValues" -> None, "FormatValues" -> None, "Options" -> 
    None, "Attributes" -> {Protected}, "FullName" -> 
    "OGRe`TGeodesicFromLagrangian"|>, False]]], "Output",
 CellLabel->
  "Out[205]=",ExpressionUUID->"c87044f8-1853-084b-b57c-e81b62bdec49"]
}, Open  ]],

Cell["For the Minkowski metric, the geodesic equations are:", "Text",ExpressionUUID->"ad7cfd63-7bdb-f941-a4d0-e49d19ae0e8a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TList", "@", 
  RowBox[{
  "TGeodesicFromLagrangian", "[", "\"\<Minkowski\>\"", "]"}]}]], "Input",
 CellLabel->
  "In[206]:=",ExpressionUUID->"86f9d735-1c2d-df4f-8da1-8a3dd10a8744"],

Cell[BoxData[
 StyleBox[
  TagBox[GridBox[{
     {
      TemplateBox[{"\"Minkowski->GeodesicFromLagrangian\"", "\":\""},
       "RowDefault"]},
     {
      TagBox[GridBox[{
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"0\"", 
             TemplateBox[{"t"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          TemplateBox[{"Inactive", 
            RowBox[{"(", 
              RowBox[{"-", 
                OverscriptBox["t", "."]}], ")"}], "\[Lambda]"},
           "InactiveD"]},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"0\"", 
             TemplateBox[{"x"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          TemplateBox[{"Inactive", 
            OverscriptBox["x", "."], "\[Lambda]"},
           "InactiveD"]},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"0\"", 
             TemplateBox[{"y"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          TemplateBox[{"Inactive", 
            OverscriptBox["y", "."], "\[Lambda]"},
           "InactiveD"]},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"0\"", 
             TemplateBox[{"z"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          TemplateBox[{"Inactive", 
            OverscriptBox["z", "."], "\[Lambda]"},
           "InactiveD"]}
        },
        AutoDelete->False,
        GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
        GridBoxItemSize->{
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
       "Grid"]}
    },
    DefaultBaseStyle->"Column",
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
   "Column"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"7b313d5f-4120-9f4a-9cce-e4b9f13bff2d"]
}, Open  ]],

Cell[TextData[{
 "Note that this module only calculates the left-hand side of the \
Euler-Lagrange equations; if we equate the result to zero, we will get the \
actual geodesic equations. This is hinted at visually by setting the \
resulting tensor's symbol to 0, so that you actually see the equations when \
using ",
 StyleBox["TList", "Input"],
 ". It is trivial to see that the solution to these equations is simply a \
curve with a constant velocity; in a flat Minkowski spacetime, particles \
experience no gravitational force, and thus no acceleration (unless some \
other force acts on them, of course)."
}], "Text",ExpressionUUID->"5f9a26e4-a2a1-f343-97bf-76a1c9c12107"],

Cell[TextData[{
 "The derivatives with respect to the curve parameter ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "f4674420-3da8-0f47-876a-a7248164087f"],
 " are kept unevaluated, using the Mathematica function ",
 StyleBox["Inactive", "Input"],
 ". This simplifies the equations, and can sometimes help solve them by \
inspection. If we want to activate the derivatives, we simply need to use ",
 StyleBox["Activate", "Input"],
 ". Recall that ",
 StyleBox["TList", "Input"],
 " and ",
 StyleBox["TShow", "Input"],
 " can apply a function to the tensor's components before displaying them, so \
we just need to pass ",
 StyleBox["Activate", "Input"],
 " as the last argument:"
}], "Text",ExpressionUUID->"cd6fde4c-be64-0448-9309-1bfb658ff49b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TList", "[", 
  RowBox[{
   RowBox[{"TGeodesicFromLagrangian", "[", "\"\<Minkowski\>\"", "]"}], ",", 
   "Activate"}], "]"}]], "Input",
 CellLabel->
  "In[207]:=",ExpressionUUID->"1f66ba01-283d-c449-8a62-c5f2a77ca481"],

Cell[BoxData[
 StyleBox[
  TagBox[GridBox[{
     {
      TemplateBox[{"\"Minkowski->GeodesicFromLagrangian\"", "\":\""},
       "RowDefault"]},
     {
      TagBox[GridBox[{
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"0\"", 
             TemplateBox[{"t"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{"-", 
           OverscriptBox["t", "\[DoubleDot]"]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"0\"", 
             TemplateBox[{"x"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          OverscriptBox["x", "\[DoubleDot]"]},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"0\"", 
             TemplateBox[{"y"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          OverscriptBox["y", "\[DoubleDot]"]},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"0\"", 
             TemplateBox[{"z"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          OverscriptBox["z", "\[DoubleDot]"]}
        },
        AutoDelete->False,
        GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
        GridBoxItemSize->{
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
       "Grid"]}
    },
    DefaultBaseStyle->"Column",
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
   "Column"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"61f29c7e-62d8-8744-becb-f774d9d7be14"]
}, Open  ]],

Cell["\<\
Now the derivatives have been activated; note that all the components have \
become second derivatives of the coordinates.\
\>", "Text",ExpressionUUID->"81365b92-0c23-d34f-bd2f-f608fcfb308a"],

Cell[TextData[{
 "As with the Lagrangian itself, the geodesic equations are displayed in \
compact notation when using ",
 StyleBox["TList", "Input"],
 ". If we want the full expressions with the explicit derivatives, for \
example in order to pass them to ",
 StyleBox["DSolve", "Input"],
 " and actually solve the equations, we can use ",
 StyleBox["TGetComponents", "Input"],
 ":"
}], "Text",ExpressionUUID->"f4acf60b-3bd3-f24f-83ee-a27c899681e2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TGetComponents", "[", 
  RowBox[{"TGeodesicFromLagrangian", "[", "\"\<Minkowski\>\"", "]"}], 
  "]"}]], "Input",
 CellLabel->
  "In[208]:=",ExpressionUUID->"f9052e17-d672-4545-be01-a39e409835d6"],

Cell[BoxData[
 TemplateBox[{
  "TGetComponents", "UsingDefault", 
   "\"Using \\!\\(\\*RowBox[{\\\"\\\\\\\"the default index configuration {-1} \
and the default coordinate system \\\\\\\\\\\\\\\"Cartesian\\\\\\\\\\\\\\\"\\\
\\\\\"\\\"}]\\).\"", 2, 208, 16, 30274037233204585468, "Local", 
   "OGRe`TGetComponents"},
  "MessageTemplate2",
  BaseStyle->"MSG"]], "Message",
 CellLabel->
  "During evaluation of \
In[208]:=",ExpressionUUID->"b5f910ce-6b5d-1746-bde9-4c86b7a7abfd"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   TemplateBox[{"Inactive", 
     RowBox[{"(", 
       RowBox[{"-", 
         RowBox[{
           SuperscriptBox["t", "\[Prime]", MultilineFunction -> None], "[", 
           "\[Lambda]", "]"}]}], ")"}], "\[Lambda]"},
    "InactiveD"], ",", 
   TemplateBox[{"Inactive", 
     RowBox[{
       SuperscriptBox["x", "\[Prime]", MultilineFunction -> None], "[", 
       "\[Lambda]", "]"}], "\[Lambda]"},
    "InactiveD"], ",", 
   TemplateBox[{"Inactive", 
     RowBox[{
       SuperscriptBox["y", "\[Prime]", MultilineFunction -> None], "[", 
       "\[Lambda]", "]"}], "\[Lambda]"},
    "InactiveD"], ",", 
   TemplateBox[{"Inactive", 
     RowBox[{
       SuperscriptBox["z", "\[Prime]", MultilineFunction -> None], "[", 
       "\[Lambda]", "]"}], "\[Lambda]"},
    "InactiveD"]}], "}"}]], "Output",
 CellLabel->
  "Out[208]=",ExpressionUUID->"90a6f587-c933-e048-953d-53604f82d851"]
}, Open  ]],

Cell[TextData[{
 "Again, if we wish to activate the derivatives, we need to use ",
 StyleBox["Activate", "Input"],
 " (recall that a function passed as the last argument to ",
 StyleBox["TGetComponents", "Input"],
 " is applied to the components before returning them):"
}], "Text",ExpressionUUID->"e735e149-cc5a-6843-8e9c-150dc4a6ea49"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TGetComponents", "[", 
  RowBox[{
   RowBox[{"TGeodesicFromLagrangian", "[", "\"\<Minkowski\>\"", "]"}], ",", 
   "Activate"}], "]"}]], "Input",
 CellLabel->
  "In[209]:=",ExpressionUUID->"fa3f8952-0830-fc44-aa35-4b1e5671f550"],

Cell[BoxData[
 TemplateBox[{
  "TGetComponents", "UsingDefault", 
   "\"Using \\!\\(\\*RowBox[{\\\"\\\\\\\"the default index configuration {-1} \
and the default coordinate system \\\\\\\\\\\\\\\"Cartesian\\\\\\\\\\\\\\\"\\\
\\\\\"\\\"}]\\).\"", 2, 209, 17, 30274037233204585468, "Local", 
   "OGRe`TGetComponents"},
  "MessageTemplate2",
  BaseStyle->"MSG"]], "Message",
 CellLabel->
  "During evaluation of \
In[209]:=",ExpressionUUID->"ea44c136-cd67-6a46-ab8a-1c171a85605a"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"-", 
    RowBox[{
     SuperscriptBox["t", "\[Prime]\[Prime]",
      MultilineFunction->None], "[", "\[Lambda]", "]"}]}], ",", 
   RowBox[{
    SuperscriptBox["x", "\[Prime]\[Prime]",
     MultilineFunction->None], "[", "\[Lambda]", "]"}], ",", 
   RowBox[{
    SuperscriptBox["y", "\[Prime]\[Prime]",
     MultilineFunction->None], "[", "\[Lambda]", "]"}], ",", 
   RowBox[{
    SuperscriptBox["z", "\[Prime]\[Prime]",
     MultilineFunction->None], "[", "\[Lambda]", "]"}]}], "}"}]], "Output",
 CellLabel->
  "Out[209]=",ExpressionUUID->"b45449e3-7fad-9840-97ee-f7cd997390f8"]
}, Open  ]],

Cell["\<\
We can similarly find the geodesic equations of other metrics:\
\>", "Text",ExpressionUUID->"f9de62ac-bde4-9341-ba54-d27611172227"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TList", "@", 
  RowBox[{
  "TGeodesicFromLagrangian", "[", "\"\<Schwarzschild\>\"", "]"}]}]], "Input",
 CellLabel->
  "In[210]:=",ExpressionUUID->"e045678e-ca13-8146-b0e5-d2b2309061c0"],

Cell[BoxData[
 StyleBox[
  TagBox[GridBox[{
     {
      TemplateBox[{"\"Schwarzschild->GeodesicFromLagrangian\"", "\":\""},
       "RowDefault"]},
     {
      TagBox[GridBox[{
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"0\"", 
             TemplateBox[{"t"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          TemplateBox[{"Inactive", 
            RowBox[{"(", 
              RowBox[{
                RowBox[{"(", 
                  RowBox[{
                    RowBox[{"-", "1"}], "+", 
                    FractionBox[
                    RowBox[{"2", " ", "M"}], "r"]}], ")"}], " ", 
                OverscriptBox["t", "."]}], ")"}], "\[Lambda]"},
           "InactiveD"]},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"0\"", 
             TemplateBox[{"r"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           FractionBox[
            RowBox[{"M", " ", 
             SuperscriptBox[
              OverscriptBox["r", "."], "2"]}], 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"-", "2"}], " ", "M"}], "+", "r"}], ")"}], "2"]], "+", 
           FractionBox[
            RowBox[{"M", " ", 
             SuperscriptBox[
              OverscriptBox["t", "."], "2"]}], 
            SuperscriptBox["r", "2"]], "-", 
           RowBox[{"r", " ", 
            RowBox[{"(", 
             RowBox[{
              SuperscriptBox[
               OverscriptBox["\[Theta]", "."], "2"], "+", 
              RowBox[{
               SuperscriptBox[
                OverscriptBox["\[Phi]", "."], "2"], " ", 
               SuperscriptBox[
                RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}]}], ")"}]}], "+", 
           TemplateBox[{"Inactive", 
             FractionBox[
              OverscriptBox["r", "."], 
              RowBox[{"1", "-", 
                FractionBox[
                 RowBox[{"2", " ", "M"}], "r"]}]], "\[Lambda]"},
            "InactiveD"]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"0\"", 
             TemplateBox[{"\[Theta]"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           RowBox[{
            RowBox[{"-", 
             SuperscriptBox["r", "2"]}], " ", 
            RowBox[{"Cos", "[", "\[Theta]", "]"}], " ", 
            SuperscriptBox[
             OverscriptBox["\[Phi]", "."], "2"], " ", 
            RowBox[{"Sin", "[", "\[Theta]", "]"}]}], "+", 
           TemplateBox[{"Inactive", 
             RowBox[{"(", 
               RowBox[{
                 SuperscriptBox["r", "2"], " ", 
                 OverscriptBox["\[Theta]", "."]}], ")"}], "\[Lambda]"},
            "InactiveD"]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"0\"", 
             TemplateBox[{"\[Phi]"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          TemplateBox[{"Inactive", 
            RowBox[{"(", 
              RowBox[{
                SuperscriptBox["r", "2"], " ", 
                OverscriptBox["\[Phi]", "."], " ", 
                SuperscriptBox[
                 RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}], ")"}], 
            "\[Lambda]"},
           "InactiveD"]}
        },
        AutoDelete->False,
        GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
        GridBoxItemSize->{
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
       "Grid"]}
    },
    DefaultBaseStyle->"Column",
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
   "Column"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"42abb07a-01f0-8f42-8262-1d3893a4d586"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TList", "@", 
  RowBox[{"TGeodesicFromLagrangian", "[", "\"\<FLRW\>\"", "]"}]}]], "Input",
 CellLabel->
  "In[211]:=",ExpressionUUID->"cd742b09-69be-074a-8672-5b7882f16b86"],

Cell[BoxData[
 StyleBox[
  TagBox[GridBox[{
     {
      TemplateBox[{"\"FLRW->GeodesicFromLagrangian\"", "\":\""},
       "RowDefault"]},
     {
      TagBox[GridBox[{
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"0\"", 
             TemplateBox[{"t"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           RowBox[{
            RowBox[{"-", "a"}], " ", 
            TemplateBox[{
              SubscriptBox["\"\[PartialD]\"", "t"], "a"},
             "RowDefault"], " ", 
            RowBox[{"(", 
             RowBox[{
              SuperscriptBox[
               OverscriptBox["r", "."], "2"], "+", 
              RowBox[{
               SuperscriptBox["r", "2"], " ", 
               RowBox[{"(", 
                RowBox[{
                 SuperscriptBox[
                  OverscriptBox["\[Theta]", "."], "2"], "+", 
                 RowBox[{
                  SuperscriptBox[
                   OverscriptBox["\[Phi]", "."], "2"], " ", 
                  SuperscriptBox[
                   RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}]}], ")"}]}]}],
              ")"}]}], "+", 
           TemplateBox[{"Inactive", 
             RowBox[{"(", 
               RowBox[{"-", 
                 OverscriptBox["t", "."]}], ")"}], "\[Lambda]"},
            "InactiveD"]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"0\"", 
             TemplateBox[{"r"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           RowBox[{
            RowBox[{"-", 
             SuperscriptBox["a", "2"]}], " ", "r", " ", 
            RowBox[{"(", 
             RowBox[{
              SuperscriptBox[
               OverscriptBox["\[Theta]", "."], "2"], "+", 
              RowBox[{
               SuperscriptBox[
                OverscriptBox["\[Phi]", "."], "2"], " ", 
               SuperscriptBox[
                RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}]}], ")"}]}], "+", 
           TemplateBox[{"Inactive", 
             RowBox[{"(", 
               RowBox[{
                 SuperscriptBox["a", "2"], " ", 
                 OverscriptBox["r", "."]}], ")"}], "\[Lambda]"},
            "InactiveD"]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"0\"", 
             TemplateBox[{"\[Theta]"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           RowBox[{
            RowBox[{"-", 
             SuperscriptBox["a", "2"]}], " ", 
            SuperscriptBox["r", "2"], " ", 
            RowBox[{"Cos", "[", "\[Theta]", "]"}], " ", 
            SuperscriptBox[
             OverscriptBox["\[Phi]", "."], "2"], " ", 
            RowBox[{"Sin", "[", "\[Theta]", "]"}]}], "+", 
           TemplateBox[{"Inactive", 
             RowBox[{"(", 
               RowBox[{
                 SuperscriptBox["a", "2"], " ", 
                 SuperscriptBox["r", "2"], " ", 
                 OverscriptBox["\[Theta]", "."]}], ")"}], "\[Lambda]"},
            "InactiveD"]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"0\"", 
             TemplateBox[{"\[Phi]"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          TemplateBox[{"Inactive", 
            RowBox[{"(", 
              RowBox[{
                SuperscriptBox["a", "2"], " ", 
                SuperscriptBox["r", "2"], " ", 
                OverscriptBox["\[Phi]", "."], " ", 
                SuperscriptBox[
                 RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}], ")"}], 
            "\[Lambda]"},
           "InactiveD"]}
        },
        AutoDelete->False,
        GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
        GridBoxItemSize->{
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
       "Grid"]}
    },
    DefaultBaseStyle->"Column",
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
   "Column"], "DisplayFormula",
  StripOnInput->False]], "Output",
