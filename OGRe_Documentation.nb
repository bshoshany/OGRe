            FractionBox[
             RowBox[{"2", " ", "M"}], "r"]}]]},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"g\"", 
             TemplateBox[{"\[Theta]", "\[Theta]"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          SuperscriptBox["r", "2"]},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"g\"", 
             TemplateBox[{"\[Phi]", "\[Phi]"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           SuperscriptBox["r", "2"], " ", 
           SuperscriptBox[
            RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}]}
