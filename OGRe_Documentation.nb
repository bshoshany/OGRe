Cell[TextData[{
 "but in terms of ",
 Cell[BoxData[
  FormBox[
   StyleBox["t", "TI"], TraditionalForm]],ExpressionUUID->
  "666b07fb-8ffc-5749-8e6b-d2c2cc06f357"],
