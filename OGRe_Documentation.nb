Cell[TextData[{
 StyleBox["TGetComponents", "Input"],
 " can take replacement rules and/or a function to map to the components, in \
the exact same syntax as ",
 StyleBox["TList", "Input"],
 " and ",
 StyleBox["TShow", "Input"],
 " (see above). For example, here are the components of the Schwarzschild \
metric on the hypersurface with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Theta]", "\[LongEqual]", "\[Pi]"}], TraditionalForm]],
  ExpressionUUID->"480f2079-5c4d-2f40-bbc0-7c1f97efe6bb"],
 "/2:"
}], "Text",ExpressionUUID->"85f0c4ef-1024-3d49-9051-f173ff77ac41"],

