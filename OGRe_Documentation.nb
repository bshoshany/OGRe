Cell["\<\
The Riemann tensor with all its indices lowered satisfies the following \
symmetry and anti-symmetry relations:\
\>", "Text",ExpressionUUID->"ceb8d6dd-8c16-c94b-9d1b-a981195fdf9f"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["R", "TI"], "\[Rho]\[Sigma]\[Mu]\[Nu]"], "\[LongEqual]", "-", 
    SubscriptBox[
     StyleBox["R", "TI"], "\[Sigma]\[Rho]\[Mu]\[Nu]"], "\[LongEqual]", "-", 
    SubscriptBox[
     StyleBox["R", "TI"], "\[Rho]\[Sigma]\[Nu]\[Mu]"], "\[LongEqual]", 
    SubscriptBox[
     StyleBox["R", "TI"], "\[Mu]\[Nu]\[Rho]\[Sigma]"]}], "."}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"6aaa5527-de78-3d4a-\
bee2-cde9ebc7aa80"],

Cell[TextData[{
 "We can verify this for the Schwarzschild Riemann tensor using ",
 StyleBox["TList", "Input"],
 ", as it automatically detects components that are the same up to sign:"
}], "Text",ExpressionUUID->"94688486-51a6-424d-81e4-3f8ffedee776"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TList", "[", 
  RowBox[{
   RowBox[{"TRiemann", "[", "\"\<Schwarzschild\>\"", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "1"}], ",", 
     RowBox[{"-", "1"}], ",", 
     RowBox[{"-", "1"}], ",", 
     RowBox[{"-", "1"}]}], "}"}]}], "]"}]], "Input",
 CellLabel->
  "In[159]:=",ExpressionUUID->"9b06c6c1-d2a3-7c4a-be74-77024f0937a9"],

