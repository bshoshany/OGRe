 RowBox[{"TList", "[", 
  RowBox[{"\"\<SimpleMetricManualChristoffel\>\"", ",", "\"\<Spherical\>\""}],
   "]"}]], "Input",
 CellLabel->
  "In[148]:=",ExpressionUUID->"5a03a324-80dc-ba45-89c8-d87e9789b1e0"],

