Cell[CellGroupData[{

Cell["Geodesic equations from the Lagrangian", "Subsection",ExpressionUUID->"bf6354b7-73af-6b45-8f25-13ac231b2995"],

Cell[TextData[{
 "By applying the ",
 StyleBox["Euler-Lagrange equations",
  FontWeight->Bold],
 " to the curve Lagrangian:"
}], "Text",ExpressionUUID->"09a88476-3405-ad4d-b53f-6e6f08329e0f"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    FractionBox[
     StyleBox["d",
      FontSlant->"Plain"], 
     RowBox[{
      StyleBox["d",
       FontSlant->"Plain"], "\[Lambda]"}]], 
    RowBox[{"(", 
     FractionBox[
      RowBox[{"\[PartialD]", 
       StyleBox["L", "TI"]}], 
      RowBox[{"\[PartialD]", 
       SuperscriptBox[
        OverscriptBox[
         StyleBox["x", "TI"], "."], "\[Mu]"]}]], ")"}], "-", 
    FractionBox[
     RowBox[{"\[PartialD]", 
      StyleBox["L", "TI"]}], 
     RowBox[{"\[PartialD]", 
      SuperscriptBox[
       StyleBox["x", "TI"], "\[Mu]"]}]], "\[LongEqual]", "0"}], ","}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"df844f9f-68bf-ff42-\
89d5-6cf0c5346233"],

Cell[TextData[{
 "we can obtain the geodesic equations for our spacetime. This is done using \
the module ",
 StyleBox["TGeodesicFromLagrangian", "Input"],
 ":"
}], "Text",ExpressionUUID->"a3b44b54-55c6-ac4d-af15-d3011ca8483c"],

