              DynamicBox[FEPrivate`FrontEndResource[
               "FEBitmaps", "DownPointerOpener"],
               ImageSizeCache->{10., {2.67529296875, 7.32470703125}}], True->
              
              DynamicBox[FEPrivate`FrontEndResource[
               "FEBitmaps", "DownPointerOpenerHot"],
               ImageSizeCache->{10., {2.67529296875, 7.32470703125}}]}, 
              Dynamic[System`InformationDump`mouseOver$$]],
             Alignment->Left,
             Appearance->{"Default" -> None},
             
             ButtonFunction:>FEPrivate`Set[
              System`InformationDump`open$$, True],
             Evaluator->Automatic,
             FrameMargins->{{9, 0}, {0, 0}},
             ImageMargins->0,
             ImageSize->Full,
             Method->"Preemptive"],
            
            EventHandlerTag[{
             "MouseEntered" :> 
              FEPrivate`Set[System`InformationDump`mouseOver$$, True], 
              "MouseExited" :> 
              FEPrivate`Set[System`InformationDump`mouseOver$$, False], 
              Method -> "Preemptive", PassEventsDown -> Automatic, 
              PassEventsUp -> True}]],
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False], "\[SpanFromLeft]"}
        },
        AutoDelete->False,
        FrameStyle->Directive[
          LightDarkSwitched[
           GrayLevel[0.8]], 
          Thickness[Tiny]],
        GridBoxAlignment->{"Columns" -> {Left, Right}, "Rows" -> {{Center}}},
        GridBoxDividers->{
         "Columns" -> {{None}}, "Rows" -> {False, {True}, False}},
        GridBoxItemSize->{
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
       "Grid"]}, Dynamic[System`InformationDump`open$$],
      BaselinePosition->Baseline,
      FrameMargins->0,
      ImageSize->Automatic],
     DynamicModuleValues:>{}],
    BaseStyle->"InformationGridFrame",
    StripOnInput->False], "InformationGridPlain",
   StripOnInput->False],
  InformationData[<|
   "ObjectType" -> "Symbol", "Usage" -> 
    "\!\(\*InterpretationBox[Cell[TextData[{\"TChangeDefaultIndices[\", \
StyleBox[\"ID\", Bold, Rule[StripOnInput, False]], \", \", StyleBox[\"indices\
\", Bold, Rule[StripOnInput, False]], \"] changes the default index \
configuration of the tensor object \", StyleBox[\"ID\", Bold, \
Rule[StripOnInput, False]], \" to \", StyleBox[\"indices\", Bold, \
Rule[StripOnInput, False]], \".\\n\", StyleBox[\"indices\", Bold, \
Rule[StripOnInput, False]], \" must be a list of the form {\\[PlusMinus]1, \
\\[PlusMinus]1, ...}, where +1 corresponds to an upper index and -1 \
corresponds to a lower index.\"}]], \
TextCell[Row[List[\"TChangeDefaultIndices[\", Style[\"ID\", Bold], \", \", \
Style[\"indices\", Bold], \"] changes the default index configuration of the \
tensor object \", Style[\"ID\", Bold], \" to \", Style[\"indices\", Bold], \
\".\\n\", Style[\"indices\", Bold], \" must be a list of the form \
{\\[PlusMinus]1, \\[PlusMinus]1, ...}, where +1 corresponds to an upper index \
and -1 corresponds to a lower index.\"]]]]\)", "Documentation" -> None, 
    "OwnValues" -> None, "UpValues" -> None, "DownValues" -> 
    Information`InformationValueForm[
     DownValues, OGRe`TChangeDefaultIndices, {OGRe`TChangeDefaultIndices[
         Pattern[OGRe`Private`tensorID, 
          Blank[String]], 
         Pattern[OGRe`Private`indices, 
          Blank[List]]] :> (
        OGRe`Private`CheckIfTensorExists[OGRe`Private`tensorID]; 
        OGRe`Private`CheckIfUserTensor[OGRe`Private`tensorID]; 
        If[OGRe`Private`GetTensorData[OGRe`Private`tensorID]["Role"] === 
          "Coordinates", Message[
            MessageName[OGRe`TChangeDefaultIndices, "ErrorCoords"]]; Abort[]; 
          Null]; If[
         OGRe`Private`GetTensorData[OGRe`Private`tensorID]["Role"] === 
          "Metric", Message[
            MessageName[OGRe`TChangeDefaultIndices, "ErrorMetric"]]; Abort[]; 
          Null]; OGRe`Private`CheckIndicesForm[OGRe`Private`indices]; 
        OGRe`Private`CheckIndicesRank[
         OGRe`Private`indices, OGRe`Private`tensorID]; 
        OGRe`Private`AddRepresentation[
         OGRe`Private`tensorID, OGRe`Private`indices, 
          OGRe`Private`GetTensorData[OGRe`Private`tensorID]["DefaultCoords"]]; 
        OGRe`Private`ChangeTensorKey[
         OGRe`Private`tensorID, "DefaultIndices", OGRe`Private`indices]; 
        Return[OGRe`Private`tensorID]; Null)}], "SubValues" -> None, 
    "DefaultValues" -> 
    Information`InformationValueForm[
     DefaultValues, OGRe`TChangeDefaultIndices, {
      SyntaxInformation[OGRe`TChangeDefaultIndices] -> {"ArgumentsPattern" -> {
           Blank[], 
           Blank[]}}}], "NValues" -> None, "FormatValues" -> None, "Options" -> 
    None, "Attributes" -> {Protected}, "FullName" -> 
    "OGRe`TChangeDefaultIndices"|>, False]]], "Output",
 CellLabel->"Out[74]=",ExpressionUUID->"3e308585-26eb-254d-9099-2fb4c26a3f24"]
}, Open  ]],

Cell["\<\
For example, let us change the default indices of the perfect fluid stress \
tensor to two lower indices:\
\>", "Text",ExpressionUUID->"b4077128-926c-e948-9e87-d2d1e91a8703"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TChangeDefaultIndices", "[", 
  RowBox[{"\"\<PerfectFluid\>\"", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "1"}], ",", 
     RowBox[{"-", "1"}]}], "}"}]}], "]"}]], "Input",
 CellLabel->"In[75]:=",ExpressionUUID->"59c46a51-99be-b846-b914-b3920ab01e1e"],

Cell[BoxData["\<\"PerfectFluid\"\>"], "Output",
 CellLabel->"Out[75]=",ExpressionUUID->"ba249353-96cc-994b-a023-63e37b2afb1a"]
}, Open  ]],

Cell[TextData[{
 "Now, when we display the tensor using ",
 StyleBox["TShow", "Input"],
 " with only the tensor ID, this is the index configuration that will be used:"
}], "Text",ExpressionUUID->"1deff8d4-0b4b-9b48-9dae-130e27607c97"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TShow", "[", "\"\<PerfectFluid\>\"", "]"}]], "Input",
 CellLabel->"In[76]:=",ExpressionUUID->"6ac1b01b-e682-d148-b7c6-27a61e68c9bf"],

Cell[BoxData[
 StyleBox[
  TemplateBox[{"\"PerfectFluid\"", "\":   \"", 
    SubscriptBox["\"T\"", 
     TemplateBox[{"\"\[Mu]\"", "\"\[Nu]\""}, "RowDefault"]], "\"(\"", 
    TemplateBox[{",", "\",\"", "t", "x", "y", "z"}, "RowWithSeparators"], 
    "\")\"", "\" = \"", 
    TagBox[
     RowBox[{"(", "\[NoBreak]", 
       GridBox[{{"\[Rho]", "0", "0", "0"}, {"0", "p", "0", "0"}, {
         "0", "0", "p", "0"}, {"0", "0", "0", "p"}}, RowSpacings -> 1, 
        ColumnSpacings -> 1, RowAlignments -> Baseline, ColumnAlignments -> 
        Center], "\[NoBreak]", ")"}], 
     Function[BoxForm`e$, 
      MatrixForm[BoxForm`e$]]]},
   "RowDefault"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"148f780b-3988-6646-8467-ca0eae3b5a5d"]
}, Open  ]],

Cell["\<\
Note that the default indices can only be changed for user-defined tensors; \
they cannot be changed for coordinates, metrics, or built-in tensors such as \
curvature tensors (which we will introduce later).\
\>", "Text",ExpressionUUID->"eed9b40a-81b0-5441-86af-bf132742be14"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Coordinate transformations", "Subsection",ExpressionUUID->"28c2226c-aac7-8440-a319-d71fb843f014"],

Cell[TextData[{
 "The components of any tensor may be transformed from one coordinate system ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["x", "TI"], "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "87742629-8c32-9948-9e3c-58f570102cd4"],
 " to another coordinate system ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["x", "TI"], 
    SuperscriptBox["\[Mu]", "\[Prime]"]], TraditionalForm]],ExpressionUUID->
  "17ef0307-80d0-c644-9b7c-654cf2a1b3ef"],
 " using the following prescription:"
}], "Text",ExpressionUUID->"f5ac641a-ee91-9041-8e27-449921694900"],

Cell[TextData[{
 "For every lower index ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "f3088074-8c78-a74f-b3aa-e830eeb9e8e1"],
 ", add a factor of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PartialD]", 
    SuperscriptBox[
     StyleBox["x", "TI"], "\[Mu]"]}], TraditionalForm]],ExpressionUUID->
  "bc025389-70b3-e84e-bd47-ef9a419e0e48"],
 "/",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PartialD]", 
    SuperscriptBox[
     StyleBox["x", "TI"], 
     SuperscriptBox["\[Mu]", "\[Prime]"]]}], TraditionalForm]],ExpressionUUID->
  "440c345c-a7f8-b74a-83bf-e16a0ecf1f11"],
 " (i.e. the derivative of the old coordinates with respect to the new, or \
the ",
 StyleBox["Jacobian",
  FontWeight->Bold],
 ")."
}], "Item",ExpressionUUID->"ebf641ed-0070-9a46-afb3-88ac5a04df62"],

Cell[TextData[{
 "For every upper index ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "631ceb63-081f-574b-968e-4555b75e9974"],
 ", add a factor of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PartialD]", 
    SuperscriptBox[
     StyleBox["x", "TI"], 
     SuperscriptBox["\[Mu]", "\[Prime]"]]}], TraditionalForm]],ExpressionUUID->
  "1d5be22d-9e02-5a42-9253-68a8635412df"],
 "/",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PartialD]", 
    SuperscriptBox[
     StyleBox["x", "TI"], "\[Mu]"]}], TraditionalForm]],ExpressionUUID->
  "5d8a0141-7a8e-2f4f-af5e-0e0e8415987e"],
 " (i.e. the derivative of the new coordinates with respect to the old, or \
the inverse of the Jacobian)."
}], "Item",ExpressionUUID->"ae9694f0-a39b-7c48-8ab3-484d9d84aed2"],

Cell[TextData[{
 "For example, given a tensor with components ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    StyleBox["T", "TI"], "\[Alpha]\[Beta]"], TraditionalForm]],ExpressionUUID->
  "13f2f224-3a6e-2042-b55a-b839da44605c"],
 " in a coordinate system ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["x", "TI"], "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "f2a95068-c65b-bd41-9def-90b330d902fa"],
 ", we can transform to components ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    StyleBox["T", "TI"], 
    RowBox[{
     SuperscriptBox["\[Alpha]", "\[Prime]"], 
     SuperscriptBox["\[Beta]", "\[Prime]"]}]], TraditionalForm]],
  ExpressionUUID->"7662b9c6-e64b-184d-b7bf-5ace161299d4"],
 " in another coordinate system ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["x", "TI"], 
    SuperscriptBox["\[Mu]", "\[Prime]"]], TraditionalForm]],ExpressionUUID->
  "49064324-d780-9c49-8d1b-332213bc6aa5"],
 " as follows:"
}], "Text",ExpressionUUID->"489bbb9c-efd3-ff42-88b6-c03ab491629e"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["T", "TI"], 
     RowBox[{
      SuperscriptBox["\[Alpha]", "\[Prime]"], 
      SuperscriptBox["\[Beta]", "\[Prime]"]}]], 
    RowBox[{"(", 
     SuperscriptBox[
      StyleBox["x", "TI"], 
      SuperscriptBox["\[Mu]", "\[Prime]"]], ")"}], "\[LongEqual]", 
    FractionBox[
     RowBox[{"\[PartialD]", 
      SuperscriptBox[
       StyleBox["x", "TI"], "\[Alpha]"]}], 
     RowBox[{"\[PartialD]", 
      SuperscriptBox[
       StyleBox["x", "TI"], 
       SuperscriptBox["\[Alpha]", "\[Prime]"]]}]], 
    FractionBox[
     RowBox[{"\[PartialD]", 
      SuperscriptBox[
       StyleBox["x", "TI"], "\[Beta]"]}], 
     RowBox[{"\[PartialD]", 
      SuperscriptBox[
       StyleBox["x", "TI"], 
       SuperscriptBox["\[Beta]", "\[Prime]"]]}]], 
    SubscriptBox[
     StyleBox["T", "TI"], "\[Alpha]\[Beta]"], 
    RowBox[{"(", 
     SuperscriptBox[
      StyleBox["x", "TI"], "\[Mu]"], ")"}]}], "."}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"d9d1ab65-43e9-df4c-\
a866-50ab96f0796c"],

Cell[TextData[{
 "For a general rank ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     StyleBox["p", "TI"], ",", 
     StyleBox["q", "TI"]}], ")"}], TraditionalForm]],ExpressionUUID->
  "5a47005c-ac30-a74a-9aab-149004a60898"],
 " tensor with ",
 Cell[BoxData[
  FormBox[
   StyleBox["p", "TI"], TraditionalForm]],ExpressionUUID->
  "c7c5d100-3dc8-9048-b244-53c3fcab907c"],
 " upper indices ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Alpha]", "1"], ",", "\[Ellipsis]", ",", 
    SubscriptBox["\[Alpha]", 
     StyleBox["p", "TI"]]}], TraditionalForm]],ExpressionUUID->
  "4cb132a3-4b46-614b-bf6c-45e1746cbfec"],
 " and ",
 Cell[BoxData[
  FormBox[
   StyleBox["q", "TI"], TraditionalForm]],ExpressionUUID->
  "16c5eeba-7c7b-704a-ba47-cb7d0d7012e6"],
 " lower indices ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Beta]", "1"], ",", "\[Ellipsis]", ",", 
    SubscriptBox["\[Beta]", 
     StyleBox["q", "TI"]]}], TraditionalForm]],ExpressionUUID->
  "13100517-97ea-b845-b61c-7529d8ed00a6"],
 ", the transformation takes the form"
}], "Text",ExpressionUUID->"11c16b1c-3403-0541-be57-3c64ed310eae"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubsuperscriptBox[
     StyleBox["T", "TI"], 
     RowBox[{
      SubsuperscriptBox["\[Beta]", "1", "\[Prime]"], 
      SubsuperscriptBox["\[CenterEllipsis]\[Beta]", 
       StyleBox["q", "TI"], "\[Prime]"]}], 
     RowBox[{
      SubsuperscriptBox["\[Alpha]", "1", "\[Prime]"], 
      SubsuperscriptBox["\[CenterEllipsis]\[Alpha]", 
       StyleBox["p", "TI"], "\[Prime]"]}]], 
    RowBox[{"(", 
     SuperscriptBox[
      StyleBox["x", "TI"], 
      SuperscriptBox["\[Mu]", "\[Prime]"]], ")"}], "\[LongEqual]", 
    RowBox[{"(", 
     RowBox[{
      FractionBox[
       RowBox[{"\[PartialD]", 
        SuperscriptBox[
         StyleBox["x", "TI"], 
         SubsuperscriptBox["\[Alpha]", "1", "\[Prime]"]]}], 
       RowBox[{"\[PartialD]", 
        SuperscriptBox[
         StyleBox["x", "TI"], 
         SubscriptBox["\[Alpha]", "1"]]}]], "\[CenterEllipsis]", 
      FractionBox[
       RowBox[{"\[PartialD]", 
        SuperscriptBox[
         StyleBox["x", "TI"], 
         SubsuperscriptBox["\[Alpha]", 
          StyleBox["p", "TI"], "\[Prime]"]]}], 
       RowBox[{"\[PartialD]", 
        SuperscriptBox[
         StyleBox["x", "TI"], 
         SubscriptBox["\[Alpha]", 
          StyleBox["p", "TI"]]]}]]}], ")"}], 
    RowBox[{"(", 
     RowBox[{
      FractionBox[
       RowBox[{"\[PartialD]", 
        SuperscriptBox[
         StyleBox["x", "TI"], 
         SubscriptBox["\[Beta]", "1"]]}], 
       RowBox[{"\[PartialD]", 
        SuperscriptBox[
         StyleBox["x", "TI"], 
         SubsuperscriptBox["\[Beta]", "1", "\[Prime]"]]}]], 
      "\[CenterEllipsis]", 
      FractionBox[
       RowBox[{"\[PartialD]", 
        SuperscriptBox[
         StyleBox["x", "TI"], 
         SubscriptBox["\[Beta]", 
          StyleBox["q", "TI"]]]}], 
       RowBox[{"\[PartialD]", 
        SuperscriptBox[
         StyleBox["x", "TI"], 
         SubsuperscriptBox["\[Beta]", 
          StyleBox["q", "TI"], "\[Prime]"]]}]]}], ")"}], 
    SubsuperscriptBox[
     StyleBox["T", "TI"], 
     RowBox[{
      SubscriptBox["\[Beta]", "1"], 
      SubscriptBox["\[CenterEllipsis]\[Beta]", 
       StyleBox["q", "TI"]]}], 
     RowBox[{
      SubscriptBox["\[Alpha]", "1"], 
      SubscriptBox["\[CenterEllipsis]\[Alpha]", 
       StyleBox["p", "TI"]]}]], 
    RowBox[{"(", 
     SuperscriptBox[
      StyleBox["x", "TI"], "\[Mu]"], ")"}]}], "."}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"ed3da107-2999-9243-\
ae6c-f9a3b2917c14"],

Cell[TextData[{
 "As a mnemonic for this formula, recall that two indices may only be \
contracted if one of them is an upper index and the other is a lower index. \
If an index is in the denominator of a derivative, then its role is reversed \
(upper ",
 Cell[BoxData[
  FormBox["\[LeftRightArrow]", TraditionalForm]],ExpressionUUID->
  "1bb235f0-ac55-664a-865d-3a766479a7b2"],
 " lower). Thus the old (non-primed) and new (primed) indices can only be in \
places that allow properly contracting the Jacobian or inverse Jacobian with \
the tensor. For example, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Alpha]", "1"], TraditionalForm]],ExpressionUUID->
  "8e9a15c7-e4bd-784b-a906-03d983a0ddb2"],
 " is an upper index in ",
 Cell[BoxData[
  FormBox[
   StyleBox["T", "TI"], TraditionalForm]],ExpressionUUID->
  "0f6676fe-b875-9f4f-8003-4a6a6a77f1cf"],
 " and therefore must be contracted with a lower index. Thus, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PartialD]", 
    SuperscriptBox[
     StyleBox["x", "TI"], 
     SubscriptBox["\[Alpha]", "1"]]}], TraditionalForm]],ExpressionUUID->
  "ef16b091-dd0f-8748-a8c1-cbefe871a0e3"],
 " must be in the denominator, to lower its index and allow it to be \
contracted with the tensor."
}], "Text",ExpressionUUID->"0b92354c-5d2c-b843-a44b-79de9c12f7f4"],

Cell[TextData[{
 "As we saw above, OGRe automatically knows how to raise or lower indices as \
needed using the appropriate metric. Similarly, any operation that requires \
transforming to another coordinate system will perform the transformation \
automatically behind the scenes. However, for this to happen, OGRe needs to \
know the appropriate ",
 StyleBox["transformation rules",
  FontWeight->Bold],
 ". These are defined between the tensor objects representing the \
coordinates, which were generated using the module ",
 StyleBox["TNewCoordinates", "Input"],
 ". The rules for transforming from a source coordinate system to a target \
coordinate system are stored within the tensor object representing the \
source. This is done using the module ",
 StyleBox["TAddCoordTransformation", "Input"],
 ":"
}], "Text",ExpressionUUID->"4a66cf39-053e-5a4a-b77a-112c137e605a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"?", "TAddCoordTransformation"}]], "Input",
 CellLabel->"In[77]:=",ExpressionUUID->"d043d419-431c-3e49-8fae-e839074b078f"],

Cell[BoxData[
 InterpretationBox[
  StyleBox[
   FrameBox[
    DynamicModuleBox[{System`InformationDump`open$$ = False, 
     System`InformationDump`mouseOver$$ = False}, 
     PaneSelectorBox[{True->
      TagBox[GridBox[{
         {
          ItemBox[
           PaneBox[
            StyleBox[
             TagBox[
              TooltipBox[
               StyleBox["\<\" Symbol\"\>", "InformationRowLabel",
                StripOnInput->False],
               "\"Symbol\"",
               TooltipStyle->"TextStyling"],
              Annotation[#, "Symbol", "Tooltip"]& ], "InformationTitleText",
             StripOnInput->False,
             BaseStyle -> None],
            FrameMargins->{{4, 0}, {-1, 1}}],
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False]},
         {
          ItemBox[
           PaneBox[
            
            StyleBox["\<\"\\!\\(\\*InterpretationBox[Cell[TextData[{\\\"\
TAddCoordTransformation[\\\", StyleBox[\\\"sourceID\\\", Bold, \
Rule[StripOnInput, False]], \\\", \\\", StyleBox[\\\"targetID\\\", Bold, \
Rule[StripOnInput, False]], \\\", \\\", StyleBox[\\\"rules\\\", Bold, \
Rule[StripOnInput, False]], \\\"] adds a transformation from the coordinate \
system \\\", StyleBox[\\\"sourceID\\\", Bold, Rule[StripOnInput, False]], \
\\\" to the coordinate system \\\", StyleBox[\\\"targetID\\\", Bold, \
Rule[StripOnInput, False]], \\\".\\\\n\\\", StyleBox[\\\"rules\\\", Bold, \
Rule[StripOnInput, False]], \\\" must be a list of transformation rules. For \
example, {x \\\\[Rule] r Sin[\\\\[Theta]] Cos[\\\\[Phi]], y \\\\[Rule] r Sin[\
\\\\[Theta]] Sin[\\\\[Phi]], z \\\\[Rule] r Cos[\\\\[Theta]]} is a \
transformation from Cartesian to spherical coordinates.\\\"}]], \
TextCell[Row[List[\\\"TAddCoordTransformation[\\\", Style[\\\"sourceID\\\", \
Bold], \\\", \\\", Style[\\\"targetID\\\", Bold], \\\", \\\", Style[\\\"rules\
\\\", Bold], \\\"] adds a transformation from the coordinate system \\\", \
Style[\\\"sourceID\\\", Bold], \\\" to the coordinate system \\\", \
Style[\\\"targetID\\\", Bold], \\\".\\\\n\\\", Style[\\\"rules\\\", Bold], \\\
\" must be a list of transformation rules. For example, {x \\\\[Rule] r \
Sin[\\\\[Theta]] Cos[\\\\[Phi]], y \\\\[Rule] r Sin[\\\\[Theta]] \
Sin[\\\\[Phi]], z \\\\[Rule] r Cos[\\\\[Theta]]} is a transformation from \
Cartesian to spherical coordinates.\\\"]]]]\\)\"\>", "InformationUsageText",
             StripOnInput->False,
             LineSpacing->{1.5, 1.5, 3.}],
            FrameMargins->{{10, 10}, {8, 10}}],
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False]},
         {
          PaneBox[
           TagBox[GridBox[{
              {
               StyleBox[
                TagBox[
                 TooltipBox[
                  StyleBox["\<\" Definitions\"\>", "InformationRowLabel",
                   StripOnInput->False],
                  "\"Definitions\"",
                  TooltipStyle->"TextStyling"],
                 Annotation[#, "Definitions", "Tooltip"]& ], "DialogStyle",
                StripOnInput->False]},
              {
               TemplateBox[{"\"\[ThinSpace]\"", 
                 GridBox[{{
                    RowBox[{
                    RowBox[{"TAddCoordTransformation", "[", 
                    
                    RowBox[{
                    "OGRe`Private`sourceID_String", ",", 
                    "OGRe`Private`targetID_String", ",", 
                    "OGRe`Private`rules_List"}], "]"}], ":=", 
                    RowBox[{"Module", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    
                    RowBox[{"OGRe`Private`allJacobians", ",", 
                    "OGRe`Private`dim", ",", "OGRe`Private`inverseJacobian", 
                    ",", "OGRe`Private`jacobian", ",", 
                    "OGRe`Private`newCoordSymbols", ",", 
                    "OGRe`Private`oldCoordSymbols"}], "}"}], ",", 
                    RowBox[{
                    
                    RowBox[{"OGRe`Private`CheckIfTensorExists", "[", 
                    "OGRe`Private`sourceID", "]"}], ";", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"!", 
                    RowBox[{"AllTrue", "[", 
                    RowBox[{"OGRe`Private`rules", ",", 
                    RowBox[{
                    RowBox[{"MatchQ", "[", 
                    RowBox[{"#1", ",", 
                    RowBox[{"_", "\[Rule]", "_"}]}], "]"}], "&"}]}], "]"}]}], 
                    ",", 
                    RowBox[{
                    RowBox[{"Message", "[", 
                    StyleBox[
                    
                    RowBox[{"TAddCoordTransformation", "::", 
