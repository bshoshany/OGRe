           RowBox[{"-", "1"}], "+", 
           FractionBox[
            RowBox[{"2", " ", "M"}], "r"]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"g\"", 
             TemplateBox[{"r", "r"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
