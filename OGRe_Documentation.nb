Cell["\<\
To see explicitly how it differs from the Riemann tensor, compare the \
Kretschmann scalar:\
\>", "Text",ExpressionUUID->"5d6b2d4b-bd21-144d-ba27-e72beb18796a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TShow", "@", 
  RowBox[{
  "TKretschmann", "[", "\"\<SchwarzschildDeSitter\>\"", "]"}]}]], "Input",
 CellLabel->
  "In[183]:=",ExpressionUUID->"2446d613-6fb9-1440-bcd5-07082451a56a"],

Cell[BoxData[
 StyleBox[
  TemplateBox[{
   "\"SchwarzschildDeSitter->Kretschmann\"", "\":   \"", "\"K\"", "\"(\"", 
    TemplateBox[{",", "\",\"", "t", "r", "\[Theta]", "\[Phi]"}, 
     "RowWithSeparators"], "\")\"", "\" = \"", 
    RowBox[{
      FractionBox[
       RowBox[{"48", " ", 
         SuperscriptBox["M", "2"]}], 
       SuperscriptBox["r", "6"]], "+", 
      FractionBox[
       RowBox[{"8", " ", 
         SuperscriptBox["\[CapitalLambda]", "2"]}], "3"]}]},
   "RowDefault"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"3df5ebfd-b0bb-844a-9540-33d5b7627be0"]
}, Open  ]],

Cell["With the norm-squared of the Weyl tensor:", "Text",ExpressionUUID->"3bb937f2-06a3-e948-8e80-be3a19bbb244"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TNormSquared", "[", 
  RowBox[{"TWeyl", "[", "\"\<SchwarzschildDeSitter\>\"", "]"}], 
  "]"}]], "Input",
 CellLabel->
  "In[184]:=",ExpressionUUID->"3a9003e8-b054-8744-8015-fd819e2787b9"],

Cell[BoxData[
 FractionBox[
  RowBox[{"48", " ", 
   SuperscriptBox["M", "2"]}], 
  SuperscriptBox["r", "6"]]], "Output",
 CellLabel->
  "Out[184]=",ExpressionUUID->"01114c3c-242d-f74d-b20b-e3227e555ffc"]
}, Open  ]],

Cell["\<\
The Kretschmann scalar contains both the Schwarzschild mass term and the \
cosmological constant term, while the norm-squared of the Weyl tensor \
contains only the mass term.\
\>", "Text",ExpressionUUID->"04cdbc29-cfff-924d-b8c6-7b536fbefd80"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Covariant derivatives", "Subsection",ExpressionUUID->"cf3c0e6a-ecc4-b349-99c3-0809701a783f"],

Cell[TextData[{
 "The partial derivative has limited use in general relativity, as ",
 StyleBox["it does not transform like a tensor",
  FontWeight->Bold],
 ". Therefore, it is only used in special cases, such as calculating the \
Christoffel symbols and the Riemann tensor. The ",
 StyleBox["covariant derivative",
  FontWeight->Bold],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Del]", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "c7b711ed-041f-834a-a79c-a5a819ce00c5"],
 " is a generalization of the partial derivative, which does transform like a \
tensor (as long as it acts on a proper tensor). It is defined as follows:"
}], "Text",ExpressionUUID->"2e26b951-9620-964d-8038-a15699613349"],

Cell[TextData[{
 "On a scalar ",
 Cell[BoxData[
  FormBox["\[CapitalPhi]", TraditionalForm]],ExpressionUUID->
  "171854f7-33e8-614c-8c9a-05f3ce07a23c"],
 ", the covariant derivative acts as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Del]", "\[Mu]"], "\[CapitalPhi]", "\[Congruent]", 
    SubscriptBox["\[PartialD]", "\[Mu]"], "\[CapitalPhi]"}], 
   TraditionalForm]],ExpressionUUID->"1fed0116-93ab-f94c-beab-21bf8e90b5f2"],
 "."
}], "Item",ExpressionUUID->"36f3bbce-d2a2-5c40-8251-5f1911a61363"],

Cell[TextData[{
 "On a vector ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["v", "TI"], "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "5f7f3883-ef6c-5c43-81f2-adee90131858"],
 ", the covariant derivative acts as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Del]", "\[Mu]"], 
    SuperscriptBox[
     StyleBox["v", "TI"], "\[Nu]"], "\[Congruent]", 
    SubscriptBox["\[PartialD]", "\[Mu]"], 
    SuperscriptBox[
     StyleBox["v", "TI"], "\[Nu]"], "+", 
    SubsuperscriptBox["\[CapitalGamma]", "\[Mu]\[Lambda]", "\[Nu]"], 
    SuperscriptBox[
     StyleBox["v", "TI"], "\[Lambda]"]}], TraditionalForm]],ExpressionUUID->
  "b8c01c1f-ac35-e44a-894d-d1c45bc5faaa"],
 "."
}], "Item",ExpressionUUID->"603d3eb5-51cc-fc4c-89d6-369be91ee149"],

Cell[TextData[{
 "On a covector ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    StyleBox["w", "TI"], "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "6997ff37-8fad-9342-8b11-c66f8bea4074"],
 ", the covariant derivative acts as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Del]", "\[Mu]"], 
    SubscriptBox[
     StyleBox["w", "TI"], "\[Nu]"], "\[Congruent]", 
    SubscriptBox["\[PartialD]", "\[Mu]"], 
    SubscriptBox[
     StyleBox["w", "TI"], "\[Nu]"], "-", 
    SubsuperscriptBox["\[CapitalGamma]", "\[Mu]\[Nu]", "\[Lambda]"], 
    SubscriptBox[
     StyleBox["w", "TI"], "\[Lambda]"]}], TraditionalForm]],ExpressionUUID->
  "3790ccad-0430-f043-9f32-a08c3cb07a5d"],
 "."
}], "Item",ExpressionUUID->"19cd687c-693f-d946-a235-dc6a5bcd0631"],

Cell[TextData[{
 "More generally, on a rank ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     StyleBox["p", "TI"], ",", 
     StyleBox["q", "TI"]}], ")"}], TraditionalForm]],ExpressionUUID->
  "05b05dc9-244d-ac4e-95fa-05ac093a0e08"],
 " tensor with components ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox[
    StyleBox["T", "TI"], 
    RowBox[{
     SubscriptBox["\[Sigma]", "1"], 
     SubscriptBox["\[CenterEllipsis]\[Sigma]", 
      StyleBox["q", "TI"]]}], 
    RowBox[{
     SubscriptBox["\[Nu]", "1"], 
     SubscriptBox["\[CenterEllipsis]\[Nu]", 
      StyleBox["p", "TI"]]}]], TraditionalForm]],ExpressionUUID->
  "345b9d0e-669e-8c41-9f5d-70b9f56b2c97"],
 ", the covariant derivative ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Del]", "\[Mu]"], 
    SubsuperscriptBox[
     StyleBox["T", "TI"], 
     RowBox[{
      SubscriptBox["\[Sigma]", "1"], 
      SubscriptBox["\[CenterEllipsis]\[Sigma]", 
       StyleBox["q", "TI"]]}], 
     RowBox[{
      SubscriptBox["\[Nu]", "1"], 
      SubscriptBox["\[CenterEllipsis]\[Nu]", 
       StyleBox["p", "TI"]]}]]}], TraditionalForm]],ExpressionUUID->
  "8618b42e-b750-f946-bed4-8ab20fcfba40"],
 " is defined as follows:"
}], "Text",ExpressionUUID->"504b84c5-66f1-d74a-94c3-230fceccfcc7"],

Cell[TextData[{
 "The first term will be ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[PartialD]", "\[Mu]"], 
    SubsuperscriptBox[
     StyleBox["T", "TI"], 
     RowBox[{
      SubscriptBox["\[Sigma]", "1"], 
      SubscriptBox["\[CenterEllipsis]\[Sigma]", 
       StyleBox["q", "TI"]]}], 
     RowBox[{
      SubscriptBox["\[Nu]", "1"], 
      SubscriptBox["\[CenterEllipsis]\[Nu]", 
       StyleBox["p", "TI"]]}]]}], TraditionalForm]],ExpressionUUID->
  "e378fa8a-1899-0e43-889f-4408e454702f"],
 "."
}], "Item",ExpressionUUID->"17c3f261-d02b-b346-9783-004f730c4fa5"],

Cell[TextData[{
 "We ",
 StyleBox["add",
  FontWeight->Bold],
 " one term ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[CapitalGamma]", "\[Mu]\[Lambda]", 
     SubscriptBox["\[Nu]", 
      StyleBox["i", "TI"]]], 
    SubsuperscriptBox[
     StyleBox["T", "TI"], 
     RowBox[{
      SubscriptBox["\[Sigma]", "1"], 
      SubscriptBox["\[CenterEllipsis]\[Sigma]", 
       StyleBox["q", "TI"]]}], 
     RowBox[{
      SubscriptBox["\[Nu]", "1"], 
      SubscriptBox["\[CenterEllipsis]\[Lambda]\[CenterEllipsis]\[Nu]", 
       StyleBox["p", "TI"]]}]]}], TraditionalForm]],ExpressionUUID->
  "c7f3ca9f-7066-3c45-920c-b299b81c3806"],
 " for each upper index ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Nu]", 
    StyleBox["i", "TI"]], TraditionalForm]],ExpressionUUID->
  "85862034-982f-974b-9aad-85d0b2183c42"],
 "."
}], "Item",ExpressionUUID->"9abdad30-8e42-8f4f-a8fe-d29d3bfd2728"],

Cell[TextData[{
 "We ",
 StyleBox["subtract",
  FontWeight->Bold],
 " one term ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[CapitalGamma]", 
     SubscriptBox["\[Mu]\[Sigma]", 
      StyleBox["i", "TI"]], "\[Lambda]"], 
    SubsuperscriptBox[
     StyleBox["T", "TI"], 
     RowBox[{
      SubscriptBox["\[Sigma]", "1"], 
      SubscriptBox["\[CenterEllipsis]\[Lambda]\[CenterEllipsis]\[Sigma]", 
       StyleBox["q", "TI"]]}], 
     RowBox[{
      SubscriptBox["\[Nu]", "1"], 
      SubscriptBox["\[CenterEllipsis]\[Nu]", 
       StyleBox["p", "TI"]]}]]}], TraditionalForm]],ExpressionUUID->
  "72adef1f-c00b-b64d-8f92-40755401f40a"],
 " for each lower index ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Sigma]", 
    StyleBox["i", "TI"]], TraditionalForm]],ExpressionUUID->
  "725bccd7-6073-3e4f-a063-8103252af877"],
 "."
}], "Item",ExpressionUUID->"b6b816ed-1289-3f4b-a887-8e41943e79c9"],

Cell["\<\
Note that even though the covariant derivative is made from ingredients that \
do not transform like tensors - the partial derivative and the Christoffel \
symbols - the unwanted terms in the transformations of these ingredients \
cancel each other exactly, so that in the end, the entire sum does transform \
like a tensor.\
\>", "Text",ExpressionUUID->"73ad7f91-efe3-304a-af9b-22f4fda6605c"],

Cell["\<\
As usual, we can, of course, write down the covariant derivative manually. \
For example, the covariant divergence of the metric is:\
\>", "Text",ExpressionUUID->"e1121290-219e-ec41-ad57-f948d1fff125"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox["\[Del]", "\[Mu]"], 
    SubscriptBox[
     StyleBox["g", "TI"], "\[Alpha]\[Beta]"], "\[LongEqual]", 
    SubscriptBox["\[PartialD]", "\[Mu]"], 
    SubscriptBox[
     StyleBox["g", "TI"], "\[Alpha]\[Beta]"], "-", 
    SubsuperscriptBox["\[CapitalGamma]", "\[Mu]\[Alpha]", "\[Lambda]"], 
    SubscriptBox[
     StyleBox["g", "TI"], "\[Lambda]\[Beta]"], "-", 
    SubsuperscriptBox["\[CapitalGamma]", "\[Mu]\[Beta]", "\[Lambda]"], 
    SubscriptBox[
     StyleBox["g", "TI"], "\[Alpha]\[Lambda]"]}], "."}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"2cd6b4f8-904a-9445-\
9848-d56ec22bfd13"],

Cell[TextData[{
 "It should vanish, by definition, for any metric; this is what we meant when \
we said the Levi-Civita connection ",
 StyleBox["preserves",
  FontWeight->Bold],
 " the metric. Indeed, we have for the Schwarzschild metric:"
}], "Text",ExpressionUUID->"4528d9de-d081-0149-982e-36e0fa287010"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TList", "@", 
  RowBox[{"TCalc", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"TPartialD", "[", "\"\<\[Mu]\>\"", "]"}], ".", 
     RowBox[{"\"\<Schwarzschild\>\"", "[", "\"\<\[Alpha]\[Beta]\>\"", "]"}]}],
     "-", 
    RowBox[{
     RowBox[{
      RowBox[{"TChristoffel", "[", "\"\<Schwarzschild\>\"", "]"}], 
      "[", "\"\<\[Lambda]\[Mu]\[Alpha]\>\"", "]"}], ".", 
     RowBox[{"\"\<Schwarzschild\>\"", "[", "\"\<\[Lambda]\[Beta]\>\"", 
      "]"}]}], "-", 
    RowBox[{
     RowBox[{
      RowBox[{"TChristoffel", "[", "\"\<Schwarzschild\>\"", "]"}], 
      "[", "\"\<\[Lambda]\[Mu]\[Beta]\>\"", "]"}], ".", 
     RowBox[{"\"\<Schwarzschild\>\"", "[", "\"\<\[Alpha]\[Lambda]\>\"", 
      "]"}]}]}], "]"}]}]], "Input",
 CellLabel->
  "In[185]:=",ExpressionUUID->"4f08fe94-1a36-d041-bee7-75f61087dfc7"],

Cell[BoxData[
 StyleBox[
  TagBox[GridBox[{
     {
      TemplateBox[{"\"Result\"", "\":\""},
       "RowDefault"]},
     {"\<\"No non-zero elements.\"\>"}
    },
    DefaultBaseStyle->"Column",
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
   "Column"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"62f756e8-ccab-5e40-a26f-e29f14cc2bc0"]
}, Open  ]],

Cell[TextData[{
 "Much more conveniently, the covariant derivative is represented in OGRe as ",
 StyleBox["TCovariantD", "Input"],
 ". It will automatically add the correct terms, as detailed above, for each \
of the tensor's indices. To use it, simply contract it with any tensor, just \
like ",
 StyleBox["TPartialD", "Input"],
 ":"
}], "Text",ExpressionUUID->"aa0e6c61-a29b-154c-9a36-f3fd22fc7fe1"],

