                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"], 
                TemplateBox[{
                  Rational[19, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
            TemplateBox[{"\"\[CapitalGamma]\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[19, 2]}, "Spacer1"], "\[Phi]", "r"}, "RowDefault"], 
              TemplateBox[{"\[Phi]", 
                TemplateBox[{
                  Rational[19, 2]}, "Spacer1"], 
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", 
          FractionBox["1", "r"]},
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"\[CapitalGamma]\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[17, 2]}, "Spacer1"], "\[Phi]", "\[Phi]"}, 
               "RowDefault"], 
              TemplateBox[{"\[Theta]", 
                TemplateBox[{
                  Rational[19, 2]}, "Spacer1"], 
