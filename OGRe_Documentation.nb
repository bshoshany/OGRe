Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TList", "@", 
  RowBox[{
  "TGeodesicFromLagrangian", "[", "\"\<Alcubierre\>\"", "]"}]}]], "Input",
 CellLabel->
  "In[212]:=",ExpressionUUID->"ad1283b8-e176-514b-87c1-fd1e16295807"],

Cell[BoxData[
 StyleBox[
  TagBox[GridBox[{
     {
      TemplateBox[{"\"Alcubierre->GeodesicFromLagrangian\"", "\":\""},
       "RowDefault"]},
     {
      TagBox[GridBox[{
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"0\"", 
             TemplateBox[{"t"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           RowBox[{
            RowBox[{"-", 
             OverscriptBox["t", "."]}], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"f", " ", "v", " ", 
               OverscriptBox["t", "."]}], "-", 
              OverscriptBox["z", "."]}], ")"}], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"v", " ", 
               TemplateBox[{
                 SubscriptBox["\"\[PartialD]\"", "t"], "f"},
                "RowDefault"]}], "+", 
              RowBox[{"f", " ", 
               TemplateBox[{
                 SubscriptBox["\"\[PartialD]\"", "t"], "v"},
                "RowDefault"]}]}], ")"}]}], "+", 
           TemplateBox[{"Inactive", 
             RowBox[{"(", 
               RowBox[{
                 RowBox[{
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"-", "1"}], "+", 
                    RowBox[{
                    SuperscriptBox["f", "2"], " ", 
                    SuperscriptBox["v", "2"]}]}], ")"}], " ", 
                   OverscriptBox["t", "."]}], "-", 
                 RowBox[{"f", " ", "v", " ", 
                   OverscriptBox["z", "."]}]}], ")"}], "\[Lambda]"},
            "InactiveD"]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"0\"", 
             TemplateBox[{"x"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           RowBox[{"v", " ", 
            OverscriptBox["t", "."], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"-", "f"}], " ", "v", " ", 
               OverscriptBox["t", "."]}], "+", 
              OverscriptBox["z", "."]}], ")"}], " ", 
            TemplateBox[{
              SubscriptBox["\"\[PartialD]\"", "x"], "f"},
             "RowDefault"]}], "+", 
           TemplateBox[{"Inactive", 
             OverscriptBox["x", "."], "\[Lambda]"},
            "InactiveD"]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"0\"", 
             TemplateBox[{"y"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           RowBox[{"v", " ", 
            OverscriptBox["t", "."], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"-", "f"}], " ", "v", " ", 
               OverscriptBox["t", "."]}], "+", 
              OverscriptBox["z", "."]}], ")"}], " ", 
            TemplateBox[{
              SubscriptBox["\"\[PartialD]\"", "y"], "f"},
             "RowDefault"]}], "+", 
           TemplateBox[{"Inactive", 
             OverscriptBox["y", "."], "\[Lambda]"},
            "InactiveD"]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"0\"", 
             TemplateBox[{"z"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           RowBox[{"v", " ", 
            OverscriptBox["t", "."], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"-", "f"}], " ", "v", " ", 
               OverscriptBox["t", "."]}], "+", 
              OverscriptBox["z", "."]}], ")"}], " ", 
            TemplateBox[{
              SubscriptBox["\"\[PartialD]\"", "z"], "f"},
             "RowDefault"]}], "+", 
           TemplateBox[{"Inactive", 
             RowBox[{"(", 
               RowBox[{
                 RowBox[{
                   RowBox[{"-", "f"}], " ", "v", " ", 
                   OverscriptBox["t", "."]}], "+", 
                 OverscriptBox["z", "."]}], ")"}], "\[Lambda]"},
            "InactiveD"]}]}
        },
        AutoDelete->False,
        GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
        GridBoxItemSize->{
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
       "Grid"]}
    },
    DefaultBaseStyle->"Column",
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
   "Column"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"6b099cf2-7fc2-734c-b992-be24570c999e"]
}, Open  ]],

Cell["\<\
The last example, the geodesic equations of the Alcubierre metric, is a good \
example of how we can solve the geodesic equations by inspection. Indeed, it \
is easy to see that\
\>", "Text",ExpressionUUID->"e417e39f-33aa-3443-8b3f-3e0eefe8e1ca"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SuperscriptBox[
    OverscriptBox[
     StyleBox["x", "TI"], "."], "\[Mu]"], "\[LongEqual]", 
   RowBox[{"(", 
    RowBox[{"1", ",", "0", ",", "0", ",", 
     StyleBox["v", "TI"], 
     StyleBox["f", "TI"]}], ")"}]}], TraditionalForm]], "DisplayFormula",Expre\
ssionUUID->"cab55bd3-d199-6b42-acae-71fe6e4535f9"],

Cell[TextData[{
 "is a solution to this system of equations, since then we have ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox[
     StyleBox["x", "TI"], "."], "\[LongEqual]", 
    OverscriptBox[
     StyleBox["y", "TI"], "."], "\[LongEqual]", "0"}], TraditionalForm]],
  ExpressionUUID->"19eca217-b21b-8c46-baf3-05350d79038b"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      StyleBox["f", "TI"], 
      StyleBox["v", "TI"], 
      OverscriptBox[
       StyleBox["t", "TI"], "."], "-", 
      OverscriptBox[
       StyleBox["z", "TI"], "."]}], ")"}], "\[LongEqual]", "0"}], 
   TraditionalForm]],ExpressionUUID->"139a9454-f83c-c541-af65-90243228d4e7"],
 ", and both terms in each equation vanish (the last term in the first \
equation will reduce to ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[PartialD]", "\[Lambda]"], "(", 
    RowBox[{"-", "1"}], ")"}], TraditionalForm]],ExpressionUUID->
  "f537e679-92f3-4d40-9657-40465ac584e3"],
 ", which is of course zero). We can verify this solution by replacing the \
coordinate functions with their solutions; since we will be left with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[PartialD]", "\[Lambda]"], "(", 
    RowBox[{"-", "1"}], ")"}], TraditionalForm]],ExpressionUUID->
  "49f82a19-be80-a44f-a972-c12efae9962d"],
 " in the first equation, we must also activate the derivative:"
}], "Text",ExpressionUUID->"059c5811-9bc2-9749-af3f-81d8ef8f43ff"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TList", "[", 
  RowBox[{
   RowBox[{"TGeodesicFromLagrangian", "[", "\"\<Alcubierre\>\"", "]"}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"Activate", "@", 
      RowBox[{"#1", "/.", "\[VeryThinSpace]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           SuperscriptBox["t", "\[Prime]",
            MultilineFunction->None], "[", "\[Lambda]", "]"}], "\[Rule]", 
          "1"}], ",", 
         RowBox[{
          RowBox[{
           SuperscriptBox["x", "\[Prime]",
            MultilineFunction->None], "[", "\[Lambda]", "]"}], "\[Rule]", 
          "0"}], ",", 
         RowBox[{
          RowBox[{
           SuperscriptBox["y", "\[Prime]",
            MultilineFunction->None], "[", "\[Lambda]", "]"}], "\[Rule]", 
          "0"}], ",", 
         RowBox[{
          RowBox[{
           SuperscriptBox["z", "\[Prime]",
            MultilineFunction->None], "[", "\[Lambda]", "]"}], "\[Rule]", 
          RowBox[{
           RowBox[{"v", "[", 
            RowBox[{"t", "[", "\[Lambda]", "]"}], "]"}], " ", 
           RowBox[{"f", "[", 
            RowBox[{
             RowBox[{"t", "[", "\[Lambda]", "]"}], ",", 
             RowBox[{"x", "[", "\[Lambda]", "]"}], ",", 
             RowBox[{"y", "[", "\[Lambda]", "]"}], ",", 
             RowBox[{"z", "[", "\[Lambda]", "]"}]}], "]"}]}]}]}], "}"}]}]}], 
     ")"}], "&"}]}], "]"}]], "Input",
 CellLabel->
  "In[213]:=",ExpressionUUID->"d7a584f9-0e0e-fe47-b86a-22ffa38b52cd"],

Cell[BoxData[
 StyleBox[
  TagBox[GridBox[{
     {
      TemplateBox[{"\"Alcubierre->GeodesicFromLagrangian\"", "\":\""},
       "RowDefault"]},
     {"\<\"No non-zero elements.\"\>"}
    },
    DefaultBaseStyle->"Column",
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
   "Column"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"7c403cb5-c8fb-7345-bd1c-97818d3aa56a"]
}, Open  ]],

Cell[TextData[{
 "Notice how we had to write the coordinates explicitly as ",
 StyleBox["functions of the curve parameter",
  FontWeight->Bold],
 ", even when they are arguments of a function; for example, ",
 StyleBox["v[t]", "Input"],
 " became ",
 StyleBox["v[t[\[Lambda]]]", "Input"],
 ". This solution indicates that we are traveling with velocity ",
 Cell[BoxData[
  FormBox[
   StyleBox["v", "TI"], TraditionalForm]],ExpressionUUID->
  "5e00e066-3b57-b446-8baa-0e495065f235"],
 " in the ",
 Cell[BoxData[
  FormBox[
   StyleBox["z", "TI"], TraditionalForm]],ExpressionUUID->
  "024c9c0c-85c3-e343-8137-1be25227d207"],
 " direction; the warp bubble (inside which, as you recall, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["f", "TI"], "\[LongEqual]", "1"}], TraditionalForm]],
  ExpressionUUID->"66cf4c6e-4c25-7b4d-88fc-1ed79923120b"],
 ") moves whatever is inside it, such as a spaceship, through space at the \
velocity ",
 Cell[BoxData[
  FormBox[
   StyleBox["v", "TI"], TraditionalForm]],ExpressionUUID->
  "e4cd1998-40c2-834a-a761-46cf5bccb581"],
 ", but there is no limit on ",
 Cell[BoxData[
  FormBox[
   StyleBox["v", "TI"], TraditionalForm]],ExpressionUUID->
  "85629e4a-266b-054b-b8d4-e4d1b7524b7c"],
 " - it can even be faster than light!"
}], "Text",ExpressionUUID->"85c8cb08-354a-be49-bb03-7f80da1484c8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Geodesic equations from the Christoffel symbols", "Subsection",ExpressionUUID->"b978be24-48a2-f642-9b8d-88dce9d05b06"],

Cell["\<\
Another way of obtaining the geodesic equations is using the covariant \
derivative, and thus the Christoffel symbols:\
\>", "Text",ExpressionUUID->"57b95ebd-51fa-9646-9034-536635c71800"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SuperscriptBox[
     OverscriptBox[
      StyleBox["x", "TI"], "."], "\[Rho]"], 
    SubscriptBox["\[Del]", "\[Rho]"], 
    SuperscriptBox[
     OverscriptBox[
      StyleBox["x", "TI"], "."], "\[Sigma]"], "\[LongEqual]", 
    RowBox[{"0", "  "}], 
    RowBox[{"\[DoubleRightArrow]", "  "}], 
    SuperscriptBox[
     OverscriptBox[
      StyleBox["x", "TI"], "\:0308"], "\[Sigma]"], "+", 
    SubsuperscriptBox["\[CapitalGamma]", "\[Mu]\[Nu]", "\[Sigma]"], 
    SuperscriptBox[
     OverscriptBox[
      StyleBox["x", "TI"], "."], "\[Mu]"], 
    SuperscriptBox[
     OverscriptBox[
      StyleBox["x", "TI"], "."], "\[Nu]"], "\[LongEqual]", "0"}], "."}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"b337edac-8a70-6141-\
8504-fda0e05b0384"],

Cell[TextData[{
 "In OGRe, we can calculate the left-hand side of this equation using ",
 StyleBox["TGeodesicFromChristoffel", "Input"],
 ":"
}], "Text",ExpressionUUID->"888580b1-5c69-1a47-bdfa-6a845bd0c912"],

