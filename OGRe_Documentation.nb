                    ";", 
                    RowBox[{"Protect", "[", "OGRe`Private`TensorData", "]"}], 
                    ";", 
                    RowBox[{"If", "[", 
                    RowBox[{"OGRe`Private`par", ",", 
                    RowBox[{
                    
                    RowBox[{"OGRe`Private`OGRePrint", "[", 
                    "\"Parallelization enabled.\"", "]"}], ";", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"$KernelCount", "<", "$MaxLicenseSubprocesses"}], 
                    ",", 
                    RowBox[{
                    RowBox[{"LaunchKernels", "[", 
