                    RowBox[{
                    RowBox[{"OGRe`Private`useCoords", "=", 
                    RowBox[{
                    
                    RowBox[{"OGRe`Private`GetTensorData", "[", 
                    "OGRe`Private`tensorID", "]"}], "[", "\"DefaultCoords\"", 
                    "]"}]}], ";", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"OGRe`Private`usingMessage", "=!=", "\"\""}], ",", 
