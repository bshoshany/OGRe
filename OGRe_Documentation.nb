}, Open  ]],

Cell[TextData[{
 "For example, let us give the symbol ",
 Cell[BoxData[
  FormBox[
   StyleBox["u", "TI"], TraditionalForm]],ExpressionUUID->
  "8865dd78-e224-ed45-a1e8-c253835d931c"],
 " to the four-velocity, and then show it:"
}], "Text",ExpressionUUID->"318ee88a-9005-1749-946f-aab288e5d1fa"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TShow", "@", 
  RowBox[{"TChangeSymbol", "[", 
   RowBox[{"\"\<FourVelocity\>\"", ",", "\"\<u\>\""}], "]"}]}]], "Input",
