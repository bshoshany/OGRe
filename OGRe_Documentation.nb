Cell[CellGroupData[{

Cell["The Einstein tensor", "Subsection",ExpressionUUID->"7a16caea-2e12-ee48-9975-bbb7e211ca31"],

Cell[TextData[{
 "The ",
 StyleBox["Einstein tensor",
  FontWeight->Bold],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    StyleBox["G", "TI"], "\[Mu]\[Nu]"], TraditionalForm]],ExpressionUUID->
  "6c3ed0bc-49b7-ff43-8a80-dc45d85e4908"],
 " is given by:"
}], "Text",ExpressionUUID->"331c86ac-7466-0748-b465-be3c324d1247"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["G", "TI"], "\[Mu]\[Nu]"], "\[LongEqual]", 
    SubscriptBox[
     StyleBox["R", "TI"], "\[Mu]\[Nu]"], "-", 
    FractionBox["1", "2"], 
    SubscriptBox[
     StyleBox["g", "TI"], "\[Mu]\[Nu]"], 
    StyleBox["R", "TI"]}], "."}], TraditionalForm]], "DisplayFormula",Expressi\
onUUID->"62f72b37-ce44-5842-8071-e1d86da9dbab"],

Cell["\<\
As with all other curvature tensors, we can calculate it by combining the \
previously calculated tensors with the usual syntax:\
\>", "Text",ExpressionUUID->"983e3e41-71e4-f54b-b3cc-baec3d23cc2a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TList", "[", 
  RowBox[{"TCalc", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"TRicci", "[", "\"\<FLRW\>\"", "]"}], "[", "\"\<\[Mu]\[Nu]\>\"",
       "]"}], "-", 
     RowBox[{
      FractionBox["1", "2"], " ", 
      RowBox[{
       RowBox[{"\"\<FLRW\>\"", "[", "\"\<\[Mu]\[Nu]\>\"", "]"}], ".", 
       RowBox[{
        RowBox[{"TRicciScalar", "[", "\"\<FLRW\>\"", "]"}], "[", "\"\<\>\"", 
        "]"}]}]}]}], ",", "\"\<G\>\""}], "]"}], "]"}]], "Input",
 CellLabel->
  "In[173]:=",ExpressionUUID->"95403dc3-e688-4d4c-9a85-f08e72637e39"],

Cell[BoxData[
 StyleBox[
  TagBox[GridBox[{
     {
      TemplateBox[{"\"Result\"", "\":\""},
       "RowDefault"]},
     {
      TagBox[GridBox[{
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"G\"", 
             TemplateBox[{"t", "t"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          FractionBox[
           RowBox[{"3", " ", 
            RowBox[{"(", 
             RowBox[{"k", "+", 
              SuperscriptBox[
               TemplateBox[{"\"(\"", 
                 TemplateBox[{
                   SubscriptBox["\"\[PartialD]\"", "t"], "a"}, "RowDefault"], 
                 "\")\""},
                "RowDefault"], "2"]}], ")"}]}], 
           SuperscriptBox["a", "2"]]},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"G\"", 
             TemplateBox[{"r", "r"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          FractionBox[
           RowBox[{"k", "+", 
            RowBox[{"2", " ", "a", " ", 
             TemplateBox[{
               
               TemplateBox[{"\"\[PartialD]\"", "t", "2"}, "Subsuperscript", 
                SyntaxForm -> SubsuperscriptBox], "a"},
              "RowDefault"]}], "+", 
            SuperscriptBox[
             TemplateBox[{"\"(\"", 
               TemplateBox[{
                 SubscriptBox["\"\[PartialD]\"", "t"], "a"}, "RowDefault"], 
               "\")\""},
              "RowDefault"], "2"]}], 
           RowBox[{
            RowBox[{"-", "1"}], "+", 
            RowBox[{"k", " ", 
             SuperscriptBox["r", "2"]}]}]]},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"G\"", 
             TemplateBox[{"\[Theta]", "\[Theta]"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           RowBox[{"-", 
            SuperscriptBox["r", "2"]}], " ", 
           RowBox[{"(", 
            RowBox[{"k", "+", 
             RowBox[{"2", " ", "a", " ", 
              TemplateBox[{
                
                TemplateBox[{"\"\[PartialD]\"", "t", "2"}, "Subsuperscript", 
                 SyntaxForm -> SubsuperscriptBox], "a"},
               "RowDefault"]}], "+", 
             SuperscriptBox[
              TemplateBox[{"\"(\"", 
                TemplateBox[{
                  SubscriptBox["\"\[PartialD]\"", "t"], "a"}, "RowDefault"], 
                "\")\""},
               "RowDefault"], "2"]}], ")"}]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"G\"", 
             TemplateBox[{"\[Phi]", "\[Phi]"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           RowBox[{"-", 
            SuperscriptBox["r", "2"]}], " ", 
           RowBox[{"(", 
            RowBox[{"k", "+", 
             RowBox[{"2", " ", "a", " ", 
              TemplateBox[{
                
                TemplateBox[{"\"\[PartialD]\"", "t", "2"}, "Subsuperscript", 
                 SyntaxForm -> SubsuperscriptBox], "a"},
               "RowDefault"]}], "+", 
             SuperscriptBox[
              TemplateBox[{"\"(\"", 
                TemplateBox[{
                  SubscriptBox["\"\[PartialD]\"", "t"], "a"}, "RowDefault"], 
                "\")\""},
               "RowDefault"], "2"]}], ")"}], " ", 
           SuperscriptBox[
            RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}]}
        },
        AutoDelete->False,
        GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
        GridBoxItemSize->{
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
