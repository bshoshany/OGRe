available, the user will be given the option to download or install it.\"}]], \
TextCell[Row[List[\"TCheckForUpdates[] checks the GitHub repository for new \
versions of this package. If a new version is available, the user will be \
given the option to download or install it.\"]]]]\)", "Documentation" -> None,
     "OwnValues" -> None, "UpValues" -> None, "DownValues" -> 
    Information`InformationValueForm[
     DownValues, OGRe`TCheckForUpdates, {
      OGRe`TCheckForUpdates[] :> 
       Module[{OGRe`Private`errorMessage, OGRe`Private`latestRelease, 
          OGRe`Private`newVersion, OGRe`Private`newVersionQ, 
          OGRe`Private`releaseFileURL, OGRe`Private`releaseNotes, 
          OGRe`Private`releaseURL, OGRe`Private`toPrint}, 
         OGRe`Private`errorMessage = 
          Row[{"Error: Failed to check for updates. Please visit ", 
             Hyperlink["https://github.com/bshoshany/OGRe/releases"], 
             " to check manually."}]; 
         OGRe`Private`OGRePrint["Checking GitHub repository for updates..."]; 
         OGRe`Private`latestRelease = OGRe`Private`LatestReleaseData[]; 
         If[OGRe`Private`latestRelease === $Failed, 
           OGRe`Private`OGRePrint[OGRe`Private`errorMessage]; Abort[]; Null]; 
         OGRe`Private`newVersion = OGRe`Private`latestRelease["tag_name"]; 
         OGRe`Private`releaseNotes = OGRe`Private`latestRelease["body"]; 
         OGRe`Private`releaseURL = OGRe`Private`latestRelease["html_url"]; 
         OGRe`Private`newVersionQ = 
          OGRe`Private`NewVersionQ[OGRe`Private`newVersion]; 
         If[OGRe`Private`newVersionQ === $Failed, 
           OGRe`Private`OGRePrint[OGRe`Private`errorMessage]; Abort[]; Null]; 
         If[
           Not[OGRe`Private`newVersionQ], 
           OGRe`Private`OGRePrint[
           "You have the latest version of the package."], 
           OGRe`Private`releaseFileURL = 
            "https://raw.githubusercontent.com/bshoshany/OGRe/" <> 
             OGRe`Private`newVersion <> "/OGRe.m"; OGRe`Private`toPrint = {
              Row[{"A new version of the package is available: ", 
                Style[OGRe`Private`newVersion, Bold]}]}; 
           AppendTo[OGRe`Private`toPrint, 
             Row[{"\[Bullet] ", 
               Hyperlink[
               "View release notes on GitHub.", OGRe`Private`releaseURL]}]]; 
           AppendTo[OGRe`Private`toPrint, 
             Row[{"\[Bullet] ", 
               With[{OGRe`Private`notes = OGRe`Private`releaseNotes}, 
                OGRe`Private`CreateButton[
                "View release notes in this notebook.", 
                 OGRe`Private`ShowReleaseNotes[OGRe`Private`notes]]]}]]; 
           AppendTo[OGRe`Private`toPrint, 
             Row[{"\[Bullet] ", 
               With[{OGRe`Private`url = OGRe`Private`releaseFileURL}, 
                OGRe`Private`CreateButton[
                "Reload new version directly from GitHub without downloading \
it.", 
                 Get[OGRe`Private`url]]]}]]; Off[
             MessageName[NotebookDirectory, "nosv"]]; 
           If[NotebookDirectory[] =!= $Failed, AppendTo[OGRe`Private`toPrint, 
               Row[{"\[Bullet] ", 
                 
                 With[{OGRe`Private`url = OGRe`Private`releaseFileURL, 
                   OGRe`Private`path = FileNameJoin[{
                    NotebookDirectory[], "OGRe.m"}]}, 
                  OGRe`Private`CreateButton[
                  "Download new version to " <> OGRe`Private`path <> 
                   " and reload the package.", 
                   URLDownload[OGRe`Private`url, OGRe`Private`path]; 
                   OGRe`Private`OGRePrint["Downloaded! Reloading..."]; 
                   Get[OGRe`Private`path]]]}]]; Null]; On[
             MessageName[NotebookDirectory, "nosv"]]; 
           AppendTo[OGRe`Private`toPrint, 
             Row[{"\[Bullet] ", 
               
               With[{OGRe`Private`url = OGRe`Private`releaseFileURL, 
                 OGRe`Private`path = 
                 FileNameJoin[{$UserBaseDirectory, "Applications", 
                    "OGRe.m"}]}, 
                OGRe`Private`CreateButton[
                "Install new version to " <> OGRe`Private`path <> 
                 " and reload the package.", 
                 URLDownload[OGRe`Private`url, OGRe`Private`path]; 
                 OGRe`Private`OGRePrint["Installed! Reloading..."]; 
                 Get[OGRe`Private`path]]]}]]; OGRe`Private`OGRePrint[
             Column[OGRe`Private`toPrint]]; Null]; Null]}], "SubValues" -> 
    None, "DefaultValues" -> 
    Information`InformationValueForm[
     DefaultValues, OGRe`TCheckForUpdates, {
