Cell[CellGroupData[{

Cell["The Kretschmann scalar", "Subsection",ExpressionUUID->"c2c076da-6f65-254a-8ec0-33c32fd2021d"],

Cell[TextData[{
 "The ",
 StyleBox["Kretschmann scalar",
  FontWeight->Bold],
 " is the norm-squared of the Riemann tensor:"
}], "Text",ExpressionUUID->"e53558c9-cb26-9542-99de-04757cbe3b72"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    StyleBox["K", "TI"], "\[LongEqual]", 
    SubscriptBox[
     StyleBox["R", "TI"], "\[Rho]\[Sigma]\[Mu]\[Nu]"], 
    SuperscriptBox[
     StyleBox["R", "TI"], "\[Rho]\[Sigma]\[Mu]\[Nu]"]}], "."}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"f6f5f5e7-253f-4841-\
a4e6-58b0563e24cc"],

Cell[TextData[{
 "It can be easily calculated in OGRe for the Schwarzschild metric using ",
 StyleBox["TCalc", "Input"],
 " as follows:"
}], "Text",ExpressionUUID->"18569cb1-9651-ff43-80ba-34d000f5d807"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TShow", "@", 
  RowBox[{"TCalc", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"TRiemann", "[", "\"\<Schwarzschild\>\"", "]"}], 
      "[", "\"\<\[Rho]\[Sigma]\[Mu]\[Nu]\>\"", "]"}], ".", 
     RowBox[{
      RowBox[{"TRiemann", "[", "\"\<Schwarzschild\>\"", "]"}], 
      "[", "\"\<\[Rho]\[Sigma]\[Mu]\[Nu]\>\"", "]"}]}], ",", "\"\<K\>\""}], 
   "]"}]}]], "Input",
 CellLabel->
  "In[168]:=",ExpressionUUID->"33d33ef4-8f60-8242-9c40-db2795da1798"],

Cell[BoxData[
 StyleBox[
  TemplateBox[{"\"Result\"", "\":   \"", "\"K\"", "\"(\"", 
    TemplateBox[{",", "\",\"", "t", "r", "\[Theta]", "\[Phi]"}, 
     "RowWithSeparators"], "\")\"", "\" = \"", 
    FractionBox[
     RowBox[{"48", " ", 
       SuperscriptBox["M", "2"]}], 
     SuperscriptBox["r", "6"]]},
   "RowDefault"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"74865287-7b34-9043-85a0-5b64b7d67f30"]
}, Open  ]],

Cell[TextData[{
 "Even more easily, we can use the ",
 StyleBox["TNormSquared", "Input"],
 " module on the Riemann tensor (but the result will be the scalar itself, \
not a new tensor object):"
}], "Text",ExpressionUUID->"788a8efd-db46-ee48-b523-192cbf111b78"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TNormSquared", "[", 
  RowBox[{"TRiemann", "[", "\"\<Schwarzschild\>\"", "]"}], "]"}]], "Input",
 CellLabel->
  "In[169]:=",ExpressionUUID->"450712cf-5110-ee47-af78-002eb4657eb8"],

Cell[BoxData[
 FractionBox[
  RowBox[{"48", " ", 
   SuperscriptBox["M", "2"]}], 
  SuperscriptBox["r", "6"]]], "Output",
 CellLabel->
  "Out[169]=",ExpressionUUID->"f3373f3a-0832-b244-8ce2-487c35a0396d"]
}, Open  ]],

Cell[TextData[{
 "However, the easiest way to calculate it is using the built-in module ",
 StyleBox["TKretschmann", "Input"],
 ":"
}], "Text",ExpressionUUID->"0a899587-c314-584f-b986-1714a08d1d15"],

