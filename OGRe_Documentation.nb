         OGRe`Private`CheckIfOverwriting[OGRe`Private`newID]; 
         OGRe`Private`oldData = 
          OGRe`Private`GetTensorData[OGRe`Private`oldID]; 
         OGRe`Private`SetTensorID[OGRe`Private`newID, OGRe`Private`oldData]; 
         OGRe`Private`RemoveTensorID[OGRe`Private`oldID]; 
         If[OGRe`Private`oldData["Role"] === "Metric", 
           Scan[If[OGRe`Private`GetTensorData[#]["Metric"] === 
              OGRe`Private`oldID, 
              
              OGRe`Private`ChangeTensorKey[#, "Metric", 
               OGRe`Private`newID]]& , 
             OGRe`Private`AllTensorIDs[]]; Null]; 
         If[OGRe`Private`oldData["Role"] === "Coordinates", 
           Scan[OGRe`Private`ChangeCoordinateID[#, OGRe`Private`oldID, 
              OGRe`Private`newID]& , 
