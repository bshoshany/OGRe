In[68]:=",ExpressionUUID->"2bb357ac-d08f-3043-8cf6-2128095cb066"],

Cell[BoxData["\<\"4-Velocity\"\>"], "Output",
 CellLabel->"Out[68]=",ExpressionUUID->"670d4731-61e2-9449-9c0f-fb6b0859d8f9"]
}, Open  ]],

Cell[TextData[{
 "Like any other message, the message warning us that we are overwriting a \
tensor can be turned off using ",
 StyleBox["Off", "Input"],
 ". In this case, the command to turn it off would be ",
 StyleBox["Off[TMessage::WarningOverwrite]", "Input"],
 "."
}], "Text",ExpressionUUID->"5205ef84-073a-4948-9da1-b80415023269"],

Cell[TextData[{
 "Note that the state of ",
 StyleBox["TSetAllowOverwrite", "Input"],
 " is persistent between sessions - if you turn overwriting on, then it will \
remain on permanently, even in other Mathematica sessions, until you turn it \
back off. For this reason, the documentation notebook will now restore the \
previous setting, to avoid messing up the preferences of users who evaluate \
it:"
}], "Text",ExpressionUUID->"8a5e6605-c5ff-be44-bab6-fbb607cef1e7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Off", "[", 
   StyleBox[
    RowBox[{"TSetAllowOverwrite", "::", "Notify"}], "MessageName"], "]"}], ";", 
  RowBox[{"TSetAllowOverwrite", "[", "currentOverwrite", "]"}], ";", 
  RowBox[{"On", "[", 
   StyleBox[
    RowBox[{"TSetAllowOverwrite", "::", "Notify"}], "MessageName"], 
   "]"}]}]], "Input",
 CellLabel->"In[69]:=",ExpressionUUID->"e24ce57a-8f6d-dd4d-8aba-a3c584cbc542"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Raising and lowering indices", "Subsection",ExpressionUUID->"f6985e18-48fb-ea45-9163-ff27403897d4"],

Cell[TextData[{
 "Raising and lowering indices is one of the most basic tensor operations. \
For example, if we have a vector represented with one upper index, ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["v", "TI"], "\[Nu]"], TraditionalForm]],ExpressionUUID->
  "fc8cb4d2-330d-c547-879e-a806a9c5a0b5"],
 ", we can turn it into a covector, which is represented with one lower \
index, by ",
 StyleBox["contracting",
  FontWeight->Bold],
 " it with the metric:"
}], "Text",ExpressionUUID->"e4d93599-74ce-084e-91db-5d4d8b442a37"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["v", "TI"], "\[Mu]"], "\[LongEqual]", 
    SubscriptBox[
     StyleBox["g", "TI"], "\[Mu]\[Nu]"], 
    SuperscriptBox[
     StyleBox["v", "TI"], "\[Nu]"]}], "."}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"d7c4bf9d-8ddf-0e44-\
98ec-fdb31987681f"],

Cell[TextData[{
 "This is called \"lowering an index\". Here and in the rest of this \
documentation, we will be using the ",
 StyleBox["Einstein summation convention",
  FontWeight->Bold],
 ", where the same index repeated ",
 StyleBox["exactly twice",
  FontWeight->Bold],
 ", once as an upper index and once as a lower index, implies summation over \
that index. In this case, the implied summation is over ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Nu]", "\[Element]", 
    RowBox[{"{", 
     RowBox[{"0", ",", "1", ",", "2", ",", "3"}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"aab6c039-7546-7e43-9fc8-a24e78a630c9"],
 ":"
}], "Text",ExpressionUUID->"a5cdc4a2-c8cd-234a-8b77-0ed2da1f5cc5"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["v", "TI"], "\[Mu]"], "\[LongEqual]", 
    SubsuperscriptBox["\[Sum]", 
     RowBox[{"\[Nu]", "\[LongEqual]", "0"}], "3"], 
    SubscriptBox[
     StyleBox["g", "TI"], "\[Mu]\[Nu]"], 
    SuperscriptBox[
     StyleBox["v", "TI"], "\[Nu]"], "\[LongEqual]", 
    SubscriptBox[
     StyleBox["g", "TI"], 
     RowBox[{"\[Mu]", "0"}]], 
    SuperscriptBox[
     StyleBox["v", "TI"], "0"], "+", 
    SubscriptBox[
     StyleBox["g", "TI"], 
     RowBox[{"\[Mu]", "1"}]], 
    SuperscriptBox[
     StyleBox["v", "TI"], "1"], "+", 
    SubscriptBox[
     StyleBox["g", "TI"], 
     RowBox[{"\[Mu]", "2"}]], 
    SuperscriptBox[
     StyleBox["v", "TI"], "2"], "+", 
    SubscriptBox[
     StyleBox["g", "TI"], 
     RowBox[{"\[Mu]", "3"}]], 
    SuperscriptBox[
     StyleBox["v", "TI"], "3"]}], "."}], TraditionalForm]], "DisplayFormula",E\
xpressionUUID->"9ff08daf-e8b3-c74d-bb92-1344aa615c99"],

Cell[TextData[{
 "Such a sum over an index is called a contraction, and it is a \
generalization of the inner product, as we will describe in more detail \
below. Conversely, if we have a covector ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    StyleBox["w", "TI"], "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "45d75c1f-d2d9-524a-b223-5cbe86818aee"],
 ", we can raise its index by contracting it with the inverse metric:"
}], "Text",ExpressionUUID->"2ce2c4ca-07ca-824f-b0be-9a060d66c69f"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SuperscriptBox[
     StyleBox["w", "TI"], "\[Mu]"], "\[LongEqual]", 
    SuperscriptBox[
     StyleBox["g", "TI"], "\[Mu]\[Nu]"], 
    SubscriptBox[
     StyleBox["w", "TI"], "\[Nu]"]}], "."}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"8e19d72a-eba7-e54d-\
a9fb-18eeb24073b1"],

Cell[TextData[{
 "This works the same for indices of higher-rank tensors. For example, if we \
have a tensor of rank 2 represented with two upper indices, ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["T", "TI"], "\[Mu]\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "86d3f464-e544-4148-a926-1c0d8219d1bc"],
 ", we can lower either one or both of its indices:"
}], "Text",ExpressionUUID->"eca46e9b-3e67-9942-af58-5d32f7376c2c"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubsuperscriptBox[
     StyleBox["T", "TI"], "\[Nu]", "\[Mu]"], "\[LongEqual]", 
    SubscriptBox[
     StyleBox["g", "TI"], "\[Nu]\[Lambda]"], 
    SuperscriptBox[
     StyleBox["T", "TI"], "\[Mu]\[Lambda]"], 
    RowBox[{",", "  "}], 
    SubscriptBox[
     StyleBox["T", "TI"], "\[Mu]\[Nu]"], "\[LongEqual]", 
    SubscriptBox[
     StyleBox["g", "TI"], "\[Mu]\[Rho]"], 
    SubscriptBox[
     StyleBox["g", "TI"], "\[Nu]\[Lambda]"], 
    SuperscriptBox[
     StyleBox["T", "TI"], "\[Rho]\[Lambda]"]}], "."}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"f4489781-88f9-5747-\
97e7-403bd26964bc"],

Cell[TextData[{
 "In OGRe, since tensor objects are ",
 StyleBox["abstract tensors",
  FontWeight->Bold],
 ", independent of any specific index configuration, ",
 StyleBox["there is no notion of raising or lowering the indices of a tensor \
object",
  FontWeight->Bold],
 ". Instead, one simply requests to ",
 StyleBox["display",
  FontWeight->Bold],
 " the components of the tensor with the desired index configuration, without \
modifying the object itself. This works with both the ",
 StyleBox["TShow", "Input"],
 " and ",
 StyleBox["TList", "Input"],
 " modules, by simply adding as a second argument the list of indices, as \
when we created a new tensor."
}], "Text",ExpressionUUID->"c7e47fe5-ae8d-0244-bbaf-829a34a76bd9"],

Cell[TextData[{
 "As an example, let us show the vector ",
 StyleBox["\"4-Velocity\"", "Input"],
 " with a lower index, that is, with index configuration ",
 StyleBox["{-1}", "Input"],
 ":"
}], "Text",ExpressionUUID->"764a0029-02ac-3147-af68-9d7ee03507b6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TShow", "[", 
  RowBox[{"\"\<4-Velocity\>\"", ",", 
   RowBox[{"{", 
    RowBox[{"-", "1"}], "}"}]}], "]"}]], "Input",
 CellLabel->"In[70]:=",ExpressionUUID->"eb5abb4e-1d55-f644-a8ef-4c80f6a978cc"],

Cell[BoxData[
 StyleBox[
  TemplateBox[{"\"4-Velocity\"", "\":   \"", 
    SubscriptBox["\"v\"", 
     TemplateBox[{"\"\[Mu]\""}, "RowDefault"]], "\"(\"", 
    TemplateBox[{",", "\",\"", "t", "x", "y", "z"}, "RowWithSeparators"], 
    "\")\"", "\" = \"", 
    TagBox[
     RowBox[{"(", "\[NoBreak]", 
       TagBox[
        GridBox[{{
           RowBox[{"-", 
             FractionBox["1", 
              SqrtBox[
               RowBox[{"1", "-", 
                 SuperscriptBox["v", "2"]}]]]}]}, {
           FractionBox["v", 
            SqrtBox[
             RowBox[{"1", "-", 
               SuperscriptBox["v", "2"]}]]]}, {"0"}, {"0"}}, RowSpacings -> 1,
          ColumnAlignments -> Center, ColumnAlignments -> Left], Column], 
       "\[NoBreak]", ")"}], 
     Function[BoxForm`e$, 
      MatrixForm[BoxForm`e$]]]},
   "RowDefault"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"d061b6eb-593e-1e4d-8e3d-b861a736ae1c"]
}, Open  ]],

Cell[TextData[{
 "OGRe automatically knows to use the Minkowski metric to lower the index, \
which means that a minus sign has been added to the first component, as \
expected. Similarly, let us lower just the ",
 StyleBox["second",
  FontWeight->Bold],
 " index on ",
 StyleBox["PerfectFluid", "Input"],
 ":"
}], "Text",ExpressionUUID->"a2a9dfc7-67ef-5a41-920a-1dade8624f9d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TList", "[", 
  RowBox[{"\"\<PerfectFluid\>\"", ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", 
     RowBox[{"-", "1"}]}], "}"}]}], "]"}]], "Input",
 CellLabel->"In[71]:=",ExpressionUUID->"a08e9c25-8630-124c-a930-45f82eb6aff8"],

Cell[BoxData[
 StyleBox[
  TagBox[GridBox[{
     {
      TemplateBox[{"\"PerfectFluid\"", "\":\""},
       "RowDefault"]},
     {
      TagBox[GridBox[{
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"T\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"], "t"}, "RowDefault"], 
              TemplateBox[{"t", 
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{"-", "\[Rho]"}]},
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"T\"", 
              TemplateBox[{
                TemplateBox[{7}, "Spacer1"], "x"}, "RowDefault"], 
              TemplateBox[{"x", 
                TemplateBox[{7}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
            TemplateBox[{"\"T\"", 
              TemplateBox[{
                TemplateBox[{7}, "Spacer1"], "y"}, "RowDefault"], 
              TemplateBox[{"y", 
                TemplateBox[{7}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
            TemplateBox[{"\"T\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[13, 2]}, "Spacer1"], "z"}, "RowDefault"], 
              TemplateBox[{"z", 
                TemplateBox[{
                  Rational[13, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", "p"}
        },
        AutoDelete->False,
        GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
        GridBoxItemSize->{
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
       "Grid"]}
    },
    DefaultBaseStyle->"Column",
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
   "Column"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"8dabce57-a5f6-344d-8e36-9a85de5003a9"]
}, Open  ]],

Cell["\<\
The components of the representation of the metric with two upper indices are \
the components of the inverse metric, since\
\>", "Text",ExpressionUUID->"b02b8ce3-1c8d-ee4a-9cc7-4dc6ffc8d954"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["g", "TI"], "\[Mu]\[Lambda]"], 
    SuperscriptBox[
     StyleBox["g", "TI"], "\[Lambda]\[Nu]"], "\[LongEqual]", 
    SubsuperscriptBox["\[Delta]", "\[Mu]", "\[Nu]"]}], "."}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"b49ee0b2-1e55-dd4d-\
bd84-a20992c28644"],

Cell["\<\
Therefore, a quick way to show the components of the inverse metric is:\
\>", "Text",ExpressionUUID->"241454a8-ddbd-ed42-bcf0-da1b510a16e5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TShow", "[", 
  RowBox[{"\"\<Schwarzschild\>\"", ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "1"}], "}"}]}], "]"}]], "Input",
 CellLabel->"In[72]:=",ExpressionUUID->"39790e7e-5871-624d-8594-28c5b4b68e21"],

Cell[BoxData[
 StyleBox[
  TemplateBox[{"\"Schwarzschild\"", "\":   \"", 
    TemplateBox[{"\"g\"", 
      TemplateBox[{"\"\[Mu]\"", "\"\[Nu]\""}, "RowDefault"]}, "Superscript", 
     SyntaxForm -> SuperscriptBox], "\"(\"", 
    TemplateBox[{",", "\",\"", "t", "r", "\[Theta]", "\[Phi]"}, 
     "RowWithSeparators"], "\")\"", "\" = \"", 
    TagBox[
     RowBox[{"(", "\[NoBreak]", 
       GridBox[{{
          FractionBox["r", 
           RowBox[{
             RowBox[{"2", " ", "M"}], "-", "r"}]], "0", "0", "0"}, {"0", 
          RowBox[{"1", "-", 
            FractionBox[
             RowBox[{"2", " ", "M"}], "r"]}], "0", "0"}, {"0", "0", 
          FractionBox["1", 
           SuperscriptBox["r", "2"]], "0"}, {"0", "0", "0", 
          FractionBox[
           SuperscriptBox[
            RowBox[{"Csc", "[", "\[Theta]", "]"}], "2"], 
           SuperscriptBox["r", "2"]]}}, RowSpacings -> 1, ColumnSpacings -> 1,
         RowAlignments -> Baseline, ColumnAlignments -> Center], "\[NoBreak]",
        ")"}], 
     Function[BoxForm`e$, 
      MatrixForm[BoxForm`e$]]]},
   "RowDefault"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"8eb690cf-8e04-8249-bbc8-ca86532c629e"]
}, Open  ]],

Cell["\<\
For the same reason, the metric with one upper and one lower index is just \
the identity matrix:\
\>", "Text",ExpressionUUID->"e9dd38a5-4b9c-e640-b69c-a0064dce64ed"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TList", "[", 
  RowBox[{"\"\<Schwarzschild\>\"", ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", 
     RowBox[{"-", "1"}]}], "}"}]}], "]"}]], "Input",
 CellLabel->"In[73]:=",ExpressionUUID->"0b50fa71-c5c5-eb40-a147-2482b39ab3ef"],

Cell[BoxData[
 StyleBox[
  TagBox[GridBox[{
     {
      TemplateBox[{"\"Schwarzschild\"", "\":\""},
       "RowDefault"]},
     {
      TagBox[GridBox[{
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"g\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"], "t"}, "RowDefault"], 
              TemplateBox[{"t", 
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
            TemplateBox[{"\"g\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"], "r"}, "RowDefault"], 
              TemplateBox[{"r", 
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
            TemplateBox[{"\"g\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[17, 2]}, "Spacer1"], "\[Theta]"}, "RowDefault"], 
              TemplateBox[{"\[Theta]", 
                TemplateBox[{
                  Rational[17, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
            TemplateBox[{"\"g\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[19, 2]}, "Spacer1"], "\[Phi]"}, "RowDefault"], 
              TemplateBox[{"\[Phi]", 
                TemplateBox[{
                  Rational[19, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", "1"}
        },
        AutoDelete->False,
        GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
        GridBoxItemSize->{
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
       "Grid"]}
    },
    DefaultBaseStyle->"Column",
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
   "Column"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"b9f39a28-303c-3140-a38b-94781b4da0d9"]
}, Open  ]],

Cell[TextData[{
 "As explained above, if the modules ",
 StyleBox["TShow", "Input"],
 " or ",
 StyleBox["TList", "Input"],
 " are called with only the tensor ID, the tensor is displayed in its ",
 StyleBox["default index configuration",
  FontWeight->Bold],
 ", which is the one first used to define the tensor. So the 4-velocity has \
one upper index by default, and the stress tensor has two upper indices by \
default, because that is how we initially defined them. However, the default \
indices can be changed using the module ",
 StyleBox["TChangeDefaultIndices", "Input"],
 ":"
}], "Text",ExpressionUUID->"41ca5bae-e0a4-fc47-8d09-7567eee5a826"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"?", "TChangeDefaultIndices"}]], "Input",
 CellLabel->"In[74]:=",ExpressionUUID->"f1d591b2-70ca-b144-9c9c-ba99dad97883"],

