               TemplateBox[{"t", "\[Phi]", "\[Phi]", "t"}, "RowDefault"]]}], 
            RowBox[{"-", 
              SubscriptBox["\"R\"", 
               TemplateBox[{"\[Phi]", "t", "t", "\[Phi]"}, "RowDefault"]]}]},
           "RowWithSeparators"], "\<\"=\"\>", 
          FractionBox[
           RowBox[{"M", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"-", "2"}], " ", "M"}], "+", "r"}], ")"}], " ", 
