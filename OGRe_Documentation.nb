Cell[TextData[{
 "By default, OGRe uses ",
 StyleBox["FullSimplify", "Input"],
 ". However, one possible use of ",
 StyleBox["TSetSimplifyFunc", "Input"],
 " is to replace it with ",
 StyleBox["Simplify", "Input"],
 ", which is a much faster simplification function that still does a good job \
in most cases. This might be necessary if simplification is taking too long \
or getting stuck."
}], "Text",ExpressionUUID->"97b8bdbc-baff-ff42-96f5-ccad51095cdb"],

Cell[TextData[{
 "You may also use your own custom-made simplification function, combining \
various Mathematica functions or your own code. In that case, your function \
should take two arguments: the expression to be simplified, and a list of \
assumptions. A simple example is using ",
 StyleBox["FullSimplify", "Input"],
 " with specific options. For example, we can use ",
 StyleBox["FullSimplify", "Input"],
 " with the option ",
 StyleBox["TimeConstraint->5", "Input"],
 " to limit the time spent on simplification to 5 seconds:"
}], "Text",ExpressionUUID->"22729d78-449d-db4b-91d3-62d2f4a2ef55"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TSetSimplifyFunc", "[", 
  RowBox[{
   RowBox[{"FullSimplify", "[", 
    RowBox[{"#1", ",", "#2", ",", 
     RowBox[{"TimeConstraint", "\[Rule]", "5"}]}], "]"}], "&"}], 
  "]"}]], "Input",
 CellLabel->"In[91]:=",ExpressionUUID->"675e42c3-240b-4d4f-bb1a-d2452abdc49d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"FullSimplify", "[", 
   RowBox[{"#1", ",", "#2", ",", 
    RowBox[{"TimeConstraint", "\[Rule]", "5"}]}], "]"}], "&"}]], "Output",
 CellLabel->"Out[91]=",ExpressionUUID->"0f4a1257-54b7-7c4f-b57b-ff32f2262352"]
}, Open  ]],

Cell[TextData[{
 "In extreme situations, you may even want to cancel simplification \
altogether, which can be achieved using ",
 StyleBox["TSetSimplifyFunc[None]", "Input"],
 ". To restore the simplification function to the default, ",
 StyleBox["FullSimplify", "Input"],
 ", you can use ",
 StyleBox["TSetSimplifyFunc[Automatic]", "Input"],
 ":"
}], "Text",ExpressionUUID->"6ba95cb6-d1bb-4a4d-b4f4-218a204ba54c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TSetSimplifyFunc", "[", "Automatic", "]"}]], "Input",
 CellLabel->"In[92]:=",ExpressionUUID->"1d30b63c-78e5-244e-bc6c-74365e5563cb"],

Cell[BoxData["FullSimplify"], "Output",
 CellLabel->"Out[92]=",ExpressionUUID->"2e5dc0bb-e723-9042-9d14-4f78308bb8cc"]
}, Open  ]],

Cell[TextData[{
 "Note that changing the simplification function will ",
 StyleBox["not",
  FontWeight->Bold],
 " automatically apply it to any existing tensors. The reason is that when \
OGRe calculates the components of a tensor in a particular representation, it \
calculates them ",
 StyleBox["once and for all",
  FontWeight->Bold],
 ", and then saves them in the object's data to be reused later. This is done \
to improve performance, so that the components don't have to be recalculated \
every time they are needed. However, we can force re-simplification of the \
stored components of a specific tensor using the module ",
 StyleBox["TSimplify", "Input"],
 ":"
}], "Text",ExpressionUUID->"87681a57-9609-f343-b7af-d2b9f1a96f51"],

