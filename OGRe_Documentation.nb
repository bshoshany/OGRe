\" based on the user-defined simplification assumptions. If \", \
Style[\"expression\", Bold], \" is a list, the components will be simplified \
in parallel.\"]]]]\)", "Documentation" -> None, "OwnValues" -> None, 
    "UpValues" -> None, "DownValues" -> 
    Information`InformationValueForm[
     DownValues, OGRe`TSimplify, {OGRe`TSimplify[
         Pattern[OGRe`Private`tensorID, 
          Blank[String]]] :> (
        OGRe`Private`CheckIfTensorExists[OGRe`Private`tensorID]; 
        OGRe`Private`ChangeTensorKey[OGRe`Private`tensorID, "Components", 
          Map[OGRe`Private`TensorSimplify, 
           OGRe`Private`GetTensorData[OGRe`Private`tensorID]["Components"]]]; 
        Return[OGRe`Private`tensorID]; Null), OGRe`TSimplify[
         Pattern[OGRe`Private`expression, 
          Blank[]]] :> OGRe`Private`TensorSimplify[OGRe`Private`expression]}],
     "SubValues" -> None, "DefaultValues" -> 
    Information`InformationValueForm[
     DefaultValues, OGRe`TSimplify, {
      SyntaxInformation[OGRe`TSimplify] -> {"ArgumentsPattern" -> {
           Blank[]}}}], "NValues" -> None, "FormatValues" -> None, "Options" -> 
    None, "Attributes" -> {Protected}, "FullName" -> "OGRe`TSimplify"|>, 
   False]]], "Output",
 CellLabel->"Out[93]=",ExpressionUUID->"e5dd2087-31b8-6d4d-a57c-cf3f13ae2f25"]
