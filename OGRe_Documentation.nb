Cell[TextData[{
 "The same applies to all other tensors derived from the metric using \
built-in modules. However, user-defined tensors created with ",
 StyleBox["TNewTensor", "Input"],
 " that are associated to the metric are not automatically deleted, since \
they do not depend on the metric itself."
}], "Text",ExpressionUUID->"96d248cb-474a-b543-b607-bcd6e48480f1"],

Cell[TextData[{
 "Finally, let us reset ",
 StyleBox["TSetAllowOverwrite", "Input"],
 " back to its previous setting:"
}], "Text",ExpressionUUID->"82c3a045-44cf-1846-abb6-801b3c01a35d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Off", "[", 
   StyleBox[
    RowBox[{"TSetAllowOverwrite", "::", "Notify"}], "MessageName"], "]"}], ";", 
  RowBox[{"TSetAllowOverwrite", "[", "currentOverwrite", "]"}], ";", 
  RowBox[{"On", "[", 
   StyleBox[
    RowBox[{"TSetAllowOverwrite", "::", "Notify"}], "MessageName"], 
   "]"}]}]], "Input",
 CellLabel->
  "In[198]:=",ExpressionUUID->"951a478b-63b2-2c40-8398-11ed8f810306"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Curves and geodesics", "Section",ExpressionUUID->"24ccd181-2d5c-7748-b690-5e13a3badeb1"],

Cell[CellGroupData[{

Cell["The curve Lagrangian", "Subsection",ExpressionUUID->"c9e3dce2-3fb0-314b-89b9-48b9c85cf870"],

Cell[TextData[{
 "Consider a ",
 StyleBox["curve",
  FontWeight->Bold],
 ", which is a function ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     StyleBox["x", "TI"], "\[Mu]"], "(", "\[Lambda]", ")"}], 
   TraditionalForm]],ExpressionUUID->"e33e686b-726e-104b-a7c0-76ac84bc7dea"],
 " on the manifold where ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "47b9df26-c547-054f-bfb7-8f1a317e4f8f"],
 " is called the ",
 StyleBox["curve parameter",
  FontWeight->Bold],
 ". The ",
 StyleBox["curve Lagrangian",
  FontWeight->Bold],
 " of a metric is defined as the norm-squared of the tangent to the curve:"
}], "Text",ExpressionUUID->"90933cd1-faa8-164f-a8ce-d8aca4ae0bd0"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    StyleBox["L", "TI"], "\[LongEqual]", 
    SubscriptBox[
     StyleBox["g", "TI"], "\[Mu]\[Nu]"], 
    SuperscriptBox[
     OverscriptBox[
      StyleBox["x", "TI"], "."], "\[Mu]"], 
    SuperscriptBox[
     OverscriptBox[
      StyleBox["x", "TI"], "."], "\[Nu]"]}], ","}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"c419e2bf-4a82-5a4a-\
93ed-332e6f6c063a"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    OverscriptBox[
     StyleBox["x", "TI"], "."], "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "ece75037-87fd-6c47-958b-3cf67137a21a"],
 " is the first derivative of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    StyleBox["x", "TI"], "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "5e8e88dd-c5ff-c24e-93d3-cc4c74831674"],
 " with respect to the curve parameter (in Newton dot notation). We can \
calculate it using the module ",
 StyleBox["TLagrangian", "Input"],
 ":"
}], "Text",ExpressionUUID->"64b16146-abda-6d42-ba60-be9a68271a38"],

