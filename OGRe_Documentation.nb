Cell[TextData[{
 "The ",
 StyleBox["gradient",
  FontWeight->Bold],
 " of a tensor is the partial derivative ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[PartialD]", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "19763ae5-83dc-2544-9db7-6dc81c11519a"],
 " acting on the tensor with a free index, e.g. ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[PartialD]", "\[Mu]"], "\[Phi]"}], TraditionalForm]],
  ExpressionUUID->"1f84ac8f-5a17-f54b-9e60-a9f868e112fa"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[PartialD]", "\[Mu]"], 
    SuperscriptBox[
     StyleBox["v", "TI"], "\[Nu]"]}], TraditionalForm]],ExpressionUUID->
  "e62cdeef-411f-9347-8df8-5ad9265f98c0"],
 ", or ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[PartialD]", "\[Mu]"], 
    SuperscriptBox[
     StyleBox["T", "TI"], "\[Nu]\[Lambda]"]}], TraditionalForm]],
  ExpressionUUID->"62afd78e-87c3-3a42-92c3-3185d8ba8674"],
 ", resulting in a tensor of ",
 StyleBox["one rank higher",
  FontWeight->Bold],
 ". For example, we can calculate the gradient ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[PartialD]", "\[Mu]"], 
    StyleBox["K", "TI"]}], TraditionalForm]],ExpressionUUID->
  "f60c2fe9-33cf-374a-8902-4d1ad1a6a6ae"],
 " of the Kretschmann scalar as follows:"
}], "Text",ExpressionUUID->"9389af0d-0f5d-b548-8488-fdf6b7030303"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TShow", "@", 
  RowBox[{"TCalc", "[", 
   RowBox[{
    RowBox[{"TPartialD", "[", "\"\<\[Mu]\>\"", "]"}], ".", 
    RowBox[{"\"\<Kretschmann\>\"", "[", "\"\<\>\"", "]"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[138]:=",ExpressionUUID->"1557d252-7366-0946-8a4b-3212be9b2193"],

Cell[BoxData[
 StyleBox[
  TemplateBox[{"\"Result\"", "\":   \"", 
    SubscriptBox["\"\[DottedSquare]\"", 
     TemplateBox[{"\"\[Mu]\""}, "RowDefault"]], "\"(\"", 
    TemplateBox[{",", "\",\"", "t", "r", "\[Theta]", "\[Phi]"}, 
     "RowWithSeparators"], "\")\"", "\" = \"", 
    TagBox[
     RowBox[{"(", "\[NoBreak]", 
       TagBox[
        GridBox[{{"0"}, {
           RowBox[{"-", 
             FractionBox[
              RowBox[{"288", " ", 
                SuperscriptBox["M", "2"]}], 
              SuperscriptBox["r", "7"]]}]}, {"0"}, {"0"}}, RowSpacings -> 1, 
         ColumnAlignments -> Center, ColumnAlignments -> Left], Column], 
       "\[NoBreak]", ")"}], 
     Function[BoxForm`e$, 
      MatrixForm[BoxForm`e$]]]},
   "RowDefault"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"81d97de5-3ee1-be4b-83d7-b4c912b6f306"]
}, Open  ]],

Cell[TextData[{
 "The ",
 StyleBox["divergence",
  FontWeight->Bold],
 " of a tensor is the contraction of the partial derivative ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[PartialD]", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "2b1dbb45-8d1a-8746-a2bc-5746fd3d63a3"],
 " with one of the tensor's indices, e.g. ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[PartialD]", "\[Mu]"], 
    SuperscriptBox[
     StyleBox["v", "TI"], "\[Mu]"]}], TraditionalForm]],ExpressionUUID->
  "ec812ba1-e13f-aa4f-b72c-301f3d1ce069"],
 " or ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[PartialD]", "\[Mu]"], 
    SuperscriptBox[
     StyleBox["T", "TI"], "\[Mu]\[Nu]"]}], TraditionalForm]],ExpressionUUID->
  "e5ac0875-aefe-b644-a312-661bf5d2bc00"],
 ", resulting in a tensor of ",
 StyleBox["one rank lower",
  FontWeight->Bold],
 ". For example, here is the divergence ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[PartialD]", "\[Mu]"], 
    SuperscriptBox[
     StyleBox["x", "TI"], "\[Mu]"]}], TraditionalForm]],ExpressionUUID->
  "7e16d0d0-f075-bc48-af40-0e39b581fb62"],
 " of the Cartesian position vector:"
}], "Text",ExpressionUUID->"c694bccb-3cbb-1d44-9aac-af948de44c60"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TShow", "@", 
  RowBox[{"TNewTensor", "[", 
   RowBox[{"\"\<Position\>\"", ",", "\"\<Minkowski\>\"", 
    ",", "\"\<Cartesian\>\"", ",", 
    RowBox[{"{", "1", "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "x", ",", "y", ",", "z"}], "}"}], ",", "\"\<x\>\""}], 
   "]"}]}]], "Input",
 CellLabel->
  "In[139]:=",ExpressionUUID->"7e824dee-293f-7e4a-a9a8-877fe3fd07cc"],

Cell[BoxData[
 StyleBox[
  TemplateBox[{"\"Position\"", "\":   \"", 
    TemplateBox[{"\"x\"", 
      TemplateBox[{"\"\[Mu]\""}, "RowDefault"]}, "Superscript", SyntaxForm -> 
     SuperscriptBox], "\"(\"", 
    TemplateBox[{",", "\",\"", "t", "x", "y", "z"}, "RowWithSeparators"], 
    "\")\"", "\" = \"", 
    TagBox[
     RowBox[{"(", "\[NoBreak]", 
       TagBox[
        GridBox[{{"t"}, {"x"}, {"y"}, {"z"}}, RowSpacings -> 1, 
         ColumnAlignments -> Center, ColumnAlignments -> Left], Column], 
       "\[NoBreak]", ")"}], 
     Function[BoxForm`e$, 
      MatrixForm[BoxForm`e$]]]},
   "RowDefault"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"00e87851-1594-c648-b750-50691379486d"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TShow", "@", 
  RowBox[{"TCalc", "[", 
   RowBox[{
    RowBox[{"TPartialD", "[", "\"\<\[Mu]\>\"", "]"}], ".", 
    RowBox[{"\"\<Position\>\"", "[", "\"\<\[Mu]\>\"", "]"}]}], 
   "]"}]}]], "Input",
 CellLabel->
  "In[140]:=",ExpressionUUID->"7302ce40-c911-874a-98d1-d5cfd8e2b5ba"],

Cell[BoxData[
 StyleBox[
  TemplateBox[{"\"Result\"", "\":   \"", "\"\[DottedSquare]\"", "\"(\"", 
    TemplateBox[{",", "\",\"", "t", "x", "y", "z"}, "RowWithSeparators"], 
    "\")\"", "\" = \"", "4"},
   "RowDefault"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"9658d773-db0f-a543-9ea0-b1c8e2d31bac"]
}, Open  ]],

Cell[TextData[{
 "As you can see, the syntax for both the gradient and divergence is the \
same; if the index specification of ",
 StyleBox["TPartialD[\"\[Mu]\"]", "Input"],
 " matches one of the indices of the tensor to its right, then the divergence \
will be calculated, otherwise the gradient will be calculated."
}], "Text",ExpressionUUID->"8407dd32-c341-b546-af7a-405748fa7185"],

Cell[TextData[{
 StyleBox["WARNING: When applying partial derivatives to tensors, the result \
generally does not transform like a tensor under a coordinate transformation.",
  FontWeight->Bold],
 " For this reason, in general relativity we normally use the ",
 StyleBox["covariant derivative",
  FontWeight->Bold],
 " (see below) instead of a partial derivative. However, there are three \
important exceptions, where partial derivatives must be used: in the \
covariant derivative itself, the ",
 StyleBox["Levi-Civita connection",
  FontWeight->Bold],
 ", and the ",
 StyleBox["Riemann tensor",
  FontWeight->Bold],
 ", all of which will be discussed below."
}], "Text",ExpressionUUID->"337646ab-db7e-ef40-a3f6-42a94f43ce19"],

Cell[TextData[{
 "Of these three special cases, the covariant derivative and the Riemann \
tensor turn out to nonetheless transform like tensors under coordinate \
transformations, due to cancellations. However, the Levi-Civita connection, \
whose components are called the ",
 StyleBox["Christoffel symbols",
  FontWeight->Bold],
 ", does not transform like a tensor; it has a special transformation rule \
with an extra term, as we will see below."
}], "Text",ExpressionUUID->"3346e91f-b138-9046-ad38-a430c445a494"],

Cell[TextData[{
 "In all other cases, if the user creates an arbitrary tensor using partial \
derivatives, the result will generally ",
 StyleBox["transform incorrectly",
  FontWeight->Bold],
 " under a coordinate transformation in OGRe. Therefore, it is highly \
recommended to avoid using partial derivatives with ",
 StyleBox["TCalc", "Input"],
 " unless you really know what you're doing."
}], "Text",ExpressionUUID->"094b9b36-a2f7-8e4d-b5c3-c18c9606c39f"],

Cell[CellGroupData[{

Cell["The Christoffel symbols", "Subsection",ExpressionUUID->"5e099ec8-446f-704e-a6bb-eda6fb9254d6"],

Cell[TextData[{
 "The ",
 StyleBox["Christoffel symbols",
  FontWeight->Bold],
 " are a very important tensor-like object in differential geometry. They are \
the components of the ",
 StyleBox["Levi-Civita connection,",
  FontWeight->Bold],
 " which is the unique torsion-free connection that preserves the metric. The \
Christoffel symbols are defined as follows:"
}], "Text",ExpressionUUID->"bd8508df-f5e1-df4f-8457-042652bf846f"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubsuperscriptBox["\[CapitalGamma]", "\[Mu]\[Nu]", "\[Lambda]"], "\[LongEqual]", 
    FractionBox["1", "2"], 
    SuperscriptBox[
     StyleBox["g", "TI"], "\[Lambda]\[Sigma]"], 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[PartialD]", "\[Mu]"], 
      SubscriptBox[
       StyleBox["g", "TI"], "\[Nu]\[Sigma]"], "+", 
      SubscriptBox["\[PartialD]", "\[Nu]"], 
      SubscriptBox[
       StyleBox["g", "TI"], "\[Sigma]\[Mu]"], "-", 
      SubscriptBox["\[PartialD]", "\[Sigma]"], 
      SubscriptBox[
       StyleBox["g", "TI"], "\[Mu]\[Nu]"]}], ")"}]}], "."}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"01f139be-1a24-0d4a-\
84cd-183fc8f52072"],

Cell[TextData[{
 "Each of the terms inside the parentheses is a gradient of the metric, with \
different indices. For example, the first term ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[PartialD]", "\[Mu]"], 
    SubscriptBox[
     StyleBox["g", "TI"], "\[Nu]\[Sigma]"]}], TraditionalForm]],
  ExpressionUUID->"eb9ce2f3-42b0-2944-8717-706fae19f475"],
 " is represented in OGRe as ",
 StyleBox["TPartialD[\"\[Mu]\"].\"Metric\"[\"\[Nu]\[Sigma]\"]", "Input"],
 " where ",
 StyleBox["\"Metric\"", "Input"],
 " is the tensor object representing the metric. Since contraction, addition, \
and multiplication by a scalar can be combined arbitrarily when using ",
 StyleBox["TCalc", "Input"],
 ", we can calculate the Christoffel symbols in a straightforward way as \
follows:"
}], "Text",ExpressionUUID->"a32d76b3-a950-1c46-b21c-a9aac125c971"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TList", "@", 
  RowBox[{"TChangeDefaultIndices", "[", 
   RowBox[{
    RowBox[{"TCalc", "[", 
     RowBox[{
      RowBox[{
       FractionBox["1", "2"], " ", 
       RowBox[{
        RowBox[{"\"\<Schwarzschild\>\"", "[", "\"\<\[Lambda]\[Sigma]\>\"", 
         "]"}], ".", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"TPartialD", "[", "\"\<\[Mu]\>\"", "]"}], ".", 
           
           RowBox[{"\"\<Schwarzschild\>\"", "[", "\"\<\[Nu]\[Sigma]\>\"", 
            "]"}]}], "+", 
          RowBox[{
           RowBox[{"TPartialD", "[", "\"\<\[Nu]\>\"", "]"}], ".", 
           
           RowBox[{"\"\<Schwarzschild\>\"", "[", "\"\<\[Sigma]\[Mu]\>\"", 
            "]"}]}], "-", 
          RowBox[{
           RowBox[{"TPartialD", "[", "\"\<\[Sigma]\>\"", "]"}], ".", 
           
           RowBox[{"\"\<Schwarzschild\>\"", "[", "\"\<\[Mu]\[Nu]\>\"", 
            "]"}]}]}], ")"}]}]}], ",", "\"\<\[CapitalGamma]\>\""}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"1", ",", 
      RowBox[{"-", "1"}], ",", 
      RowBox[{"-", "1"}]}], "}"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[141]:=",ExpressionUUID->"a6e4fe51-a2d8-c542-a354-e920a1e01c98"],

Cell[BoxData[
 StyleBox[
  TagBox[GridBox[{
