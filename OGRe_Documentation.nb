}], "Text",ExpressionUUID->"50f7f78f-0643-4e44-ab3c-7169eeb74aae"],

Cell["We can access the tensor using the new ID:", "Text",ExpressionUUID->"c5b4be70-b860-a74b-97fc-e0af9e4b514d"],

