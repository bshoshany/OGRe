Cell[TextData[{
 "Coordinates are also tensor objects, so we can use ",
 StyleBox["TShow", "Input"],
 " to show the two coordinate tensors we defined above:"
}], "Text",ExpressionUUID->"6853fd26-6790-6046-9a23-bcb95a689126"],

Cell[CellGroupData[{

Cell[BoxData[
