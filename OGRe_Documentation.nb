Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"x", "\[Rule]", 
     RowBox[{"Function", "[", 
      RowBox[{
       RowBox[{"{", "t", "}"}], ",", 
       RowBox[{
        TemplateBox[{"2"},
         "C"], "+", 
        TemplateBox[{
          RowBox[{"-", 
            FractionBox["1", 
             SqrtBox[
              RowBox[{
                SuperscriptBox[
                 RowBox[{"a", "[", 
                   RowBox[{"K", "[", "1", "]"}], "]"}], "2"], "+", 
                RowBox[{
                  SuperscriptBox[
                   RowBox[{"a", "[", 
                    RowBox[{"K", "[", "1", "]"}], "]"}], "4"], " ", 
                  TemplateBox[{"1"}, "C"]}]}]]]}], 
          RowBox[{"K", "[", "1", "]"}], "1", "t"},
         "InactiveIntegrate",
         DisplayFunction->(RowBox[{
            SubsuperscriptBox[
             StyleBox["\[Integral]", "Inactive"], #3, #4], 
            RowBox[{#, 
              RowBox[{
                StyleBox["\[DifferentialD]", "Inactive"], #2}]}]}]& ),
         InterpretationFunction->(RowBox[{
            RowBox[{"Inactive", "[", "Integrate", "]"}], "[", 
            RowBox[{#, ",", 
              RowBox[{"{", 
                RowBox[{#2, ",", #3, ",", #4}], "}"}]}], "]"}]& )]}]}], 
      "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", "\[Rule]", 
     RowBox[{"Function", "[", 
      RowBox[{
       RowBox[{"{", "t", "}"}], ",", 
       RowBox[{
        TemplateBox[{"2"},
         "C"], "+", 
        TemplateBox[{
          FractionBox["1", 
           SqrtBox[
            RowBox[{
              SuperscriptBox[
               RowBox[{"a", "[", 
                 RowBox[{"K", "[", "2", "]"}], "]"}], "2"], "+", 
              RowBox[{
                SuperscriptBox[
                 RowBox[{"a", "[", 
                   RowBox[{"K", "[", "2", "]"}], "]"}], "4"], " ", 
                TemplateBox[{"1"}, "C"]}]}]]], 
          RowBox[{"K", "[", "2", "]"}], "1", "t"},
         "InactiveIntegrate",
         DisplayFunction->(RowBox[{
            SubsuperscriptBox[
             StyleBox["\[Integral]", "Inactive"], #3, #4], 
            RowBox[{#, 
              RowBox[{
                StyleBox["\[DifferentialD]", "Inactive"], #2}]}]}]& ),
         InterpretationFunction->(RowBox[{
            RowBox[{"Inactive", "[", "Integrate", "]"}], "[", 
            RowBox[{#, ",", 
              RowBox[{"{", 
                RowBox[{#2, ",", #3, ",", #4}], "}"}]}], "]"}]& )]}]}], 
      "]"}]}], "}"}]}], "}"}]], "Output",
 CellLabel->
