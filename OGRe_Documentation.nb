In[67]:=",ExpressionUUID->"3f27916d-6737-2147-b9e9-b7bdbb3700de"]
}, Open  ]],

Cell["\<\
We can now overwrite the tensor \"4-Velocity\" by creating a new tensor with \
the same ID:\
\>", "Text",ExpressionUUID->"898b5289-121f-bc47-b341-4bf065c97651"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TNewTensor", "[", 
  RowBox[{"\"\<4-Velocity\>\"", ",", "\"\<Minkowski\>\"", 
   ",", "\"\<Cartesian\>\"", ",", 
   RowBox[{"{", "1", "}"}], ",", 
   FractionBox[
    RowBox[{"{", 
     RowBox[{"1", ",", "v", ",", "0", ",", "0"}], "}"}], 
    SqrtBox[
     RowBox[{"1", "-", 
      SuperscriptBox["v", "2"]}]]], ",", "\"\<v\>\""}], "]"}]], "Input",
 CellLabel->"In[68]:=",ExpressionUUID->"bf53c1da-6ad6-4043-9590-3870a9dfeeb7"],

Cell[BoxData[
 TemplateBox[{
  "TMessage", "WarningOverwrite", 
   "\"Overwriting the tensor \
\\\"\\!\\(\\*RowBox[{\\\"\\\\\\\"4-Velocity\\\\\\\"\\\"}]\\)\\\".\"", 2, 68, 
   8, 30274037233204585468, "Local", "OGRe`TMessage"},
  "MessageTemplate2",
  BaseStyle->"MSG"]], "Message",
 CellLabel->
