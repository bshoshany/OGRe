Cell[TextData[{
 "The ",
 StyleBox["TRank", "Input"],
 " module can be used to get the rank of a tensor. The rank is the number of \
indices in the representations of the tensor. A rank-0 tensor is a scalar, a \
rank-1 tensor is a vector, a rank-2 tensor is a matrix, and so on."
}], "Text",ExpressionUUID->"c372b05b-19d2-2d44-83a5-081f22f10638"],

