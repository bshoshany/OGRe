Cell[BoxData[
 RowBox[{"TList", "[", 
  RowBox[{
   RowBox[{"TGeodesicWithTimeParameter", "[", "\"\<FLRW\>\"", "]"}], 
   ",", "\"\<Cartesian\>\""}], "]"}]], "Input",
 CellLabel->
  "In[225]:=",ExpressionUUID->"2dd0707c-dd5e-5940-b0ea-d875f0e92830"],

Cell[BoxData[
 StyleBox[
  TagBox[GridBox[{
     {
      TemplateBox[{"\"FLRW->GeodesicWithTimeParameter\"", "\":\""},
       "RowDefault"]},
     {
      TagBox[GridBox[{
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"0\"", 
              TemplateBox[{"x"}, "RowDefault"]}, "Superscript", SyntaxForm -> 
             SuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           OverscriptBox["x", "\[DoubleDot]"], "-", 
           FractionBox[
            RowBox[{
             OverscriptBox["x", "."], " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"-", "2"}], "+", 
               RowBox[{
                SuperscriptBox["a", "2"], " ", 
                RowBox[{"(", 
                 RowBox[{
                  SuperscriptBox[
                   OverscriptBox["x", "."], "2"], "+", 
                  SuperscriptBox[
                   OverscriptBox["y", "."], "2"], "+", 
                  SuperscriptBox[
                   OverscriptBox["z", "."], "2"]}], ")"}]}]}], ")"}], " ", 
             TemplateBox[{
               SubscriptBox["\"\[PartialD]\"", "t"], "a"},
              "RowDefault"]}], "a"]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"0\"", 
              TemplateBox[{"y"}, "RowDefault"]}, "Superscript", SyntaxForm -> 
             SuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           OverscriptBox["y", "\[DoubleDot]"], "-", 
           FractionBox[
            RowBox[{
             OverscriptBox["y", "."], " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"-", "2"}], "+", 
               RowBox[{
                SuperscriptBox["a", "2"], " ", 
                RowBox[{"(", 
                 RowBox[{
                  SuperscriptBox[
                   OverscriptBox["x", "."], "2"], "+", 
                  SuperscriptBox[
                   OverscriptBox["y", "."], "2"], "+", 
                  SuperscriptBox[
                   OverscriptBox["z", "."], "2"]}], ")"}]}]}], ")"}], " ", 
             TemplateBox[{
               SubscriptBox["\"\[PartialD]\"", "t"], "a"},
              "RowDefault"]}], "a"]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"0\"", 
              TemplateBox[{"z"}, "RowDefault"]}, "Superscript", SyntaxForm -> 
             SuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           OverscriptBox["z", "\[DoubleDot]"], "-", 
           FractionBox[
            RowBox[{
             OverscriptBox["z", "."], " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"-", "2"}], "+", 
