             "Subsuperscript", SyntaxForm -> SubsuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"Cos", "[", "\[Theta]", "]"}]}], " ", 
           RowBox[{"Sin", "[", "\[Theta]", "]"}]}]},
         {
          TemplateBox[{"=", "\"=\"", 
