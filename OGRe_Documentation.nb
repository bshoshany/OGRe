                TemplateBox[{
                  Rational[19, 2]}, "Spacer1"], "\[Phi]", "\[Theta]"}, 
               "RowDefault"], 
              TemplateBox[{"\[Phi]", 
                TemplateBox[{
                  Rational[19, 2]}, "Spacer1"], 
                TemplateBox[{
