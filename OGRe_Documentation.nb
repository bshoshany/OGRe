Cell[CellGroupData[{

Cell["Geodesic equations in terms of the time coordinate", "Subsection",ExpressionUUID->"5eeef425-9457-f746-b268-dc4c33345645"],

Cell["\<\
If the metric is a spacetime metric, it is often convenient to obtain the \
geodesic equations in terms of the time parameter, instead of an affine curve \
parameter. It can be shown that the geodesic equations in terms of the time \
coordinate are given by\
\>", "Text",ExpressionUUID->"4fccb075-5c3f-6049-b237-24cd53c0e081"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{
      SuperscriptBox[
       StyleBox["d",
        FontSlant->"Plain"], "2"], 
      SuperscriptBox[
       StyleBox["x", "TI"], "\[Sigma]"]}], 
     SuperscriptBox[
      RowBox[{
       StyleBox["d",
        FontSlant->"Plain"], 
       StyleBox["t", "TI"]}], "2"]], "+", 
    RowBox[{"(", 
     RowBox[{
      SubsuperscriptBox["\[CapitalGamma]", "\[Mu]\[Nu]", "\[Sigma]"], "-", 
      SubsuperscriptBox["\[CapitalGamma]", "\[Mu]\[Nu]", "0"], 
      FractionBox[
       SuperscriptBox[
        RowBox[{
         StyleBox["d",
          FontSlant->"Plain"], 
         StyleBox["x", "TI"]}], "\[Sigma]"], 
       RowBox[{
        StyleBox["d",
         FontSlant->"Plain"], 
        StyleBox["t", "TI"]}]]}], ")"}], 
    FractionBox[
     SuperscriptBox[
      RowBox[{
       StyleBox["d",
        FontSlant->"Plain"], 
       StyleBox["x", "TI"]}], "\[Mu]"], 
     RowBox[{
      StyleBox["d",
       FontSlant->"Plain"], 
      StyleBox["t", "TI"]}]], 
    FractionBox[
     SuperscriptBox[
      RowBox[{
       StyleBox["d",
        FontSlant->"Plain"], 
       StyleBox["x", "TI"]}], "\[Nu]"], 
     RowBox[{
      StyleBox["d",
       FontSlant->"Plain"], 
      StyleBox["t", "TI"]}]], "\[LongEqual]", "0"}], ","}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"45d706b6-f4a8-4a47-\
9944-eacbbf4f5bc6"],

Cell[TextData[{
 "where we are assuming the time coordinate is ",
 Cell[BoxData[
  FormBox[
   StyleBox["t", "TI"], TraditionalForm]],ExpressionUUID->
  "6703ac4c-f8ba-1d48-a7ea-2980502314c1"],
 " and it is the first (zero) coordinate. These equations can be obtained \
