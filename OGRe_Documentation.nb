       "Grid"]}, Dynamic[System`InformationDump`open$$],
      BaselinePosition->Baseline,
      FrameMargins->0,
      ImageSize->Automatic],
     DynamicModuleValues:>{}],
    BaseStyle->"InformationGridFrame",
    StripOnInput->False], "InformationGridPlain",
   StripOnInput->False],
  InformationData[<|
   "ObjectType" -> "Symbol", "Usage" -> 
    "\!\(\*InterpretationBox[Cell[TextData[{\"TSetParallelization[\", \
StyleBox[\"True\", Bold, Rule[StripOnInput, False]], \"] enables the \
parallelization of tensor simplifications, and TSetParallelization[\", \
StyleBox[\"False\", Bold, Rule[StripOnInput, False]], \"] disables it. The \
default value is \", StyleBox[\"False\", Bold, Rule[StripOnInput, False]], \
\". TSetParallelization[] returns the current value. If simplifications take \
less than a few seconds, then you should leave parallelization off, as it has \
a small overhead and may actually impede performance. However, if \
simplifications are taking more than a few seconds, then it is highly \
recommended to enable parallelization for a significant performance \
boost.\"}]], TextCell[Row[List[\"TSetParallelization[\", Style[\"True\", \
Bold], \"] enables the parallelization of tensor simplifications, and \
TSetParallelization[\", Style[\"False\", Bold], \"] disables it. The default \
value is \", Style[\"False\", Bold], \". TSetParallelization[] returns the \
current value. If simplifications take less than a few seconds, then you \
should leave parallelization off, as it has a small overhead and may actually \
impede performance. However, if simplifications are taking more than a few \
seconds, then it is highly recommended to enable parallelization for a \
significant performance boost.\"]]]]\)", "Documentation" -> None, "OwnValues" -> 
    None, "UpValues" -> None, "DownValues" -> 
    Information`InformationValueForm[
     DownValues, OGRe`TSetParallelization, {
      OGRe`TSetParallelization[] :> 
       OGRe`Private`TensorData[Options]["Parallelize"], 
       OGRe`TSetParallelization[
         PatternTest[
          Pattern[OGRe`Private`par, 
           Blank[]], BooleanQ]] :> (Unprotect[OGRe`Private`TensorData]; 
        OGRe`Private`TensorData[Options]["Parallelize"] = OGRe`Private`par; 
        Protect[OGRe`Private`TensorData]; 
        If[OGRe`Private`par, 
          OGRe`Private`OGRePrint["Parallelization enabled."]; 
          If[$KernelCount < $MaxLicenseSubprocesses, 
            LaunchKernels[$MaxLicenseSubprocesses - $KernelCount]; 
            OGRe`Private`OGRePrint[$KernelCount, 
              " parallel kernels launched. CPU has ", $ProcessorCount, 
              " cores."]; Null], 
          OGRe`Private`OGRePrint["Parallelization disabled."]; 
          OGRe`Private`OGRePrint["Closing ", $KernelCount, " kernels."]; 
          CloseKernels[]; Null]; Null)}], "SubValues" -> None, 
    "DefaultValues" -> 
    Information`InformationValueForm[
     DefaultValues, OGRe`TSetParallelization, {
      SyntaxInformation[OGRe`TSetParallelization] -> {"ArgumentsPattern" -> {
           Optional[
            Blank[]]}}}], "NValues" -> None, "FormatValues" -> None, 
    "Options" -> None, "Attributes" -> {Protected}, "FullName" -> 
    "OGRe`TSetParallelization"|>, False]]], "Output",
 CellLabel->
  "Out[242]=",ExpressionUUID->"5878b178-1d88-404a-a90c-e2eb4484da7d"]
}, Open  ]],

Cell["Let us turn it on now:", "Text",ExpressionUUID->"bf6ee500-c07f-0141-940a-82571a89f7c1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TSetParallelization", "[", "True", "]"}]], "Input",
 CellLabel->
  "In[243]:=",ExpressionUUID->"b2462832-d8e2-084a-afbe-fcdd06c39ba3"],

Cell[BoxData["\<\"Parallelization enabled.\"\>"], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"5c3c7e48-b76b-5349-a8e4-f3c2fd0bc2bb"],

Cell[BoxData[
 TemplateBox[{
  "16", "\" parallel kernels launched. CPU has \"", "24", "\" cores.\""},
  "RowDefault"]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"d84f070e-183d-db40-a428-deea75e38237"]
}, Open  ]],

Cell["\<\
When parallelization is first turned on, all available parallel kernels are \
automatically launched. As you can see, my system has a 24-core CPU, but only \
16 parallel kernels can be launched, since that is what my Mathematica \
license allows.\
\>", "Text",ExpressionUUID->"72c821df-1328-0243-9bbc-f516b0a2d36d"],

Cell[TextData[{
 "We will now repeat the calculation of the Christoffel symbols, in order to \
see how its performance improves with parallelization. However, before we can \
do that, we must again use the command ",
 StyleBox["ClearSystemCache", "Input"],
 " to clear Mathematica's cache:"
}], "Text",ExpressionUUID->"5ac0050f-ddec-af4a-9e7f-a318ef7a885c"],

Cell[BoxData[
 RowBox[{"ClearSystemCache", "[", "]"}]], "Input",
 CellLabel->
  "In[244]:=",ExpressionUUID->"2e6ed4b3-3728-924d-8676-9028df3d7c1c"],

Cell[TextData[{
 "(If you don't trust that ",
 StyleBox["ClearSystemCache", "Input"],
 " is enough to make a reliable benchmark, you can exit the kernel using ",
 StyleBox["Quit", "Input"],
 ", and then reload the package and redefine the Cartesian coordinates and \
the test metric.)"
}], "Text",ExpressionUUID->"23b82a78-33d6-2349-a9e8-38795a1fda39"],

Cell["\<\
We will also delete the tensor that we calculated previously, so that we can \
calculate it again (if overwriting is not turned on):\
\>", "Text",ExpressionUUID->"e315df22-7cd5-4e42-b19a-0f9d2c10cd75"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TDelete", "[", 
   RowBox[{"TChristoffel", "[", "\"\<ParallelizationTest\>\"", "]"}], "]"}], 
  ";"}]], "Input",
 CellLabel->
  "In[245]:=",ExpressionUUID->"5a0b6053-13f3-f949-bb8d-89a13d5f94bd"],

Cell[TextData[{
 "Now we can accurately measure the execution time for ",
 StyleBox["TChristoffel", "Input"],
 " with parallelization:"
}], "Text",ExpressionUUID->"c5ca04bd-a6b8-5248-8fef-388fe11303b7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"parallelChristoffel", "=", 
  RowBox[{
   RowBox[{"AbsoluteTiming", "[", 
    RowBox[{"TChristoffel", "[", "\"\<ParallelizationTest\>\"", "]"}], "]"}], 
   "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]}]], "Input",
 CellLabel->
  "In[246]:=",ExpressionUUID->"e1b01493-3ea6-db49-9e56-20e781c43d0c"],

Cell[BoxData["1.5662258`"], "Output",
 CellLabel->
  "Out[246]=",ExpressionUUID->"447e15d0-176b-6a41-a618-6e4232575a82"]
}, Open  ]],

Cell["\<\
We see that the calculation now took less time, with an improvement by a \
factor of:\
\>", "Text",ExpressionUUID->"2b709066-da98-254b-b417-670fb2239465"],

Cell[CellGroupData[{

Cell[BoxData[
 FractionBox["notParallelChristoffel", "parallelChristoffel"]], "Input",
 CellLabel->
  "In[247]:=",ExpressionUUID->"2021ca3f-ac67-5546-abb6-1c9c0e9a6644"],

Cell[BoxData["3.6461749001963826`"], "Output",
 CellLabel->
  "Out[247]=",ExpressionUUID->"46a5cd5b-766c-b848-b1b9-101fe2e363b8"]
}, Open  ]],

Cell["\<\
With longer calculations, the improvement will be even more significant; I \
intentionally chose an example that doesn't take too long to calculate, \
because I evaluate this notebook on a regular basis as part of the package's \
development. Increasing the number of kernels (if it was allowed by my \
license) would provide an additional speedup.\
\>", "Text",ExpressionUUID->"c5e54f83-7474-f74c-98a9-23cfac467e50"],

Cell["\<\
As a rule of thumb, if simplifications are taking less than a few seconds, \
then you should leave parallelization off, as it has a small overhead and may \
actually impede performance in that case. However, if simplifications are \
taking more than a few seconds, then it is highly recommended to enable \
parallelization for a significant performance boost.\
\>", "Text",ExpressionUUID->"28a83920-3e76-ac4c-a7c4-022d07a9c6f5"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Making use of OGRe's parallelized simplifications for other Mathematica \
expressions\
\>", "Subsection",ExpressionUUID->"b99458c9-5ce8-1c43-b444-a5cc98b916a8"],

Cell[TextData[{
 "When ",
 StyleBox["TSimplify", "Input"],
 " is applied to any expression which is not a tensor object, the object is \
simplified based on the user-defined simplification assumptions set using ",
 StyleBox["TSetAssumptions", "Input"],
 ":"
}], "Text",ExpressionUUID->"9175dda1-e61e-b440-afc9-4d50f7299b5d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TSetAssumptions", "[", "]"}]], "Input",
 CellLabel->
  "In[248]:=",ExpressionUUID->"5ac0812a-f9be-b14f-b803-124e0ce0ab6b"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"AssumeReal\"\>", "\[Rule]", "True"}], ",", 
   RowBox[{"\<\"User\"\>", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"r", "\[GreaterEqual]", "0"}], "}"}]}]}], 
  "\[RightAssociation]"}]], "Output",
 CellLabel->
  "Out[248]=",ExpressionUUID->"f4338ea4-647e-5f4d-9d19-160242d363dc"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TSimplify", "[", 
  SqrtBox[
   SuperscriptBox["r", "2"]], "]"}]], "Input",
 CellLabel->
  "In[249]:=",ExpressionUUID->"7f57dc96-95f0-9c4d-a96c-8015084c323f"],

Cell[BoxData["r"], "Output",
 CellLabel->
  "Out[249]=",ExpressionUUID->"d78cf921-8100-7044-93a2-47639bcf4db0"]
}, Open  ]],

Cell[TextData[{
 "If the expression is a ",
 StyleBox["List", "Input"],
 ", the components will be simplified in parallel. The user can thus make use \
of OGRe's optimized simplification process to simplify any Mathematica \
expression."
}], "Text",ExpressionUUID->"6de90565-e691-e24b-8dbb-000b02e0a0bd"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["About the project", "Section",ExpressionUUID->"a2e1458f-7857-994a-ba8a-5ad9dbb2408e"],

Cell[CellGroupData[{

Cell["Bug reports and feature requests", "Subsection",ExpressionUUID->"f329a189-0763-bd4d-a6bb-85a3cf6fa6fe"],

Cell[TextData[{
 "This package is under continuous and active development. If you encounter \
any bugs, or if you would like to request any additional features, please \
feel free to ",
 ButtonBox["open a new issue on GitHub",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://github.com/bshoshany/OGRe/issues"], None},
  ButtonNote->"https://github.com/bshoshany/OGRe/issues"],
 " and I will look into it as soon as I can."
}], "Text",ExpressionUUID->"379676ab-aa4c-9949-9830-1c0ff5e39e2d"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Contribution and pull request policy", "Subsection",ExpressionUUID->"d2104e57-32df-c147-80ee-9f02d517cfc2"],

Cell[TextData[{
 "Contributions are always welcome. However, I release my projects in \
cumulative updates after editing and testing them locally on my system, so ",
 StyleBox["my policy is to never accept any pull requests",
  FontWeight->Bold],
 ". If you open a pull request, and I decide to incorporate your suggestion \
into the project, I will first modify your code to comply with the project's \
coding conventions (formatting, syntax, naming, comments, programming \
practices, etc.), and perform some tests to ensure that the change doesn't \
break anything. I will then merge it into the next release of the project, \
possibly together with some other changes. The new release will also include \
a note in ",
 StyleBox["CHANGELOG.md", "Input"],
 " with a link to your pull request, and modifications to the documentation \
in ",
 StyleBox["README.md", "Input"],
 " as needed."
}], "Text",ExpressionUUID->"2e0d0348-eb9f-824f-99ab-5e537318ebaa"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Starring the repository", "Subsection",ExpressionUUID->"e62f5e98-a0b4-a340-9fdf-261df85050a9"],

Cell[TextData[{
 "If you found this project useful, please consider ",
 ButtonBox["starring it on GitHub",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://github.com/bshoshany/OGRe/stargazers"], None},
  ButtonNote->"https://github.com/bshoshany/OGRe/stargazers"],
 "! This allows me to see how many people are using my code, and motivates me \
to keep working to improve it."
}], "Text",ExpressionUUID->"bc537bd4-bb0e-e946-8693-2fe37faa14db"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Acknowledgements", "Subsection",ExpressionUUID->"b42cc492-1921-8243-8ed3-4c55c85c8f0e"],

Cell["\<\
A major portion of the code for this package was written while I was a \
postdoctoral researcher in Niayesh Afshordi's group at Perimeter Institute \
for Theoretical Physics in Waterloo, Ontario, Canada. I would like to thank \
Niayesh Afshordi and Perimeter Institute for their support during that time. \
Research at Perimeter Institute is supported in part by the Government of \
Canada through the Department of Innovation, Science, and Economic \
Development Canada and by the Province of Ontario through the Ministry of \
Colleges and Universities.\
\>", "Text",ExpressionUUID->"d3029606-276a-204b-9bfc-2fa95e9121b7"],

Cell["\<\
Further work on this package was done as an assistant professor at Brock \
University. I acknowledge the support of the Natural Sciences and Engineering \
Research Council of Canada (NSERC), RGPIN-2024-04063.\
\>", "Text",ExpressionUUID->"9ebdf541-41a5-514b-b0f2-9478e15d9f5e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Copyright and citing", "Subsection",ExpressionUUID->"7a02a711-10c3-cc4e-9fed-20b550f73ff3"],

Cell[TextData[{
 "Copyright (c) 2021-2026 ",
 ButtonBox["Barak Shoshany",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://baraksh.com/"], None},
  ButtonNote->"https://baraksh.com/"],
 ". Licensed under the ",
 ButtonBox["MIT license",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://github.com/bshoshany/OGRe/blob/master/LICENSE.txt"], None},
  ButtonNote->"https://github.com/bshoshany/OGRe/blob/master/LICENSE.txt"],
 "."
}], "Text",ExpressionUUID->"687e835e-83e5-be48-b970-c6b1fcda1434"],

Cell[TextData[{
 "If you use this package in software of any kind, please provide a link to ",
 ButtonBox["the GitHub repository",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://github.com/bshoshany/OGRe"], None},
  ButtonNote->"https://github.com/bshoshany/OGRe"],
 " in the source code and documentation."
}], "Text",ExpressionUUID->"4e6c57d1-23eb-9946-9157-751362c4836b"],

Cell["\<\
If you use this package in published research, please cite it as follows:\
\>", "Text",ExpressionUUID->"209a7cd1-f7fb-7a4f-b8e4-0b51cd0fcd0a"],

Cell[TextData[{
 "Shoshany, B., (2021). OGRe: An Object-Oriented General Relativity Package \
for Mathematica. Journal of Open Source Software, 6(65), 3416, ",
 ButtonBox["https://doi.org/10.21105/joss.03416",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.21105/joss.03416"], None},
  ButtonNote->"https://doi.org/10.21105/joss.03416"]
}], "Item",ExpressionUUID->"62f0da1e-08ac-3643-b20a-3234940ac115"],

Cell["You can also use the following BibTeX entry:", "Text",ExpressionUUID->"b169c0de-9957-cc4f-a571-e26a0fab1968"],

Cell["\<\
@article{Shoshany2021_OGRe,
    author    = {Barak Shoshany},
    doi       = {10.21105/joss.03416},
    journal   = {Journal of Open Source Software},
    number    = {65},
    pages     = {3416},
    publisher = {The Open Journal},
    title     = {{OGRe}: An Object-Oriented General Relativity Package for \
Mathematica},
    url       = {https://doi.org/10.21105/joss.03416},
    volume    = {6},
    year      = {2021}
}\
\>", "Program",ExpressionUUID->"95729474-88f6-b34b-a76b-e0c4c193384d"],

Cell[TextData[{
 "Citing information can always be obtained by executing the command ",
 StyleBox["TCite[]", "Input"],
 ":"
}], "Text",ExpressionUUID->"b8641c78-5e41-4d4a-b05a-f19787cdfe1c"],

