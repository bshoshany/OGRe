Cell["\<\
For example, here is how the 4-velocity is stored internally:\
\>", "Text",ExpressionUUID->"95795a9b-65a9-b345-86d0-e4cd40a4bb37"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TExport", "[", "\"\<4-Velocity\>\"", "]"}]], "Input",
 CellLabel->
  "In[230]:=",ExpressionUUID->"904e4f20-0818-5846-9e04-df076def8777"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{"\<\"4-Velocity\"\>", "\[Rule]", 
   RowBox[{"\[LeftAssociation]", 
    RowBox[{
     RowBox[{"\<\"Components\"\>", "\[Rule]", 
      RowBox[{"\[LeftAssociation]", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", "1", "}"}], ",", "\<\"Cartesian\"\>"}], "}"}], "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
           FractionBox["1", 
            SqrtBox[
             RowBox[{"1", "-", 
              SuperscriptBox["v", "2"]}]]], ",", 
           FractionBox["v", 
            SqrtBox[
             RowBox[{"1", "-", 
              SuperscriptBox["v", "2"]}]]], ",", "0", ",", "0"}], "}"}]}], ",", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"-", "1"}], "}"}], ",", "\<\"Cartesian\"\>"}], "}"}], "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", 
            FractionBox["1", 
             SqrtBox[
              RowBox[{"1", "-", 
               SuperscriptBox["v", "2"]}]]]}], ",", 
           FractionBox["v", 
            SqrtBox[
             RowBox[{"1", "-", 
              SuperscriptBox["v", "2"]}]]], ",", "0", ",", "0"}], "}"}]}]}], 
       "\[RightAssociation]"}]}], ",", 
     RowBox[{"\<\"DefaultCoords\"\>", "\[Rule]", "\<\"Cartesian\"\>"}], ",", 
     RowBox[{"\<\"DefaultIndices\"\>", "\[Rule]", 
      RowBox[{"{", "1", "}"}]}], ",", 
     RowBox[{"\<\"Metric\"\>", "\[Rule]", "\<\"Minkowski\"\>"}], ",", 
     RowBox[{"\<\"Role\"\>", "\[Rule]", "\<\"Tensor\"\>"}], ",", 
     RowBox[{"\<\"Symbol\"\>", "\[Rule]", "\<\"v\"\>"}], ",", 
     RowBox[{"\<\"OGReVersion\"\>", 
      "\[Rule]", "\<\"v2.0.0 (2026-05-02)\"\>"}]}], "\[RightAssociation]"}]}],
   "\[RightAssociation]"}]], "Output",
 CellLabel->
  "Out[230]=",ExpressionUUID->"66372e24-7aaf-3544-9a78-c62ffafc6a9b"]
}, Open  ]],

Cell[TextData[{
 "This is a nested ",
 StyleBox["Association", "Input"],
 ". The upper level has just one key: ",
 StyleBox["\"4-Velocity\"", "Input"],
 ", which is the ID of the tensor. Its value is another ",
 StyleBox["Association", "Input"],
 ", which has the following keys:"
}], "Text",ExpressionUUID->"67c96192-5e88-8844-bf3d-90c9a22ac305"],

Cell[TextData[{
 StyleBox["\"Components\"", "Input"],
 ": An ",
 StyleBox["Association", "Input"],
 " containing the components of the tensor in different representations, each \
with a specific index configuration and coordinate system. The components are \
only generated when a particular combination of indices and coordinates is \
requested for the first time, so for example, here the components with both \
an upper and a lower index in Minkowski coordinates have been stored, but no \
components in spherical coordinates, since we have not tried to access them \
so far."
}], "Item",ExpressionUUID->"d5f81782-600a-5f4f-8320-0eb763ea3d9d"],

Cell[TextData[{
 StyleBox["\"DefaultCoords\"", "Input"],
 ": The default coordinate system to use when displaying the tensor."
}], "Item",ExpressionUUID->"e148130c-cb8f-ae4a-adee-2a54748c16fd"],

Cell[TextData[{
 StyleBox["\"DefaultIndices\"", "Input"],
 ": The default index configuration to use when displaying the tensor."
}], "Item",ExpressionUUID->"0db37e9d-4f64-4e45-b4ba-72d2454f85b4"],

Cell[TextData[{
 StyleBox["\"Metric\"", "Input"],
 ": The unique ID of the metric that will be used to raise and lower the \
tensor's indices. Note that this is only a reference, so a tensor object with \
this ID must exist. If a tensor is exported, its metric must be exported \
separately as well for raising and lowering of indices to work."
}], "Item",ExpressionUUID->"cbb50585-c404-6549-a4b1-c26a4eeda0e4"],

Cell[TextData[{
 StyleBox["\"Role\"", "Input"],
 ": The role of the tensor, which depends on the module that created it. Will \
be ",
 StyleBox["\"Coordinates\"", "Input"],
 " if the tensor was created using ",
 StyleBox["TNewCoordinates", "Input"],
 ", ",
 StyleBox["\"Metric\"", "Input"],
 " if the tensor was created using ",
 StyleBox["TNewMetric", "Input"],
 ", or ",
 StyleBox["\"Tensor\"", "Input"],
 " if the tensor was created using ",
 StyleBox["TNewTensor", "Input"],
 ". Other modules that we will discuss below, such as ",
 StyleBox["TCalc", "Input"],
 ", ",
 StyleBox["TChristoffel", "Input"],
 ", and ",
 StyleBox["TRiemann", "Input"],
 ", have corresponding roles as well. Additional roles are only used \
internally by OGRe, such as ",
 StyleBox["\"Temporary\"", "Input"],
 " for a temporary tensor created as an intermediate step in a calculation."
}], "Item",ExpressionUUID->"c92cdd4f-79a8-8947-8ec8-6c3338f53256"],

Cell[TextData[{
 StyleBox["\"Symbol\"", "Input"],
 ": The symbol used to represent the tensor when displaying it."
}], "Item",ExpressionUUID->"d5646f22-c551-fa4a-bf76-606a7272731a"],

Cell[TextData[{
 StyleBox["\"OGReVersion\"", "Input"],
 ": The version of the package used to create the tensor. (Note that this key \
is not stored internally, it is added by ",
 StyleBox["TExport", "Input"],
 ".)"
}], "Item",ExpressionUUID->"a34d3187-a7c5-4c43-9e17-548f4e0f2d7a"],

Cell[TextData[{
 "Other keys also exist in special cases. For example, for tensor objects \
representing coordinate systems, the keys ",
 StyleBox["\"CoordTransformations\"", "Input"],
 " and ",
 StyleBox["\"Jacobians\"", "Input"],
 " are used to store the details of coordinate transformations defined using ",
 StyleBox["TAddCoordTransformation", "Input"],
 ", as can be seen by exporting ",
 StyleBox["\"Cartesian\"", "Input"],
 ":"
}], "Text",ExpressionUUID->"16a4ca65-9596-c749-9f17-b3f362a068b9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TExport", "[", "\"\<Cartesian\>\"", "]"}]], "Input",
 CellLabel->
  "In[231]:=",ExpressionUUID->"7c259655-6173-0147-af94-0b91096f55bc"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{"\<\"Cartesian\"\>", "\[Rule]", 
   RowBox[{"\[LeftAssociation]", 
    RowBox[{
     RowBox[{"\<\"Components\"\>", "\[Rule]", 
      RowBox[{"\[LeftAssociation]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", "1", "}"}], ",", "\<\"Cartesian\"\>"}], "}"}], "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"t", ",", "x", ",", "y", ",", "z"}], "}"}]}], 
       "\[RightAssociation]"}]}], ",", 
     RowBox[{"\<\"DefaultCoords\"\>", "\[Rule]", "\<\"Cartesian\"\>"}], ",", 
     RowBox[{"\<\"DefaultIndices\"\>", "\[Rule]", 
      RowBox[{"{", "1", "}"}]}], ",", 
     RowBox[{"\<\"Role\"\>", "\[Rule]", "\<\"Coordinates\"\>"}], ",", 
     RowBox[{"\<\"Symbol\"\>", "\[Rule]", "\<\"x\"\>"}], ",", 
     RowBox[{"\<\"CoordTransformations\"\>", "\[Rule]", 
      RowBox[{"\[LeftAssociation]", 
       RowBox[{"\<\"Spherical\"\>", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"x", "\[Rule]", 
           RowBox[{"r", " ", 
            RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
            RowBox[{"Sin", "[", "\[Theta]", "]"}]}]}], ",", 
          RowBox[{"y", "\[Rule]", 
           RowBox[{"r", " ", 
            RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
            RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}], ",", 
          RowBox[{"z", "\[Rule]", 
           RowBox[{"r", " ", 
            RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}]}], "}"}]}], 
       "\[RightAssociation]"}]}], ",", 
     RowBox[{"\<\"Jacobians\"\>", "\[Rule]", 
      RowBox[{"\[LeftAssociation]", 
       RowBox[{"\<\"Spherical\"\>", "\[Rule]", 
        RowBox[{"\[LeftAssociation]", 
         RowBox[{
          RowBox[{"\<\"Jacobian\"\>", "\[Rule]", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"1", ",", "0", ",", "0", ",", "0"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"0", ",", 
               RowBox[{
                RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
                RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", 
               RowBox[{"r", " ", 
                RowBox[{"Cos", "[", "\[Theta]", "]"}], " ", 
                RowBox[{"Cos", "[", "\[Phi]", "]"}]}], ",", 
               RowBox[{
                RowBox[{"-", "r"}], " ", 
                RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
                RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"0", ",", 
               RowBox[{
                RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
                RowBox[{"Sin", "[", "\[Phi]", "]"}]}], ",", 
               RowBox[{"r", " ", 
                RowBox[{"Cos", "[", "\[Theta]", "]"}], " ", 
                RowBox[{"Sin", "[", "\[Phi]", "]"}]}], ",", 
               RowBox[{"r", " ", 
                RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
                RowBox[{"Sin", "[", "\[Theta]", "]"}]}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"0", ",", 
               RowBox[{"Cos", "[", "\[Theta]", "]"}], ",", 
               RowBox[{
                RowBox[{"-", "r"}], " ", 
                RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", "0"}], "}"}]}], 
            "}"}]}], ",", 
          RowBox[{"\<\"InverseJacobian\"\>", "\[Rule]", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"1", ",", "0", ",", "0", ",", "0"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"0", ",", 
               RowBox[{
                RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
                RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", 
               RowBox[{
                RowBox[{"Sin", "[", "\[Theta]", "]"}], " ", 
                RowBox[{"Sin", "[", "\[Phi]", "]"}]}], ",", 
               RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"0", ",", 
               FractionBox[
                RowBox[{
                 RowBox[{"Cos", "[", "\[Theta]", "]"}], " ", 
                 RowBox[{"Cos", "[", "\[Phi]", "]"}]}], "r"], ",", 
               FractionBox[
                RowBox[{
                 RowBox[{"Cos", "[", "\[Theta]", "]"}], " ", 
                 RowBox[{"Sin", "[", "\[Phi]", "]"}]}], "r"], ",", 
               RowBox[{"-", 
                FractionBox[
                 RowBox[{"Sin", "[", "\[Theta]", "]"}], "r"]}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"0", ",", 
               RowBox[{"-", 
                FractionBox[
                 RowBox[{
                  RowBox[{"Csc", "[", "\[Theta]", "]"}], " ", 
                  RowBox[{"Sin", "[", "\[Phi]", "]"}]}], "r"]}], ",", 
               FractionBox[
                RowBox[{
                 RowBox[{"Cos", "[", "\[Phi]", "]"}], " ", 
                 RowBox[{"Csc", "[", "\[Theta]", "]"}]}], "r"], ",", "0"}], 
              "}"}]}], "}"}]}]}], "\[RightAssociation]"}]}], 
       "\[RightAssociation]"}]}], ",", 
     RowBox[{"\<\"OGReVersion\"\>", 
      "\[Rule]", "\<\"v2.0.0 (2026-05-02)\"\>"}]}], "\[RightAssociation]"}]}],
   "\[RightAssociation]"}]], "Output",
 CellLabel->
  "Out[231]=",ExpressionUUID->"9e704378-c6fa-ae49-b909-a0ce7dbff473"]
}, Open  ]],

Cell[TextData[{
 "Built-in tensors derived from a metric, such as ",
 StyleBox["TRicci[\"FLRW\"]", "Input"],
 ", are cached inside the metric, not stored as top-level tensor objects with \
a unique ID. They can still be exported individually:"
}], "Text",ExpressionUUID->"f0f0d826-5703-8544-a159-287e92cf317a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TExport", "[", 
  RowBox[{"TRicci", "[", "\"\<FLRW\>\"", "]"}], "]"}]], "Input",
 CellLabel->
  "In[232]:=",ExpressionUUID->"ceae803c-f270-ab47-bd79-166c6dccc421"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{"\<\"FLRW->Ricci\"\>", "\[Rule]", 
   RowBox[{"\[LeftAssociation]", 
    RowBox[{
     RowBox[{"\<\"Components\"\>", "\[Rule]", 
      RowBox[{"\[LeftAssociation]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "1"}], ",", 
            RowBox[{"-", "1"}]}], "}"}], ",", "\<\"Spherical\"\>"}], "}"}], "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", 
             FractionBox[
              RowBox[{"3", " ", 
               RowBox[{
                SuperscriptBox["a", "\[Prime]\[Prime]",
                 MultilineFunction->None], "[", "t", "]"}]}], 
              RowBox[{"a", "[", "t", "]"}]]}], ",", "0", ",", "0", ",", "0"}],
            "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"0", ",", 
            RowBox[{
             RowBox[{"2", " ", 
              SuperscriptBox[
               RowBox[{
                SuperscriptBox["a", "\[Prime]",
                 MultilineFunction->None], "[", "t", "]"}], "2"]}], "+", 
             RowBox[{
              RowBox[{"a", "[", "t", "]"}], " ", 
              RowBox[{
               SuperscriptBox["a", "\[Prime]\[Prime]",
                MultilineFunction->None], "[", "t", "]"}]}]}], ",", "0", ",", 
            "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"0", ",", "0", ",", 
            RowBox[{
             SuperscriptBox["r", "2"], " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"2", " ", 
                SuperscriptBox[
                 RowBox[{
                  SuperscriptBox["a", "\[Prime]",
                   MultilineFunction->None], "[", "t", "]"}], "2"]}], "+", 
               RowBox[{
                RowBox[{"a", "[", "t", "]"}], " ", 
                RowBox[{
                 SuperscriptBox["a", "\[Prime]\[Prime]",
                  MultilineFunction->None], "[", "t", "]"}]}]}], ")"}]}], ",",
             "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"0", ",", "0", ",", "0", ",", 
            RowBox[{
             SuperscriptBox["r", "2"], " ", 
             SuperscriptBox[
              RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"], " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"2", " ", 
                SuperscriptBox[
                 RowBox[{
                  SuperscriptBox["a", "\[Prime]",
                   MultilineFunction->None], "[", "t", "]"}], "2"]}], "+", 
               RowBox[{
                RowBox[{"a", "[", "t", "]"}], " ", 
                RowBox[{
                 SuperscriptBox["a", "\[Prime]\[Prime]",
                  MultilineFunction->None], "[", "t", "]"}]}]}], ")"}]}]}], 
           "}"}]}], "}"}]}], "\[RightAssociation]"}]}], ",", 
     RowBox[{"\<\"DefaultCoords\"\>", "\[Rule]", "\<\"Spherical\"\>"}], ",", 
     RowBox[{"\<\"DefaultIndices\"\>", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "1"}], ",", 
        RowBox[{"-", "1"}]}], "}"}]}], ",", 
     RowBox[{"\<\"Metric\"\>", "\[Rule]", "\<\"FLRW\"\>"}], ",", 
     RowBox[{"\<\"Role\"\>", "\[Rule]", "\<\"Ricci\"\>"}], ",", 
     RowBox[{"\<\"Symbol\"\>", "\[Rule]", "\<\"R\"\>"}], ",", 
     RowBox[{"\<\"OGReVersion\"\>", 
      "\[Rule]", "\<\"v2.0.0 (2026-05-02)\"\>"}]}], "\[RightAssociation]"}]}],
   "\[RightAssociation]"}]], "Output",
 CellLabel->
  "Out[232]=",ExpressionUUID->"92d21640-8683-dd48-958c-bb73c69d48c5"]
}, Open  ]],

Cell[TextData[{
 "In this case, the exported key will have the form ",
 StyleBox["\"FLRW->Ricci\"", "Input"],
 "; this is not a tensor ID, but a reference to a cached built-in tensor. The \
",
 StyleBox["->", "Input"],
 " reference operator is reserved for these built-in tensors, and cannot be \
used in tensor IDs created by the user. Since the built-in tensors are cached \
inside the metric object, exporting the metric will also export any cached \
built-in tensors derived from it."
}], "Text",ExpressionUUID->"14f01b8b-1e4e-2042-b002-e2f048ef7fd2"],

Cell[TextData[{
 "To import a tensor back after it has been exported, use the ",
 StyleBox["TImport", "Input"],
 " module:"
}], "Text",ExpressionUUID->"0cc8cf8f-f23e-7f4a-ae16-71a92e2fda88"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"?", "TImport"}]], "Input",
 CellLabel->
  "In[233]:=",ExpressionUUID->"7588846b-66e1-4442-a662-920f47cefff8"],

Cell[BoxData[
 InterpretationBox[
  StyleBox[
   FrameBox[
    DynamicModuleBox[{System`InformationDump`open$$ = False, 
     System`InformationDump`mouseOver$$ = False}, 
     PaneSelectorBox[{True->
      TagBox[GridBox[{
         {
          ItemBox[
           PaneBox[
            StyleBox[
             TagBox[
              TooltipBox[
               StyleBox["\<\" Symbol\"\>", "InformationRowLabel",
                StripOnInput->False],
               "\"Symbol\"",
               TooltipStyle->"TextStyling"],
              Annotation[#, "Symbol", "Tooltip"]& ], "InformationTitleText",
             StripOnInput->False,
             BaseStyle -> None],
            FrameMargins->{{4, 0}, {-1, 1}}],
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False]},
         {
          ItemBox[
           PaneBox[
            
            StyleBox["\<\"\\!\\(\\*InterpretationBox[Cell[TextData[{\\\"\
TImport[\\\", StyleBox[\\\"data\\\", Bold, Rule[StripOnInput, False]], \\\"] \
imports a tensor that has been exported using TExport[].\\\"}]], \
TextCell[Row[List[\\\"TImport[\\\", Style[\\\"data\\\", Bold], \\\"] imports \
a tensor that has been exported using TExport[].\\\"]]]]\\)\"\>", 
             "InformationUsageText",
             StripOnInput->False,
             LineSpacing->{1.5, 1.5, 3.}],
            FrameMargins->{{10, 10}, {8, 10}}],
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False]},
         {
          PaneBox[
           TagBox[GridBox[{
              {
               StyleBox[
                TagBox[
                 TooltipBox[
                  StyleBox["\<\" Definitions\"\>", "InformationRowLabel",
                   StripOnInput->False],
                  "\"Definitions\"",
                  TooltipStyle->"TextStyling"],
                 Annotation[#, "Definitions", "Tooltip"]& ], "DialogStyle",
                StripOnInput->False]},
              {
               TemplateBox[{"\"\[ThinSpace]\"", 
                 GridBox[{{
                    RowBox[{
                    
                    RowBox[{
                    "TImport", "[", "OGRe`Private`data_Association", "]"}], 
                    ":=", 
                    RowBox[{"Module", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    
                    RowBox[{"OGRe`Private`newData", ",", 
                    "OGRe`Private`newID"}], "}"}], ",", 
                    RowBox[{
                    RowBox[{"OGRe`Private`newID", "=", 
                    RowBox[{
                    RowBox[{"Keys", "[", "OGRe`Private`data", "]"}], 
                    "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]}], 
                    ";", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"!", 
                    RowBox[{"KeyExistsQ", "[", 
                    RowBox[{
                    
                    RowBox[{"OGRe`Private`data", "\[LeftDoubleBracket]", "1", 
                    "\[RightDoubleBracket]"}], ",", "\"OGReVersion\""}], 
                    "]"}]}], "||", 
                    RowBox[{
                    RowBox[{
                    
                    RowBox[{"OGRe`Private`data", "\[LeftDoubleBracket]", "1", 
                    "\[RightDoubleBracket]"}], "[", "\"OGReVersion\"", "]"}], 
                    "\[NotEqual]", "OGRe`Private`OGReVersion"}]}], ",", 
                    RowBox[{
                    
                    RowBox[{"OGRe`Private`OGRePrint", "[", 
                    "\"Warning: The imported tensor was created in a \
different version of OGRe. Compatibility issues may occur.\"", "]"}], ";"}]}],
                     "]"}], ";", 
                    
                    RowBox[{"OGRe`Private`CheckIfOverwriting", "[", 
                    "OGRe`Private`newID", "]"}], ";", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    
                    RowBox[{"OGRe`Private`ReferenceIDQ", "[", 
                    "OGRe`Private`newID", "]"}], ",", 
                    RowBox[{"OGRe`Private`CheckIfTensorExists", "[", 
                    RowBox[{
                    
                    RowBox[{"OGRe`Private`ReferenceParts", "[", 
                    "OGRe`Private`newID", "]"}], "\[LeftDoubleBracket]", "1", 
                    "\[RightDoubleBracket]"}], "]"}], ",", 
                    
                    RowBox[{"OGRe`Private`CheckIDHasNoReference", "[", 
                    "OGRe`Private`newID", "]"}]}], "]"}], ";", 
                    RowBox[{"OGRe`Private`newData", "=", 
                    RowBox[{"KeyDrop", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"Values", "[", "OGRe`Private`data", "]"}], 
                    "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 
                    ",", "\"OGReVersion\""}], "]"}]}], ";", 
                    RowBox[{"OGRe`Private`CheckImportedTensorReferences", "[", 
                    
                    RowBox[{"OGRe`Private`newID", ",", 
                    "OGRe`Private`newData"}], "]"}], ";", 
                    RowBox[{"OGRe`Private`SetTensorID", "[", 
                    
                    RowBox[{"OGRe`Private`newID", ",", 
                    "OGRe`Private`newData"}], "]"}], ";", 
                    RowBox[{"OGRe`Private`UpdateCodeCompletions", "[", "]"}], 
                    ";", 
                    RowBox[{"Return", "[", "OGRe`Private`newID", "]"}], 
                    ";"}]}], "]"}]}]}, {" "}}, 
                  GridBoxAlignment -> {"Columns" -> {{Left}}}, 
                  DefaultBaseStyle -> "Column", 
                  GridBoxItemSize -> {
                   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]},
                "RowDefault"]}
             },
