Cell["\<\
For example, we can check that the covariant derivative of the FLRW metric \
also vanishes:\
\>", "Text",ExpressionUUID->"c1cd48f0-8063-1247-8b2c-d57ec5dd8d59"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TList", "@", 
  RowBox[{"TCalc", "[", 
   RowBox[{
    RowBox[{"TCovariantD", "[", "\"\<\[Mu]\>\"", "]"}], ".", 
    RowBox[{"\"\<FLRW\>\"", "[", "\"\<\[Alpha]\[Beta]\>\"", "]"}]}], 
   "]"}]}]], "Input",
 CellLabel->
  "In[187]:=",ExpressionUUID->"cb011bdc-ff55-ff49-9624-2b1689cfdb8e"],

Cell[BoxData[
 StyleBox[
  TagBox[GridBox[{
     {
      TemplateBox[{"\"Result\"", "\":\""},
       "RowDefault"]},
     {"\<\"No non-zero elements.\"\>"}
    },
    DefaultBaseStyle->"Column",
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
   "Column"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"cd43c482-01cf-a54d-ac61-e4200bbd55e8"]
}, Open  ]],

Cell["The covariant divergence of the Einstein tensor is:", "Text",ExpressionUUID->"622f1775-54bb-114c-b66a-26b693d01282"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox["\[Del]", "\[Mu]"], 
    SuperscriptBox[
     StyleBox["G", "TI"], "\[Mu]\[Nu]"], "\[LongEqual]", 
    SubscriptBox["\[PartialD]", "\[Mu]"], 
    SuperscriptBox[
     StyleBox["G", "TI"], "\[Mu]\[Nu]"], "+", 
    SubsuperscriptBox["\[CapitalGamma]", "\[Mu]\[Lambda]", "\[Mu]"], 
    SuperscriptBox[
     StyleBox["G", "TI"], "\[Lambda]\[Nu]"], "+", 
    SubsuperscriptBox["\[CapitalGamma]", "\[Mu]\[Lambda]", "\[Nu]"], 
    SuperscriptBox[
     StyleBox["G", "TI"], "\[Mu]\[Lambda]"]}], "."}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"7a8cf16d-f716-f44f-\
ae90-0be097221e89"],

Cell[TextData[{
 "Note that it involves a contraction in the index ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "28382257-4725-c246-ba78-a401520ab0b9"],
 ", which becomes a trace in the first Christoffel symbol. This expression \
vanishes because of the ",
 StyleBox["Bianchi identity",
  FontWeight->Bold],
 ":"
}], "Text",ExpressionUUID->"58c05af2-ac5e-da4f-bf68-a303c427d00b"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox["\[Del]", "\[Mu]"], 
    SuperscriptBox[
     StyleBox["R", "TI"], "\[Mu]\[Nu]"], "\[LongEqual]", 
    FractionBox["1", "2"], 
    SuperscriptBox["\[Del]", "\[Nu]"], 
    StyleBox["R", "TI"], "  ", 
    RowBox[{"\[DoubleRightArrow]", "  "}], 
    SubscriptBox["\[Del]", "\[Mu]"], 
    SuperscriptBox[
     StyleBox["G", "TI"], "\[Mu]\[Nu]"], "\[LongEqual]", "0"}], "."}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"06e769cd-e9cf-474a-\
83bb-f54afaa4b90d"],

Cell["To calculate it in OGRe, we simply write:", "Text",ExpressionUUID->"fd5d501f-b99a-b042-b668-1b8970dc3d78"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TList", "@", 
  RowBox[{"TCalc", "[", 
   RowBox[{
    RowBox[{"TCovariantD", "[", "\"\<\[Mu]\>\"", "]"}], ".", 
    RowBox[{
     RowBox[{"TEinstein", "[", "\"\<FLRW\>\"", "]"}], 
     "[", "\"\<\[Mu]\[Nu]\>\"", "]"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[188]:=",ExpressionUUID->"b08c9e10-c863-9e41-a57b-05cb36c60f60"],

Cell[BoxData[
 StyleBox[
  TagBox[GridBox[{
     {
      TemplateBox[{"\"Result\"", "\":\""},
       "RowDefault"]},
     {"\<\"No non-zero elements.\"\>"}
    },
    DefaultBaseStyle->"Column",
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
   "Column"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"9a71fd62-df80-364d-90f6-afba4c745256"]
}, Open  ]],

Cell[TextData[{
 "Finally, for a non-trivial result, let us recall that the stress-energy \
tensor should be ",
 StyleBox["conserved",
  FontWeight->Bold],
 ":"
}], "Text",ExpressionUUID->"b4ec6968-9a96-0c4a-8e98-909bf56fec0a"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox["\[Del]", "\[Mu]"], 
    SuperscriptBox[
     StyleBox["T", "TI"], "\[Mu]\[Nu]"], "\[LongEqual]", 
    SubscriptBox["\[PartialD]", "\[Mu]"], 
    SuperscriptBox[
     StyleBox["T", "TI"], "\[Mu]\[Nu]"], "+", 
    SubsuperscriptBox["\[CapitalGamma]", "\[Mu]\[Lambda]", "\[Mu]"], 
    SuperscriptBox[
     StyleBox["T", "TI"], "\[Lambda]\[Nu]"], "+", 
    SubsuperscriptBox["\[CapitalGamma]", "\[Mu]\[Lambda]", "\[Nu]"], 
    SuperscriptBox[
     StyleBox["T", "TI"], "\[Mu]\[Lambda]"], "\[LongEqual]", "0"}], "."}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"f96360bf-2398-3747-\
bf83-d0f53e28428e"],

Cell[TextData[{
 "This follows from the fact that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Del]", "\[Mu]"], 
    SuperscriptBox[
     StyleBox["G", "TI"], "\[Mu]\[Nu]"], "\[LongEqual]", "0"}], 
   TraditionalForm]],ExpressionUUID->"aa32b33f-7914-e94b-ba2f-90b262675249"],
 ", combined with the ",
 StyleBox["Einstein equation",
  FontWeight->Bold],
 ":"
}], "Text",ExpressionUUID->"9eb96e64-bb88-144c-8d65-269237cb240a"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["G", "TI"], "\[Mu]\[Nu]"], "\[LongEqual]", "\[Kappa]", 
    SubscriptBox[
     StyleBox["T", "TI"], "\[Mu]\[Nu]"]}], ","}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"2eff95cc-67c1-734d-\
8707-e548897eb1b3"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Kappa]", "\[LongEqual]", "1"}], TraditionalForm]],
  ExpressionUUID->"4a0c290f-90ac-344c-b605-b3e54fe6eb47"],
 " or ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Kappa]", "\[LongEqual]", "8", "\[Pi]"}], TraditionalForm]],
  ExpressionUUID->"e8c83ebe-d451-ad44-b93a-3ee676c37bcd"],
 " depending on your preferred units. However, unlike ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Del]", "\[Mu]"], 
    SuperscriptBox[
     StyleBox["G", "TI"], "\[Mu]\[Nu]"], "\[LongEqual]", "0"}], 
   TraditionalForm]],ExpressionUUID->"29e5a50b-2be8-df41-b7e1-036c45daa155"],
 ", the relation ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Del]", "\[Mu]"], 
    SuperscriptBox[
     StyleBox["T", "TI"], "\[Mu]\[Nu]"], "\[LongEqual]", "0"}], 
   TraditionalForm]],ExpressionUUID->"1a5c2827-480f-5c42-b556-3b41dfd8b6c7"],
 " is ",
 StyleBox["not",
  FontWeight->Bold],
 " an identity; it is an ",
 StyleBox["energy-momentum conservation equation",
  FontWeight->Bold],
 ". To derive the equation for the FLRW metric, let us first define the \
rest-frame fluid 4-velocity in this spacetime:"
}], "Text",ExpressionUUID->"e9f9ace8-73e2-e843-88e1-f77daadccf64"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TShow", "@", 
  RowBox[{"TNewTensor", "[", 
   RowBox[{"\"\<RestVelocity\>\"", ",", "\"\<FLRW\>\"", 
    ",", "\"\<Spherical\>\"", ",", 
    RowBox[{"{", "1", "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"1", ",", "0", ",", "0", ",", "0"}], "}"}], ",", "\"\<u\>\""}], 
   "]"}]}]], "Input",
 CellLabel->
  "In[189]:=",ExpressionUUID->"48088cd3-ffbd-8d4c-853c-f66cebee8500"],

Cell[BoxData[
 StyleBox[
  TemplateBox[{"\"RestVelocity\"", "\":   \"", 
    TemplateBox[{"\"u\"", 
      TemplateBox[{"\"\[Mu]\""}, "RowDefault"]}, "Superscript", SyntaxForm -> 
     SuperscriptBox], "\"(\"", 
    TemplateBox[{",", "\",\"", "t", "r", "\[Theta]", "\[Phi]"}, 
     "RowWithSeparators"], "\")\"", "\" = \"", 
    TagBox[
     RowBox[{"(", "\[NoBreak]", 
       TagBox[
        GridBox[{{"1"}, {"0"}, {"0"}, {"0"}}, ColumnAlignments -> Center, 
         RowSpacings -> 1, ColumnAlignments -> Left], Column], "\[NoBreak]", 
       ")"}], 
     Function[BoxForm`e$, 
      MatrixForm[BoxForm`e$]]]},
   "RowDefault"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"2e10ed25-3010-b94b-b52d-467b25399805"]
}, Open  ]],

Cell[TextData[{
 "Using the 4-velocity and the metric, we redefine the perfect fluid stress \
tensor in the FLRW spacetime using the formula ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     StyleBox["T", "TI"], "\[Mu]\[Nu]"], "\[LongEqual]", 
    RowBox[{"(", 
     RowBox[{"\[Rho]", "+", 
      StyleBox["p", "TI"]}], ")"}], 
    SuperscriptBox[
     StyleBox["u", "TI"], "\[Mu]"], 
    SuperscriptBox[
     StyleBox["u", "TI"], "\[Nu]"], "+", 
    SuperscriptBox[
     StyleBox[
      RowBox[{"p", "g"}], "TI"], "\[Mu]\[Nu]"]}], TraditionalForm]],
  ExpressionUUID->"04ad55cc-aa46-fb48-b5f6-10126bf5badc"],
 ", and give ",
 Cell[BoxData[
  FormBox["\[Rho]", TraditionalForm]],ExpressionUUID->
  "9497b65a-ec4a-8848-92e3-16457036904c"],
 " and ",
 Cell[BoxData[
  FormBox[
   StyleBox["p", "TI"], TraditionalForm]],ExpressionUUID->
  "d2353d45-f93d-124f-b1a9-f3ba2089f03e"],
 " spacetime dependence:"
}], "Text",ExpressionUUID->"2f2bf5ab-d226-4740-989b-0d66452d7fa0"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"TCalc", "[", 
   RowBox[{"\"\<PerfectFluidFLRW\>\"", ",", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"\[Rho]", "[", 
         RowBox[{"t", ",", "r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}], "+", 
        RowBox[{"p", "[", 
         RowBox[{"t", ",", "r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}]}], 
       ")"}], " ", 
      RowBox[{
       RowBox[{"\"\<RestVelocity\>\"", "[", "\"\<\[Mu]\>\"", "]"}], ".", 
       RowBox[{"\"\<RestVelocity\>\"", "[", "\"\<\[Nu]\>\"", "]"}]}]}], "+", 
     RowBox[{
      RowBox[{"p", "[", 
       RowBox[{"t", ",", "r", ",", "\[Theta]", ",", "\[Phi]"}], "]"}], " ", 
      RowBox[{"\"\<FLRW\>\"", "[", "\"\<\[Mu]\[Nu]\>\"", "]"}]}]}], 
    ",", "\"\<T\>\""}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"TChangeDefaultIndices", "[", 
   RowBox[{"\"\<PerfectFluidFLRW\>\"", ",", 
    RowBox[{"{", 
     RowBox[{"1", ",", "1"}], "}"}]}], "]"}], ";"}], "\n", 
 RowBox[{"TShow", "[", "\"\<PerfectFluidFLRW\>\"", "]"}]}], "Input",
 CellLabel->
  "In[190]:=",ExpressionUUID->"a605a66b-ef20-8847-9265-df4397b35eb6"],

Cell[BoxData[
 StyleBox[
  TemplateBox[{"\"PerfectFluidFLRW\"", "\":   \"", 
    TemplateBox[{"\"T\"", 
      TemplateBox[{"\"\[Mu]\"", "\"\[Nu]\""}, "RowDefault"]}, "Superscript", 
     SyntaxForm -> SuperscriptBox], "\"(\"", 
    TemplateBox[{",", "\",\"", "t", "r", "\[Theta]", "\[Phi]"}, 
     "RowWithSeparators"], "\")\"", "\" = \"", 
    TagBox[
     RowBox[{"(", "\[NoBreak]", 
       GridBox[{{"\[Rho]", "0", "0", "0"}, {"0", 
          FractionBox[
           RowBox[{"p", " ", 
             RowBox[{"(", 
               RowBox[{"1", "-", 
                 RowBox[{"k", " ", 
                   SuperscriptBox["r", "2"]}]}], ")"}]}], 
           SuperscriptBox["a", "2"]], "0", "0"}, {"0", "0", 
          FractionBox["p", 
           RowBox[{
             SuperscriptBox["a", "2"], " ", 
             SuperscriptBox["r", "2"]}]], "0"}, {"0", "0", "0", 
          FractionBox[
           RowBox[{"p", " ", 
             SuperscriptBox[
              RowBox[{"Csc", "[", "\[Theta]", "]"}], "2"]}], 
           RowBox[{
             SuperscriptBox["a", "2"], " ", 
             SuperscriptBox["r", "2"]}]]}}, RowSpacings -> 1, ColumnSpacings -> 
        1, RowAlignments -> Baseline, ColumnAlignments -> Center], 
       "\[NoBreak]", ")"}], 
     Function[BoxForm`e$, 
      MatrixForm[BoxForm`e$]]]},
   "RowDefault"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"8db68f7c-d341-ed48-9ffd-6ec7e45fb7d6"]
}, Open  ]],

Cell["\<\
Finally, we take the covariant derivative of the stress tensor:\
\>", "Text",ExpressionUUID->"fa6e772c-8cba-324d-80d3-516d448931ff"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TList", "@", 
  RowBox[{"TCalc", "[", 
   RowBox[{"\"\<FLRWConservation\>\"", ",", 
    RowBox[{
     RowBox[{"TCovariantD", "[", "\"\<\[Mu]\>\"", "]"}], ".", 
     RowBox[{"\"\<PerfectFluidFLRW\>\"", "[", "\"\<\[Mu]\[Nu]\>\"", "]"}]}]}],
    "]"}]}]], "Input",
 CellLabel->
  "In[193]:=",ExpressionUUID->"3d8c5a5a-ccf8-bd40-9099-240c3dd95915"],

Cell[BoxData[
 StyleBox[
  TagBox[GridBox[{
     {
      TemplateBox[{"\"FLRWConservation\"", "\":\""},
       "RowDefault"]},
     {
      TagBox[GridBox[{
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"\[DottedSquare]\"", 
              TemplateBox[{"t"}, "RowDefault"]}, "Superscript", SyntaxForm -> 
             SuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           FractionBox[
            RowBox[{"3", " ", 
             RowBox[{"(", 
              RowBox[{"p", "+", "\[Rho]"}], ")"}], " ", 
             TemplateBox[{
               SubscriptBox["\"\[PartialD]\"", "t"], "a"},
              "RowDefault"]}], "a"], "+", 
           TemplateBox[{
             SubscriptBox["\"\[PartialD]\"", "t"], "\[Rho]"},
            "RowDefault"]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"\[DottedSquare]\"", 
              TemplateBox[{"r"}, "RowDefault"]}, "Superscript", SyntaxForm -> 
             SuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", 
          FractionBox[
           RowBox[{
            RowBox[{"(", 
             RowBox[{"1", "-", 
              RowBox[{"k", " ", 
               SuperscriptBox["r", "2"]}]}], ")"}], " ", 
            TemplateBox[{
              SubscriptBox["\"\[PartialD]\"", "r"], "p"},
             "RowDefault"]}], 
           SuperscriptBox["a", "2"]]},
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"\[DottedSquare]\"", 
              TemplateBox[{"\[Theta]"}, "RowDefault"]}, "Superscript", 
             SyntaxForm -> SuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", 
          FractionBox[
           TemplateBox[{
             SubscriptBox["\"\[PartialD]\"", "\[Theta]"], "p"},
            "RowDefault"], 
           RowBox[{
            SuperscriptBox["a", "2"], " ", 
            SuperscriptBox["r", "2"]}]]},
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"\[DottedSquare]\"", 
              TemplateBox[{"\[Phi]"}, "RowDefault"]}, "Superscript", 
             SyntaxForm -> SuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", 
          FractionBox[
           RowBox[{
            SuperscriptBox[
             RowBox[{"Csc", "[", "\[Theta]", "]"}], "2"], " ", 
            TemplateBox[{
              SubscriptBox["\"\[PartialD]\"", "\[Phi]"], "p"},
             "RowDefault"]}], 
           RowBox[{
            SuperscriptBox["a", "2"], " ", 
            SuperscriptBox["r", "2"]}]]}
        },
        AutoDelete->False,
        GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
        GridBoxItemSize->{
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
       "Grid"]}
    },
    DefaultBaseStyle->"Column",
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
   "Column"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"5a08ef0d-9990-0645-ad52-e8fc1a8186a3"]
}, Open  ]],

Cell[TextData[{
 "From demanding that the ",
 Cell[BoxData[
  FormBox[
   StyleBox["t", "TI"], TraditionalForm]],ExpressionUUID->
  "3fe71f0a-2378-a94f-9ae6-d144c9b8b19a"],
 " component vanishes, we get the following equation:"
}], "Text",ExpressionUUID->"c1c50139-0707-854c-9c29-ce2c6f84c65a"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    OverscriptBox["\[Rho]", "."], "\[LongEqual]", 
    RowBox[{"-", "3"}], 
    RowBox[{"(", 
     RowBox[{"\[Rho]", "+", 
      StyleBox["p", "TI"]}], ")"}], 
    FractionBox[
     OverscriptBox[
      StyleBox["a", "TI"], "."], 
     StyleBox["a", "TI"]]}], "."}], TraditionalForm]], "DisplayFormula",Expres\
sionUUID->"bb001d45-d551-754c-92e0-66db32272146"],

Cell[TextData[{
 "We see that in an expanding universe, energy is not conserved, but rather, \
the energy density changes with time in a way that depends on the scale \
factor. If the universe is not expanding, that is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox[
     StyleBox["a", "TI"], "."], "\[LongEqual]", "0"}], TraditionalForm]],
  ExpressionUUID->"4d4ce955-1286-064a-b3b3-16410026a539"],
 ", then energy will be conserved."
}], "Text",ExpressionUUID->"f2bb31a5-3503-5141-afd0-50ec548900c5"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Overwriting metrics", "Subsection",ExpressionUUID->"8d449d86-7550-a749-86e4-b5e2018cc859"],

Cell[TextData[{
 "If overwriting tensors has been allowed using ",
 StyleBox["TSetAllowOverwrite[True]", "Input"],
 ", and we overwrite a metric tensor, then all derived tensors cached inside \
that metric will be automatically deleted, since the corresponding quantities \
for the new metric will generally be different. For example, let us overwrite \
the FLRW metric with a similar metric where ",
 StyleBox["k",
  FontSlant->Italic],
 " is equal to 0:"
}], "Text",ExpressionUUID->"235c0b47-5140-3e46-89bd-3b8dc778ca58"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"currentOverwrite", "=", 
   RowBox[{"TSetAllowOverwrite", "[", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"TSetAllowOverwrite", "[", "True", "]"}], ";"}], "\n", 
 RowBox[{"TShow", "@", 
  RowBox[{"TNewMetric", "[", 
   RowBox[{"\"\<FLRW\>\"", ",", "\"\<Spherical\>\"", ",", 
    RowBox[{"DiagonalMatrix", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "1"}], ",", 
       SuperscriptBox[
        RowBox[{"a", "[", "t", "]"}], "2"], ",", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"a", "[", "t", "]"}], "2"], " ", 
        SuperscriptBox["r", "2"]}], ",", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"a", "[", "t", "]"}], "2"], " ", 
        SuperscriptBox["r", "2"], " ", 
        SuperscriptBox[
         RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}]}], "}"}], "]"}]}], 
   "]"}]}]}], "Input",
 CellLabel->
  "In[194]:=",ExpressionUUID->"1f870f5f-69b0-0c4b-a5af-bc2a0347e290"],

Cell[BoxData[
 TemplateBox[{
  "TSetAllowOverwrite", "Notify", 
   "\"Overwriting tensors turned \
\\!\\(\\*RowBox[{\\\"\\\\\\\"on\\\\\\\"\\\"}]\\).\"", 2, 195, 12, 
   30274037233204585468, "Local", "OGRe`TSetAllowOverwrite"},
  "MessageTemplate2",
  BaseStyle->"MSG"]], "Message",
 CellLabel->
