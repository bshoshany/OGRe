}, Open  ]],

Cell[TextData[{
 "If we now try to access, for example, ",
 StyleBox["TChristoffel[\"FLRW\"]", "Input"],
 ", OGRe will recalculate it automatically from the new metric:"
}], "Text",ExpressionUUID->"48e6ea7c-761f-4a46-83ea-8e7ecfbf7f8d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TList", "@", 
  RowBox[{"TChristoffel", "[", "\"\<FLRW\>\"", "]"}]}]], "Input",
 CellLabel->
  "In[197]:=",ExpressionUUID->"80118be8-2fa1-6544-979c-c8ce91ad3e4f"],

Cell[BoxData[
 StyleBox[
  TagBox[GridBox[{
     {
      TemplateBox[{"\"FLRW->Christoffel\"", "\":\""},
       "RowDefault"]},
     {
      TagBox[GridBox[{
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"\[CapitalGamma]\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"], "r", "r"}, "RowDefault"], 
              TemplateBox[{"t", 
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"], 
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{"a", " ", 
           TemplateBox[{
             SubscriptBox["\"\[PartialD]\"", "t"], "a"},
            "RowDefault"]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"\[CapitalGamma]\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"], "\[Theta]", "\[Theta]"}, 
               "RowDefault"], 
              TemplateBox[{"t", 
                TemplateBox[{
                  Rational[17, 2]}, "Spacer1"], 
                TemplateBox[{
                  Rational[17, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{"a", " ", 
           SuperscriptBox["r", "2"], " ", 
           TemplateBox[{
             SubscriptBox["\"\[PartialD]\"", "t"], "a"},
            "RowDefault"]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"\[CapitalGamma]\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"], "\[Phi]", "\[Phi]"}, 
               "RowDefault"], 
              TemplateBox[{"t", 
                TemplateBox[{
                  Rational[19, 2]}, "Spacer1"], 
                TemplateBox[{
                  Rational[19, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{"a", " ", 
           SuperscriptBox["r", "2"], " ", 
           TemplateBox[{
             SubscriptBox["\"\[PartialD]\"", "t"], "a"},
            "RowDefault"], " ", 
           SuperscriptBox[
            RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"\[CapitalGamma]\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"], "t", "r"}, "RowDefault"], 
              TemplateBox[{"r", 
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"], 
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
            TemplateBox[{"\"\[CapitalGamma]\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"], "r", "t"}, "RowDefault"], 
              TemplateBox[{"r", 
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"], 
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
            TemplateBox[{"\"\[CapitalGamma]\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[17, 2]}, "Spacer1"], "t", "\[Theta]"}, 
               "RowDefault"], 
              TemplateBox[{"\[Theta]", 
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"], 
                TemplateBox[{
                  Rational[17, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
            TemplateBox[{"\"\[CapitalGamma]\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[17, 2]}, "Spacer1"], "\[Theta]", "t"}, 
               "RowDefault"], 
              TemplateBox[{"\[Theta]", 
                TemplateBox[{
                  Rational[17, 2]}, "Spacer1"], 
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
            TemplateBox[{"\"\[CapitalGamma]\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[19, 2]}, "Spacer1"], "t", "\[Phi]"}, "RowDefault"], 
              TemplateBox[{"\[Phi]", 
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"], 
                TemplateBox[{
                  Rational[19, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
            TemplateBox[{"\"\[CapitalGamma]\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[19, 2]}, "Spacer1"], "\[Phi]", "t"}, "RowDefault"], 
              TemplateBox[{"\[Phi]", 
                TemplateBox[{
                  Rational[19, 2]}, "Spacer1"], 
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", 
          FractionBox[
           TemplateBox[{
             SubscriptBox["\"\[PartialD]\"", "t"], "a"},
            "RowDefault"], "a"]},
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"\[CapitalGamma]\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"], "\[Theta]", "\[Theta]"}, 
               "RowDefault"], 
              TemplateBox[{"r", 
                TemplateBox[{
                  Rational[17, 2]}, "Spacer1"], 
                TemplateBox[{
                  Rational[17, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{"-", "r"}]},
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"\[CapitalGamma]\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"], "\[Phi]", "\[Phi]"}, 
               "RowDefault"], 
              TemplateBox[{"r", 
                TemplateBox[{
                  Rational[19, 2]}, "Spacer1"], 
                TemplateBox[{
                  Rational[19, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           RowBox[{"-", "r"}], " ", 
           SuperscriptBox[
            RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"\[CapitalGamma]\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[17, 2]}, "Spacer1"], "r", "\[Theta]"}, 
               "RowDefault"], 
              TemplateBox[{"\[Theta]", 
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"], 
                TemplateBox[{
                  Rational[17, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
            TemplateBox[{"\"\[CapitalGamma]\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[17, 2]}, "Spacer1"], "\[Theta]", "r"}, 
               "RowDefault"], 
              TemplateBox[{"\[Theta]", 
                TemplateBox[{
                  Rational[17, 2]}, "Spacer1"], 
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
            TemplateBox[{"\"\[CapitalGamma]\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[19, 2]}, "Spacer1"], "r", "\[Phi]"}, "RowDefault"], 
              TemplateBox[{"\[Phi]", 
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"], 
                TemplateBox[{
                  Rational[19, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
            TemplateBox[{"\"\[CapitalGamma]\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[19, 2]}, "Spacer1"], "\[Phi]", "r"}, "RowDefault"], 
              TemplateBox[{"\[Phi]", 
                TemplateBox[{
                  Rational[19, 2]}, "Spacer1"], 
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", 
          FractionBox["1", "r"]},
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"\[CapitalGamma]\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[17, 2]}, "Spacer1"], "\[Phi]", "\[Phi]"}, 
               "RowDefault"], 
              TemplateBox[{"\[Theta]", 
                TemplateBox[{
                  Rational[19, 2]}, "Spacer1"], 
                TemplateBox[{
