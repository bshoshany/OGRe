Cell["Here is the Ricci tensor for the FLRW metric:", "Text",ExpressionUUID->"f94281a3-0cad-9045-b2c3-31b732a322f5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TList", "@", 
  RowBox[{"TRicci", "[", "\"\<FLRW\>\"", "]"}]}]], "Input",
 CellLabel->
  "In[164]:=",ExpressionUUID->"6c6a3e1c-b950-f643-a243-f9157d902b84"],

Cell[BoxData[
 StyleBox[
  TagBox[GridBox[{
     {
      TemplateBox[{"\"FLRW->Ricci\"", "\":\""},
       "RowDefault"]},
     {
      TagBox[GridBox[{
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"R\"", 
             TemplateBox[{"t", "t"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{"-", 
           FractionBox[
            RowBox[{"3", " ", 
             TemplateBox[{
               
               TemplateBox[{"\"\[PartialD]\"", "t", "2"}, "Subsuperscript", 
                SyntaxForm -> SubsuperscriptBox], "a"},
              "RowDefault"]}], "a"]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"R\"", 
             TemplateBox[{"r", "r"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          FractionBox[
           RowBox[{
            RowBox[{"a", " ", 
             TemplateBox[{
               
               TemplateBox[{"\"\[PartialD]\"", "t", "2"}, "Subsuperscript", 
                SyntaxForm -> SubsuperscriptBox], "a"},
              "RowDefault"]}], "+", 
            RowBox[{"2", " ", 
             RowBox[{"(", 
              RowBox[{"k", "+", 
               SuperscriptBox[
                TemplateBox[{"\"(\"", 
                  TemplateBox[{
                    SubscriptBox["\"\[PartialD]\"", "t"], "a"}, "RowDefault"],
                   "\")\""},
                 "RowDefault"], "2"]}], ")"}]}]}], 
           RowBox[{"1", "-", 
            RowBox[{"k", " ", 
             SuperscriptBox["r", "2"]}]}]]},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"R\"", 
             TemplateBox[{"\[Theta]", "\[Theta]"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           SuperscriptBox["r", "2"], " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"a", " ", 
              TemplateBox[{
                
                TemplateBox[{"\"\[PartialD]\"", "t", "2"}, "Subsuperscript", 
                 SyntaxForm -> SubsuperscriptBox], "a"},
               "RowDefault"]}], "+", 
             RowBox[{"2", " ", 
              RowBox[{"(", 
               RowBox[{"k", "+", 
                SuperscriptBox[
                 TemplateBox[{"\"(\"", 
                   TemplateBox[{
                    SubscriptBox["\"\[PartialD]\"", "t"], "a"}, "RowDefault"],
                    "\")\""},
                  "RowDefault"], "2"]}], ")"}]}]}], ")"}]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"R\"", 
             TemplateBox[{"\[Phi]", "\[Phi]"}, "RowDefault"]]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           SuperscriptBox["r", "2"], " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"a", " ", 
              TemplateBox[{
                
                TemplateBox[{"\"\[PartialD]\"", "t", "2"}, "Subsuperscript", 
                 SyntaxForm -> SubsuperscriptBox], "a"},
               "RowDefault"]}], "+", 
             RowBox[{"2", " ", 
              RowBox[{"(", 
               RowBox[{"k", "+", 
                SuperscriptBox[
                 TemplateBox[{"\"(\"", 
                   TemplateBox[{
                    SubscriptBox["\"\[PartialD]\"", "t"], "a"}, "RowDefault"],
                    "\")\""},
                  "RowDefault"], "2"]}], ")"}]}]}], ")"}], " ", 
           SuperscriptBox[
            RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}]}
        },
