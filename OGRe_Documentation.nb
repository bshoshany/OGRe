Cell[CellGroupData[{

Cell["The Weyl tensor", "Subsection",ExpressionUUID->"6eb8ed08-1122-2348-966f-613c3ee198fd"],

Cell[TextData[{
 "The ",
 StyleBox["Weyl tensor",
  FontWeight->Bold],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     StyleBox["C", "TI"], "\[Rho]"], 
    SubscriptBox["\[Null]", "\[Sigma]\[Mu]\[Nu]"]}], TraditionalForm]],
  ExpressionUUID->"66c74599-66f0-c24a-ad55-d018474965a4"],
 " is the trace-free part of the Riemann tensor, given by:"
}], "Text",ExpressionUUID->"22662d54-9a38-5f43-b918-abf5df91aca9"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SuperscriptBox[
     StyleBox["C", "TI"], "\[Rho]"], 
    SubscriptBox["\[Null]", "\[Sigma]\[Mu]\[Nu]"], "\[LongEqual]", 
    SuperscriptBox[
     StyleBox["R", "TI"], "\[Rho]"], 
    SubscriptBox["\[Null]", "\[Sigma]\[Mu]\[Nu]"], "-", 
    FractionBox["1", 
     RowBox[{
      StyleBox["n", "TI"], "-", "2"}]], 
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["\[Delta]", "\[Rho]"], 
      SubscriptBox["\[Null]", "\[Mu]"], 
      SubscriptBox[
       StyleBox["R", "TI"], "\[Nu]\[Sigma]"], "-", 
      SuperscriptBox["\[Delta]", "\[Rho]"], 
      SubscriptBox["\[Null]", "\[Nu]"], 
      SubscriptBox[
       StyleBox["R", "TI"], "\[Mu]\[Sigma]"], "-", 
      SubscriptBox[
       StyleBox["g", "TI"], "\[Sigma]\[Mu]"], 
      SuperscriptBox[
       StyleBox["R", "TI"], "\[Rho]"], 
      SubscriptBox["\[Null]", "\[Nu]"], "+", 
      SubscriptBox[
       StyleBox["g", "TI"], "\[Sigma]\[Nu]"], 
      SuperscriptBox[
       StyleBox["R", "TI"], "\[Rho]"], 
      SubscriptBox["\[Null]", "\[Mu]"]}], ")"}], "+", 
    FractionBox[
     StyleBox["R", "TI"], 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        StyleBox["n", "TI"], "-", "1"}], ")"}], "(", 
      RowBox[{
       StyleBox["n", "TI"], "-", "2"}], ")"}]], 
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["\[Delta]", "\[Rho]"], 
      SubscriptBox["\[Null]", "\[Mu]"], 
      SubscriptBox[
       StyleBox["g", "TI"], "\[Nu]\[Sigma]"], "-", 
      SuperscriptBox["\[Delta]", "\[Rho]"], 
      SubscriptBox["\[Null]", "\[Nu]"], 
      SubscriptBox[
       StyleBox["g", "TI"], "\[Mu]\[Sigma]"]}], ")"}]}], ","}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"767f6247-ffb5-104c-\
affa-d3b2a95563c2"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   StyleBox["n", "TI"], TraditionalForm]],ExpressionUUID->
  "f2e28943-59f1-b449-83d8-27a8a72c7e93"],
 " is the dimension. In dimensions ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["n", "TI"], "\[LessEqual]", "3"}], TraditionalForm]],
  ExpressionUUID->"ea41f3c5-fecd-0a40-9ac5-cf561640527c"],
 ", the Weyl tensor vanishes identically. We can calculate it in OGRe using \
the built-in module ",
 StyleBox["TWeyl", "Input"],
 ":"
}], "Text",ExpressionUUID->"621149b9-da0e-9246-b4d7-5da625515a54"],

