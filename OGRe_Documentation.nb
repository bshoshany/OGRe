StyleBox[\"tensorID\", Bold, Rule[StripOnInput, False]], \"] calculates the \
norm-squared of the tensor \", StyleBox[\"tensorID\", Bold, \
Rule[StripOnInput, False]], \" with respect to its metric, that is, the \
tensor contracted with itself in all indices. For example, for a vector v^a \
the norm-squared will be v^a v_a and for a rank-2 tensor T^ab the result will \
be T^ab T_ab.\\nTNormSquared[\", StyleBox[\"tensorID\", Bold, \
Rule[StripOnInput, False]], \", \", StyleBox[\"coordinatesID\", Bold, \
Rule[StripOnInput, False]], \"] calculates the norm-squared in the coordinate \
system \", StyleBox[\"coordinatesID\", Bold, Rule[StripOnInput, False]], \
\".\"}]], TextCell[Row[List[\"TNormSquared[\", Style[\"tensorID\", Bold], \"] \
calculates the norm-squared of the tensor \", Style[\"tensorID\", Bold], \" \
with respect to its metric, that is, the tensor contracted with itself in all \
indices. For example, for a vector v^a the norm-squared will be v^a v_a and \
for a rank-2 tensor T^ab the result will be T^ab T_ab.\\nTNormSquared[\", \
Style[\"tensorID\", Bold], \", \", Style[\"coordinatesID\", Bold], \"] \
calculates the norm-squared in the coordinate system \", \
Style[\"coordinatesID\", Bold], \".\"]]]]\)", "Documentation" -> None, 
    "OwnValues" -> None, "UpValues" -> None, "DownValues" -> 
    Information`InformationValueForm[
     DownValues, OGRe`TNormSquared, {OGRe`TNormSquared[
         Pattern[OGRe`Private`tensorID, 
          Blank[String]], 
         Optional[
          Pattern[OGRe`Private`coordinatesID, 
           Blank[String]], "_UseDefault_"]] :> 
       Module[{OGRe`Private`components, OGRe`Private`normSquared, 
          OGRe`Private`rank, OGRe`Private`secondComponents, 
          OGRe`Private`useCoords, OGRe`Private`useIndices, OGRe`Private`vars},
          OGRe`Private`CheckIfTensorExists[OGRe`Private`tensorID]; 
         If[OGRe`Private`coordinatesID === "_UseDefault_", 
           OGRe`Private`useCoords = 
           OGRe`Private`GetTensorData[OGRe`Private`tensorID]["DefaultCoords"],
            OGRe`Private`CheckIfTensorExists[OGRe`Private`coordinatesID]; 
           OGRe`Private`CheckIfCoordinates[OGRe`Private`coordinatesID]; 
           OGRe`Private`useCoords = OGRe`Private`coordinatesID; Null]; 
         OGRe`Private`useIndices = 
          OGRe`Private`GetTensorData[OGRe`Private`tensorID]["DefaultIndices"]; 
         OGRe`Private`rank = Length[OGRe`Private`useIndices]; 
         OGRe`Private`components = 
          OGRe`Private`AddRepresentation[
           OGRe`Private`tensorID, OGRe`Private`useIndices, 
            OGRe`Private`useCoords]; 
         If[OGRe`Private`rank == 0, OGRe`Private`normSquared = 
           Part[OGRe`Private`components, 1]^2, 
           OGRe`Private`secondComponents = 
            OGRe`Private`AddRepresentation[
             OGRe`Private`tensorID, -OGRe`Private`useIndices, 
              OGRe`Private`useCoords]; OGRe`Private`vars = Unique[
              Table["var", {OGRe`Private`rank}]]; 
           OGRe`Private`normSquared = Sum[Part[OGRe`Private`components, 
                Apply[Sequence, OGRe`Private`vars]] 
              Part[OGRe`Private`secondComponents, 
                Apply[Sequence, OGRe`Private`vars]], 
              Evaluate[
               Apply[Sequence, 
                Map[{#, 1, 
                  Length[OGRe`Private`components]}& , OGRe`Private`vars]]]]; 
           Null]; If[
           OGRe`Private`CurveParameterTensorQ[OGRe`Private`tensorID], 
           OGRe`Private`normSquared = 
            ReplaceAll[OGRe`Private`normSquared, OGRe`$CurveParam -> Symbol[
                OGRe`Private`TensorData[Options]["CurveParameter"]]]; Null]; 
         Return[
           OGRe`Private`TensorSimplify[OGRe`Private`normSquared]]; Null]}], 
    "SubValues" -> None, "DefaultValues" -> 
    Information`InformationValueForm[
     DefaultValues, OGRe`TNormSquared, {
      SyntaxInformation[OGRe`TNormSquared] -> {"ArgumentsPattern" -> {
