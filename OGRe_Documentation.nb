           "RowWithSeparators"], "\<\"=\"\>", 
          FractionBox["M", 
           RowBox[{"r", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"-", "2"}], " ", "M"}], "+", "r"}], ")"}]}]]},
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"\[CapitalGamma]\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"], "t", "t"}, "RowDefault"], 
              TemplateBox[{"r", 
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"], 
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", 
          FractionBox[
           RowBox[{"M", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"-", "2"}], " ", "M"}], "+", "r"}], ")"}]}], 
           SuperscriptBox["r", "3"]]},
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"\[CapitalGamma]\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"], "\[Theta]", "\[Theta]"}, 
               "RowDefault"], 
              TemplateBox[{"r", 
                TemplateBox[{
                  Rational[17, 2]}, "Spacer1"], 
                TemplateBox[{
                  Rational[17, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           RowBox[{"2", " ", "M"}], "-", "r"}]},
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"\[CapitalGamma]\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"], "\[Phi]", "\[Phi]"}, 
               "RowDefault"], 
              TemplateBox[{"r", 
                TemplateBox[{
                  Rational[19, 2]}, "Spacer1"], 
                TemplateBox[{
                  Rational[19, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"2", " ", "M"}], "-", "r"}], ")"}], " ", 
           SuperscriptBox[
            RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"\[CapitalGamma]\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[17, 2]}, "Spacer1"], "r", "\[Theta]"}, 
               "RowDefault"], 
              TemplateBox[{"\[Theta]", 
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"], 
                TemplateBox[{
                  Rational[17, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
            TemplateBox[{"\"\[CapitalGamma]\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[17, 2]}, "Spacer1"], "\[Theta]", "r"}, 
               "RowDefault"], 
              TemplateBox[{"\[Theta]", 
                TemplateBox[{
                  Rational[17, 2]}, "Spacer1"], 
                TemplateBox[{
                  Rational[11, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
