Cell[CellGroupData[{

Cell["The Riemann tensor", "Subsection",ExpressionUUID->"6ca949f9-f6a2-e646-a3bd-522c1484d7f4"],

Cell[TextData[{
 "The ",
 StyleBox["Riemann curvature tensor",
  FontWeight->Bold],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     StyleBox["R", "TI"], "\[Rho]"], 
    SubscriptBox["\[Null]", "\[Sigma]\[Mu]\[Nu]"]}], TraditionalForm]],
  ExpressionUUID->"833f80a7-98a2-2643-b355-a285836d16c7"],
 " can be calculated from the Christoffel symbols using the definition:"
}], "Text",ExpressionUUID->"50d08e94-c2c2-ff41-befd-059992b7138f"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SuperscriptBox[
     StyleBox["R", "TI"], "\[Rho]"], 
    SubscriptBox["\[Null]", "\[Sigma]\[Mu]\[Nu]"], "\[LongEqual]", 
    SubscriptBox["\[PartialD]", "\[Mu]"], 
    SubsuperscriptBox["\[CapitalGamma]", "\[Nu]\[Sigma]", "\[Rho]"], "-", 
    SubscriptBox["\[PartialD]", "\[Nu]"], 
    SubsuperscriptBox["\[CapitalGamma]", "\[Mu]\[Sigma]", "\[Rho]"], "+", 
    SubsuperscriptBox["\[CapitalGamma]", "\[Mu]\[Lambda]", "\[Rho]"], 
    SubsuperscriptBox["\[CapitalGamma]", "\[Nu]\[Sigma]", "\[Lambda]"], "-", 
    SubsuperscriptBox["\[CapitalGamma]", "\[Nu]\[Lambda]", "\[Rho]"], 
    SubsuperscriptBox["\[CapitalGamma]", "\[Mu]\[Sigma]", "\[Lambda]"]}], 
   "."}], TraditionalForm]], "DisplayFormula",ExpressionUUID->"e3164907-5a9b-\
474a-9082-3ccdeb17947d"],

Cell[TextData[{
 "Even though it contains partial derivatives, it nonetheless transforms like \
a tensor under a change of coordinates, because the extra transformation \
terms exactly cancel each other. To calculate this tensor, we can simply \
write down the formula in ",
 StyleBox["TCalc", "Input"],
 " with the correct indices contracted. Note that this time we specified the \
LHS indices explicitly, since they are not in the same order as the RHS \
indices in our definition:"
}], "Text",ExpressionUUID->"22665cad-36e1-df48-97ae-bde9659685fb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TList", "@", 
  RowBox[{"TChangeDefaultIndices", "[", 
   RowBox[{
    RowBox[{"TCalc", "[", 
     RowBox[{
      RowBox[{"\"\<SchwarzschildManualRiemann\>\"", 
       "[", "\"\<\[Rho]\[Sigma]\[Mu]\[Nu]\>\"", "]"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"TPartialD", "[", "\"\<\[Mu]\>\"", "]"}], ".", 
        RowBox[{
         RowBox[{"TChristoffel", "[", "\"\<Schwarzschild\>\"", "]"}], 
         "[", "\"\<\[Rho]\[Nu]\[Sigma]\>\"", "]"}]}], "-", 
       RowBox[{
        RowBox[{"TPartialD", "[", "\"\<\[Nu]\>\"", "]"}], ".", 
        RowBox[{
         RowBox[{"TChristoffel", "[", "\"\<Schwarzschild\>\"", "]"}], 
         "[", "\"\<\[Rho]\[Mu]\[Sigma]\>\"", "]"}]}], "+", 
       RowBox[{
        RowBox[{
         RowBox[{"TChristoffel", "[", "\"\<Schwarzschild\>\"", "]"}], 
         "[", "\"\<\[Rho]\[Mu]\[Lambda]\>\"", "]"}], ".", 
        RowBox[{
         RowBox[{"TChristoffel", "[", "\"\<Schwarzschild\>\"", "]"}], 
         "[", "\"\<\[Lambda]\[Nu]\[Sigma]\>\"", "]"}]}], "-", 
       RowBox[{
        RowBox[{
         RowBox[{"TChristoffel", "[", "\"\<Schwarzschild\>\"", "]"}], 
         "[", "\"\<\[Rho]\[Nu]\[Lambda]\>\"", "]"}], ".", 
        RowBox[{
         RowBox[{"TChristoffel", "[", "\"\<Schwarzschild\>\"", "]"}], 
         "[", "\"\<\[Lambda]\[Mu]\[Sigma]\>\"", "]"}]}]}], ",", "\"\<R\>\""}],
      "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"1", ",", 
      RowBox[{"-", "1"}], ",", 
      RowBox[{"-", "1"}], ",", 
      RowBox[{"-", "1"}]}], "}"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[158]:=",ExpressionUUID->"e9370008-59f9-4d45-a426-8a86665f1f6c"],

