Cell[TextData[{
 "First let us save the current state of ",
 StyleBox["TSetAllowOverwrite", "Input"],
 ":"
}], "Text",ExpressionUUID->"aefd7f87-f60e-e940-b658-53d86f83f399"],

Cell[BoxData[
 RowBox[{
  RowBox[{"currentOverwrite", "=", 
   RowBox[{"TSetAllowOverwrite", "[", "]"}]}], ";"}]], "Input",
 CellLabel->"In[64]:=",ExpressionUUID->"f14ea2be-b1e0-ef49-8aa9-f6e751d1460b"],

Cell["Next, we turn it off:", "Text",ExpressionUUID->"9801b22e-590a-9043-b2a6-74577ba6e99d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TSetAllowOverwrite", "[", "False", "]"}]], "Input",
 CellLabel->"In[65]:=",ExpressionUUID->"8ffe2ac7-44f9-0344-8348-f03a120812d2"],

Cell[BoxData[
 TemplateBox[{
  "TSetAllowOverwrite", "Notify", 
   "\"Overwriting tensors turned \
\\!\\(\\*RowBox[{\\\"\\\\\\\"off\\\\\\\"\\\"}]\\).\"", 2, 65, 5, 
   30274037233204585468, "Local", "OGRe`TSetAllowOverwrite"},
  "MessageTemplate2",
  BaseStyle->"MSG"]], "Message",
 CellLabel->
  "During evaluation of \
In[65]:=",ExpressionUUID->"5e55613e-f120-9140-8a62-48e895bf3f54"]
}, Open  ]],

Cell["Overwriting the tensor is now forbidden:", "Text",ExpressionUUID->"3e421eeb-63e9-2b42-83c5-cddbcfec46a2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TNewTensor", "[", 
  RowBox[{"\"\<4-Velocity\>\"", ",", "\"\<Minkowski\>\"", 
   ",", "\"\<Cartesian\>\"", ",", 
   RowBox[{"{", "1", "}"}], ",", 
   FractionBox[
    RowBox[{"{", 
     RowBox[{"1", ",", "v", ",", "0", ",", "0"}], "}"}], 
    SqrtBox[
     RowBox[{"1", "-", 
      SuperscriptBox["v", "2"]}]]], ",", "\"\<v\>\""}], "]"}]], "Input",
 CellLabel->"In[66]:=",ExpressionUUID->"310abf8e-5568-1d4d-92d1-246b05f2d7c1"],

Cell[BoxData[
 TemplateBox[{
  "TMessage", "ErrorOverwrite", 
   "\"A tensor with the ID \
\\\"\\!\\(\\*RowBox[{\\\"\\\\\\\"4-Velocity\\\\\\\"\\\"}]\\)\\\" already \
exists. Please rename it using TChangeID[] or delete it using TDelete[] \
first. Type TSetAllowOverwrite[True] to allow overwriting tensors.\"", 2, 66, 
   6, 30274037233204585468, "Local", "OGRe`TMessage"},
  "MessageTemplate2",
