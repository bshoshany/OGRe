Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TList", "@", 
  RowBox[{
  "TGeodesicFromChristoffel", "[", "\"\<Alcubierre\>\"", "]"}]}]], "Input",
 CellLabel->
  "In[218]:=",ExpressionUUID->"943877db-ea45-2545-b86c-5af0359381b7"],

Cell[BoxData[
 StyleBox[
  TagBox[GridBox[{
     {
      TemplateBox[{"\"Alcubierre->GeodesicFromChristoffel\"", "\":\""},
       "RowDefault"]},
     {
      TagBox[GridBox[{
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"0\"", 
              TemplateBox[{"t"}, "RowDefault"]}, "Superscript", SyntaxForm -> 
             SuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           OverscriptBox["t", "\[DoubleDot]"], "+", 
           RowBox[{"v", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"f", " ", "v", " ", 
               OverscriptBox["t", "."]}], "-", 
              OverscriptBox["z", "."]}], ")"}], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"-", 
                OverscriptBox["x", "."]}], " ", 
               TemplateBox[{
                 SubscriptBox["\"\[PartialD]\"", "x"], "f"},
                "RowDefault"]}], "-", 
              RowBox[{
               OverscriptBox["y", "."], " ", 
               TemplateBox[{
                 SubscriptBox["\"\[PartialD]\"", "y"], "f"},
                "RowDefault"]}], "+", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"f", " ", "v", " ", 
                  OverscriptBox["t", "."]}], "-", 
                 OverscriptBox["z", "."]}], ")"}], " ", 
               TemplateBox[{
                 SubscriptBox["\"\[PartialD]\"", "z"], "f"},
                "RowDefault"]}]}], ")"}]}]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"0\"", 
              TemplateBox[{"x"}, "RowDefault"]}, "Superscript", SyntaxForm -> 
             SuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           OverscriptBox["x", "\[DoubleDot]"], "+", 
           RowBox[{"v", " ", 
            OverscriptBox["t", "."], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"-", "f"}], " ", "v", " ", 
               OverscriptBox["t", "."]}], "+", 
              OverscriptBox["z", "."]}], ")"}], " ", 
            TemplateBox[{
              SubscriptBox["\"\[PartialD]\"", "x"], "f"},
             "RowDefault"]}]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"0\"", 
              TemplateBox[{"y"}, "RowDefault"]}, "Superscript", SyntaxForm -> 
             SuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           OverscriptBox["y", "\[DoubleDot]"], "+", 
           RowBox[{"v", " ", 
            OverscriptBox["t", "."], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"-", "f"}], " ", "v", " ", 
               OverscriptBox["t", "."]}], "+", 
              OverscriptBox["z", "."]}], ")"}], " ", 
            TemplateBox[{
              SubscriptBox["\"\[PartialD]\"", "y"], "f"},
             "RowDefault"]}]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"0\"", 
              TemplateBox[{"z"}, "RowDefault"]}, "Superscript", SyntaxForm -> 
             SuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           OverscriptBox["z", "\[DoubleDot]"], "-", 
           RowBox[{"v", " ", 
            OverscriptBox["t", "."], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               OverscriptBox["t", "."], " ", 
               TemplateBox[{
                 SubscriptBox["\"\[PartialD]\"", "t"], "f"},
                "RowDefault"]}], "+", 
              RowBox[{
               OverscriptBox["x", "."], " ", 
               TemplateBox[{
                 SubscriptBox["\"\[PartialD]\"", "x"], "f"},
                "RowDefault"]}], "+", 
              RowBox[{
               OverscriptBox["y", "."], " ", 
               TemplateBox[{
                 SubscriptBox["\"\[PartialD]\"", "y"], "f"},
                "RowDefault"]}]}], ")"}]}], "+", 
           RowBox[{
            SuperscriptBox["f", "3"], " ", 
            SuperscriptBox["v", "4"], " ", 
            SuperscriptBox[
             OverscriptBox["t", "."], "2"], " ", 
            TemplateBox[{
              SubscriptBox["\"\[PartialD]\"", "z"], "f"},
             "RowDefault"]}], "-", 
           RowBox[{
            SuperscriptBox["f", "2"], " ", 
            SuperscriptBox["v", "3"], " ", 
            OverscriptBox["t", "."], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               OverscriptBox["x", "."], " ", 
               TemplateBox[{
                 SubscriptBox["\"\[PartialD]\"", "x"], "f"},
                "RowDefault"]}], "+", 
              RowBox[{
               OverscriptBox["y", "."], " ", 
               TemplateBox[{
                 SubscriptBox["\"\[PartialD]\"", "y"], "f"},
                "RowDefault"]}], "+", 
              RowBox[{"2", " ", 
               OverscriptBox["z", "."], " ", 
               TemplateBox[{
                 SubscriptBox["\"\[PartialD]\"", "z"], "f"},
                "RowDefault"]}]}], ")"}]}], "+", 
           RowBox[{"f", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"-", 
                SuperscriptBox[
                 OverscriptBox["t", "."], "2"]}], " ", 
               RowBox[{"(", 
                RowBox[{
                 TemplateBox[{
                   SubscriptBox["\"\[PartialD]\"", "t"], "v"},
                  "RowDefault"], "+", 
                 RowBox[{
                  SuperscriptBox["v", "2"], " ", 
                  TemplateBox[{
                    SubscriptBox["\"\[PartialD]\"", "z"], "f"},
                   "RowDefault"]}]}], ")"}]}], "+", 
              RowBox[{
               SuperscriptBox["v", "2"], " ", 
               OverscriptBox["z", "."], " ", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{
                  OverscriptBox["x", "."], " ", 
                  TemplateBox[{
                    SubscriptBox["\"\[PartialD]\"", "x"], "f"},
                   "RowDefault"]}], "+", 
                 RowBox[{
                  OverscriptBox["y", "."], " ", 
                  TemplateBox[{
                    SubscriptBox["\"\[PartialD]\"", "y"], "f"},
                   "RowDefault"]}], "+", 
                 RowBox[{
                  OverscriptBox["z", "."], " ", 
                  TemplateBox[{
                    SubscriptBox["\"\[PartialD]\"", "z"], "f"},
                   "RowDefault"]}]}], ")"}]}]}], ")"}]}]}]}
        },
        AutoDelete->False,
        GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
        GridBoxItemSize->{
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
       "Grid"]}
    },
    DefaultBaseStyle->"Column",
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
   "Column"], "DisplayFormula",
  StripOnInput->False]], "Output",
