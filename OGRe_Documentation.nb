              TemplateBox[{
                TemplateBox[{
                  Rational[19, 2]}, "Spacer1"], "\[Theta]", "\[Phi]"}, 
               "RowDefault"], 
              TemplateBox[{"\[Phi]", 
                TemplateBox[{
                  Rational[17, 2]}, "Spacer1"], 
                TemplateBox[{
                  Rational[19, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
            TemplateBox[{"\"\[CapitalGamma]\"", 
              TemplateBox[{
                TemplateBox[{
                  Rational[19, 2]}, "Spacer1"], "\[Phi]", "\[Theta]"}, 
               "RowDefault"], 
              TemplateBox[{"\[Phi]", 
                TemplateBox[{
                  Rational[19, 2]}, "Spacer1"], 
                TemplateBox[{
                  Rational[17, 2]}, "Spacer1"]}, "RowDefault"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox]},
