Cell[CellGroupData[{

Cell["Getting information about tensors", "Subsection",ExpressionUUID->"e4af0f1d-8ae6-d648-9540-ee2f310cea37"],

Cell[TextData[{
 "The ",
 StyleBox["TInfo", "Input"],
 " module can be used to display information about any tensor object, \
including its symbol, role, rank, dimensions, associated metric, and default \
coordinates and indices:"
}], "Text",ExpressionUUID->"e6436703-657c-714c-9bbd-a7eaa883a89f"],

