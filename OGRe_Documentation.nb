  FormBox[
   SubscriptBox[
    StyleBox["g", "TI"], "\[Mu]\[Nu]"], TraditionalForm]],ExpressionUUID->
  "a0a246fb-5d24-d54a-a11d-13a37591c959"],
 " is defined as"
}], "Text",ExpressionUUID->"63d9692f-ede1-6840-b46c-9daa89414011"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SuperscriptBox[
     RowBox[{
      StyleBox["d",
       FontSlant->"Plain"], 
      StyleBox["s", "TI"]}], "2"], "\[LongEqual]", 
    SubscriptBox[
     StyleBox["g", "TI"], "\[Mu]\[Nu]"], 
    SuperscriptBox[
     RowBox[{
      StyleBox["d",
       FontSlant->"Plain"], 
      StyleBox["x", "TI"]}], "\[Mu]"], 
    SuperscriptBox[
     RowBox[{
      StyleBox["d",
       FontSlant->"Plain"], 
      StyleBox["x", "TI"]}], "\[Nu]"]}], "."}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"80aa9875-d23e-3f44-\
88ba-7418fbc32728"],

