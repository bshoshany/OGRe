}, Open  ]],

Cell["For example:", "Text",ExpressionUUID->"dca07073-7ef4-784b-a359-3b1fcddaf045"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TLineElement", "[", "\"\<Minkowski\>\"", "]"}]], "Input",
 CellLabel->"In[28]:=",ExpressionUUID->"a5689061-9433-cf49-8def-f4ea28e1fe1c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", 
   SuperscriptBox["\[DoubleStruckD]t", "2"]}], "+", 
  SuperscriptBox["\[DoubleStruckD]x", "2"], "+", 
  SuperscriptBox["\[DoubleStruckD]y", "2"], "+", 
  SuperscriptBox["\[DoubleStruckD]z", "2"]}]], "Output",
 CellLabel->"Out[28]=",ExpressionUUID->"5af34714-2b27-104c-8868-b29dc7923c9b"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TLineElement", "[", "\"\<Schwarzschild\>\"", "]"}]], "Input",
 CellLabel->"In[29]:=",ExpressionUUID->"8f152cfc-d555-8148-9b6e-882246a99c99"],

Cell[BoxData[
 RowBox[{
  FractionBox[
   SuperscriptBox["\[DoubleStruckD]r", "2"], 
   RowBox[{"1", "-", 
    FractionBox[
     RowBox[{"2", " ", "M"}], "r"]}]], "+", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "1"}], "+", 
     FractionBox[
      RowBox[{"2", " ", "M"}], "r"]}], ")"}], " ", 
   SuperscriptBox["\[DoubleStruckD]t", "2"]}], "+", 
  RowBox[{
   SuperscriptBox["r", "2"], " ", 
   SuperscriptBox["\[DoubleStruckD]\[Theta]", "2"]}], "+", 
  RowBox[{
   SuperscriptBox["r", "2"], " ", 
   SuperscriptBox["\[DoubleStruckD]\[Phi]", "2"], " ", 
   SuperscriptBox[
    RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}]}]], "Output",
 CellLabel->"Out[29]=",ExpressionUUID->"afe9da25-4e70-c648-b94f-0c53a66d667b"]
}, Open  ]],

Cell[TextData[{
 "Note that these are standard Mathematica expressions, so they can be \
manipulated like any other expressions, including operations such as \
simplifying or factoring. As an example of a more interesting (non-diagonal) \
line element, consider the ",
 StyleBox["Alcubierre warp drive metric",
  FontWeight->Bold],
 ":"
}], "Text",ExpressionUUID->"9d907c27-9c2f-7a44-a7be-4faf2f73f82b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"TSetReservedSymbols", "[", 
   RowBox[{"{", 
    RowBox[{"v", ",", "f"}], "}"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"TNewMetric", "[", 
   RowBox[{"\"\<Alcubierre\>\"", ",", "\"\<Cartesian\>\"", ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "1"}], "+", 
         RowBox[{
          SuperscriptBox[
           RowBox[{"v", "[", "t", "]"}], "2"], " ", 
          SuperscriptBox[
           RowBox[{"f", "[", 
            RowBox[{"t", ",", "x", ",", "y", ",", "z"}], "]"}], "2"]}]}], ",",
         "0", ",", "0", ",", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"v", "[", "t", "]"}]}], " ", 
         RowBox[{"f", "[", 
          RowBox[{"t", ",", "x", ",", "y", ",", "z"}], "]"}]}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "1", ",", "0", ",", "0"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0", ",", "1", ",", "0"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"-", 
          RowBox[{"v", "[", "t", "]"}]}], " ", 
         RowBox[{"f", "[", 
          RowBox[{"t", ",", "x", ",", "y", ",", "z"}], "]"}]}], ",", "0", ",",
         "0", ",", "1"}], "}"}]}], "}"}]}], "]"}], ";"}]}], "Input",
 CellLabel->"In[30]:=",ExpressionUUID->"17db3ff6-bf2e-7844-a292-1d4a1065afe1"],

Cell["This is what the metric looks like in matrix form:", "Text",ExpressionUUID->"76fb0989-e852-cc4f-8390-b57c0bbb0845"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TShow", "[", "\"\<Alcubierre\>\"", "]"}]], "Input",
 CellLabel->"In[32]:=",ExpressionUUID->"e93f79b2-214a-b149-a604-3ce927f1fcdb"],

Cell[BoxData[
 StyleBox[
  TemplateBox[{"\"Alcubierre\"", "\":   \"", 
    SubscriptBox["\"g\"", 
     TemplateBox[{"\"\[Mu]\"", "\"\[Nu]\""}, "RowDefault"]], "\"(\"", 
    TemplateBox[{",", "\",\"", "t", "x", "y", "z"}, "RowWithSeparators"], 
    "\")\"", "\" = \"", 
    TagBox[
     RowBox[{"(", "\[NoBreak]", 
       GridBox[{{
          RowBox[{
            RowBox[{"-", "1"}], "+", 
            RowBox[{
              SuperscriptBox["f", "2"], " ", 
              SuperscriptBox["v", "2"]}]}], "0", "0", 
          RowBox[{
            RowBox[{"-", "f"}], " ", "v"}]}, {"0", "1", "0", "0"}, {
         "0", "0", "1", "0"}, {
          RowBox[{
            RowBox[{"-", "f"}], " ", "v"}], "0", "0", "1"}}, RowSpacings -> 1,
         ColumnSpacings -> 1, RowAlignments -> Baseline, ColumnAlignments -> 
        Center], "\[NoBreak]", ")"}], 
     Function[BoxForm`e$, 
      MatrixForm[BoxForm`e$]]]},
   "RowDefault"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"384e0fa7-ba75-3a4d-9d33-42b6d29f848d"]
}, Open  ]],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   StyleBox["f", "TI"], TraditionalForm]],ExpressionUUID->
  "68829451-6950-4a44-b6d4-b1c96def54fd"],
 " is a ",
 StyleBox["form function",
  FontWeight->Bold],
 " which is equal to 1 inside a \"warp bubble\" of finite radius and 0 \
outside it, and ",
 Cell[BoxData[
  FormBox[
   StyleBox["v", "TI"], TraditionalForm]],ExpressionUUID->
  "c819fa32-0a89-bf4b-b297-37c9da8dc343"],
 " is the velocity of the bubble, which can be faster than the speed of light \
(",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["v", "TI"], ">", "1"}], TraditionalForm]],ExpressionUUID->
  "150d08f6-5228-954b-96f2-4f2992a76291"],
 "). Note that we reserved both ",
 Cell[BoxData[
  FormBox[
   StyleBox["v", "TI"], TraditionalForm]],ExpressionUUID->
  "dd77c283-7925-5645-bf59-cca9a4fb7104"],
 " and ",
 Cell[BoxData[
  FormBox[
   StyleBox["f", "TI"], TraditionalForm]],ExpressionUUID->
  "f9c6baa2-9111-c74a-b59f-b687d5021b18"],
 ", since they are parameters used in the metric. Here we see another \
advantage of reserving symbols: since ",
 StyleBox["v", "Input"],
 " and ",
 StyleBox["f", "Input"],
 " are reserved symbols, and they are functions of the coordinates only, \
their arguments are not shown when using ",
 StyleBox["TShow", "Input"],
 " and ",
 StyleBox["TList", "Input"],
 ", for improved readability."
}], "Text",ExpressionUUID->"76ce1c15-d100-5b43-bdcf-030d713f5d6d"],

Cell[TextData[{
 "It is easy to see that the metric is flat where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["f", "TI"], "\[LongEqual]", "0"}], TraditionalForm]],
  ExpressionUUID->"c7cb91f4-1ef7-484a-8191-26610b32ac1f"],
 ", that is, outside the bubble. Its line element is:"
}], "Text",ExpressionUUID->"ec7b1b2c-6f22-bc41-bebd-392109e66cba"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"lineElement", "=", 
  RowBox[{"TLineElement", "[", "\"\<Alcubierre\>\"", "]"}]}]], "Input",
 CellLabel->"In[33]:=",ExpressionUUID->"ca834351-f976-9a47-8488-20989687d2d0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", 
   SuperscriptBox["\[DoubleStruckD]t", "2"]}], "+", 
  SuperscriptBox["\[DoubleStruckD]x", "2"], "+", 
  SuperscriptBox["\[DoubleStruckD]y", "2"], "+", 
  SuperscriptBox["\[DoubleStruckD]z", "2"], "+", 
  RowBox[{"\[DoubleStruckD]t", " ", 
   RowBox[{"f", "[", 
    RowBox[{"t", ",", "x", ",", "y", ",", "z"}], "]"}], " ", 
   RowBox[{"v", "[", "t", "]"}], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "2"}], " ", "\[DoubleStruckD]z"}], "+", 
     RowBox[{"\[DoubleStruckD]t", " ", 
      RowBox[{"f", "[", 
       RowBox[{"t", ",", "x", ",", "y", ",", "z"}], "]"}], " ", 
      RowBox[{"v", "[", "t", "]"}]}]}], ")"}]}]}]], "Output",
 CellLabel->"Out[33]=",ExpressionUUID->"e4b8f7ff-49b4-9448-a40a-9d97e78d6d90"]
}, Open  ]],

Cell["We can simplify it by doing some clever factorization:", "Text",ExpressionUUID->"8dd0c5b6-6374-e846-b445-bc8a60fe37db"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"lineElement", "=", 
  RowBox[{"lineElement", "//", "Expand", "//", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"#1", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], "+", 
      RowBox[{"#1", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], "+", 
      RowBox[{"#1", "\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}], "+", 
      RowBox[{"Factor", "[", 
       RowBox[{
        RowBox[{"#1", "\[LeftDoubleBracket]", "4", "\[RightDoubleBracket]"}], 
        "+", 
        RowBox[{"#1", "\[LeftDoubleBracket]", "5", "\[RightDoubleBracket]"}], 
        "+", 
        RowBox[{
        "#1", "\[LeftDoubleBracket]", "6", "\[RightDoubleBracket]"}]}], 
       "]"}]}], ")"}], "&"}]}]}]], "Input",
 CellLabel->"In[34]:=",ExpressionUUID->"26418c3f-d85e-244b-8373-0fe721ca55c9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", 
   SuperscriptBox["\[DoubleStruckD]t", "2"]}], "+", 
  SuperscriptBox["\[DoubleStruckD]x", "2"], "+", 
  SuperscriptBox["\[DoubleStruckD]y", "2"], "+", 
  SuperscriptBox[
   RowBox[{"(", 
    RowBox[{"\[DoubleStruckD]z", "-", 
     RowBox[{"\[DoubleStruckD]t", " ", 
      RowBox[{"f", "[", 
       RowBox[{"t", ",", "x", ",", "y", ",", "z"}], "]"}], " ", 
      RowBox[{"v", "[", "t", "]"}]}]}], ")"}], "2"]}]], "Output",
 CellLabel->"Out[34]=",ExpressionUUID->"41be9e70-ab3a-494d-a994-90a97878428f"]
}, Open  ]],

Cell[TextData[{
 "In this form, it is immediately clear that the metric is flat outside the \
warp bubble (where ",
 Cell[BoxData[
  FormBox[
   StyleBox["f", "TI"], TraditionalForm]],ExpressionUUID->
  "f03b16c0-0ed9-4a4f-b3db-486273f208e6"],
 " is 0), and inside the warp bubble (when ",
 Cell[BoxData[
  FormBox[
   StyleBox["f", "TI"], TraditionalForm]],ExpressionUUID->
  "f02e1cae-ba33-6d40-8b49-bfaf083cf1f9"],
 " is 1) it is a flat metric translated by an amount ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["v", "TI"], 
    RowBox[{"(", 
     StyleBox["t", "TI"], ")"}], " ", 
    StyleBox["d",
     FontSlant->"Plain"], 
    StyleBox["t", "TI"]}], TraditionalForm]],ExpressionUUID->
  "d7630a1f-adfb-844b-b74d-ec84e8d2d992"],
 " in the ",
 Cell[BoxData[
  FormBox[
   StyleBox["z", "TI"], TraditionalForm]],ExpressionUUID->
  "9eef132c-98b0-e640-940a-65748e6103ab"],
 " direction:"
}], "Text",ExpressionUUID->"ba6bc26a-9fe6-7f47-a685-67f7223bd05d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"lineElement", "/.", "\[VeryThinSpace]", 
  RowBox[{"f", "\[Rule]", 
   RowBox[{"(", 
    RowBox[{"0", "&"}], ")"}]}]}]], "Input",
 CellLabel->"In[35]:=",ExpressionUUID->"1369cf00-e8cc-f448-800e-410323a90a00"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", 
   SuperscriptBox["\[DoubleStruckD]t", "2"]}], "+", 
  SuperscriptBox["\[DoubleStruckD]x", "2"], "+", 
  SuperscriptBox["\[DoubleStruckD]y", "2"], "+", 
  SuperscriptBox["\[DoubleStruckD]z", "2"]}]], "Output",
 CellLabel->"Out[35]=",ExpressionUUID->"84b820cc-22ab-da49-a144-a7aa317eba8d"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"lineElement", "/.", "\[VeryThinSpace]", 
  RowBox[{"f", "\[Rule]", 
   RowBox[{"(", 
    RowBox[{"1", "&"}], ")"}]}]}]], "Input",
 CellLabel->"In[36]:=",ExpressionUUID->"951ccd52-4008-c74a-a499-2991fcd1e6f2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", 
   SuperscriptBox["\[DoubleStruckD]t", "2"]}], "+", 
  SuperscriptBox["\[DoubleStruckD]x", "2"], "+", 
  SuperscriptBox["\[DoubleStruckD]y", "2"], "+", 
  SuperscriptBox[
   RowBox[{"(", 
    RowBox[{"\[DoubleStruckD]z", "-", 
     RowBox[{"\[DoubleStruckD]t", " ", 
      RowBox[{"v", "[", "t", "]"}]}]}], ")"}], "2"]}]], "Output",
 CellLabel->"Out[36]=",ExpressionUUID->"76082818-1b71-3840-a29b-22145f5d8741"]
}, Open  ]],

Cell[TextData[{
 "Another thing we can do with a metric is calculate its ",
 StyleBox["volume element",
  FontWeight->Bold],
 ", defined as"
}], "Text",ExpressionUUID->"6bb13238-9de0-854c-9b62-75735b6184ba"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    StyleBox["d",
     FontSlant->"Plain"], 
    StyleBox["V", "TI"], "\[LongEqual]", 
    SqrtBox[
     TemplateBox[{
       RowBox[{"det", 
         RowBox[{"(", 
           StyleBox["g", "TI"], ")"}]}]},
      "Abs"]], " ", 
    SuperscriptBox[
     RowBox[{
      StyleBox["d",
       FontSlant->"Plain"], 
      StyleBox["x", "TI"]}], "0"], "\[Wedge]", "\[Ellipsis]", "\[Wedge]", 
    SuperscriptBox[
     RowBox[{
      StyleBox["d",
       FontSlant->"Plain"], 
      StyleBox["x", "TI"]}], 
     RowBox[{
      StyleBox["n", "TI"], "-", "1"}]]}], ","}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"059c6328-3eea-5843-\
a111-b9efdeaaf890"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   StyleBox["n", "TI"], TraditionalForm]],ExpressionUUID->
  "7ff2c1e1-4d31-e147-8372-c059ffa4e024"],
 " is the number of dimensions. This can be done using the module ",
 StyleBox["TVolumeElement", "Input"],
 ":"
}], "Text",ExpressionUUID->"c23478d2-5c9d-274d-8e05-d7a8cdb9c8ea"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"?", "TVolumeElement"}]], "Input",
 CellLabel->"In[37]:=",ExpressionUUID->"444d8fb2-e4b8-f042-8672-f513eb63bcc9"],

Cell[BoxData[
 InterpretationBox[
  StyleBox[
   FrameBox[
    DynamicModuleBox[{System`InformationDump`open$$ = False, 
     System`InformationDump`mouseOver$$ = False}, 
     PaneSelectorBox[{True->
      TagBox[GridBox[{
         {
          ItemBox[
           PaneBox[
            StyleBox[
             TagBox[
              TooltipBox[
               StyleBox["\<\" Symbol\"\>", "InformationRowLabel",
                StripOnInput->False],
               "\"Symbol\"",
               TooltipStyle->"TextStyling"],
              Annotation[#, "Symbol", "Tooltip"]& ], "InformationTitleText",
             StripOnInput->False,
             BaseStyle -> None],
            FrameMargins->{{4, 0}, {-1, 1}}],
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False]},
         {
          ItemBox[
           PaneBox[
            
            StyleBox["\<\"\\!\\(\\*InterpretationBox[Cell[TextData[{\\\"\
TVolumeElement[\\\", StyleBox[\\\"metricID\\\", Bold, Rule[StripOnInput, \
False]], \\\"] returns the volume element of the metric \\\", \
StyleBox[\\\"metricID\\\", Bold, Rule[StripOnInput, False]], \\\" in its \
