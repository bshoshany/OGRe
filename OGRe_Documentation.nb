                    RowBox[{"OGRe`Private`TensorData", "[", "Options", "]"}], 
                    "[", "\"Parallelize\"", "]"}]}]}, {" "}, {
                    RowBox[{
                    RowBox[{"TSetParallelization", "[", 
                    RowBox[{"OGRe`Private`par_", "?", "BooleanQ"}], "]"}], 
                    ":=", 
                    RowBox[{"(", 
                    RowBox[{
                    
                    RowBox[{
                    "Unprotect", "[", "OGRe`Private`TensorData", "]"}], ";", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"OGRe`Private`TensorData", "[", "Options", "]"}], 
