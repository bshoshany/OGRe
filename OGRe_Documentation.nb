Cell[BoxData[
 RowBox[{"TShow", "[", "\"\<4-Velocity\>\"", "]"}]], "Input",
 CellLabel->"In[59]:=",ExpressionUUID->"4efae158-37c5-6b4b-91ed-8c34db829012"],

Cell[BoxData[
 StyleBox[
  TemplateBox[{"\"4-Velocity\"", "\":   \"", 
    TemplateBox[{"\"u\"", 
      TemplateBox[{"\"\[Mu]\""}, "RowDefault"]}, "Superscript", SyntaxForm -> 
     SuperscriptBox], "\"(\"", 
    TemplateBox[{",", "\",\"", "t", "x", "y", "z"}, "RowWithSeparators"], 
    "\")\"", "\" = \"", 
    TagBox[
     RowBox[{"(", "\[NoBreak]", 
       TagBox[
        GridBox[{{
           FractionBox["1", 
            SqrtBox[
             RowBox[{"1", "-", 
               SuperscriptBox["v", "2"]}]]]}, {
           FractionBox["v", 
            SqrtBox[
             RowBox[{"1", "-", 
               SuperscriptBox["v", "2"]}]]]}, {"0"}, {"0"}}, RowSpacings -> 1,
          ColumnAlignments -> Center, ColumnAlignments -> Left], Column], 
       "\[NoBreak]", ")"}], 
     Function[BoxForm`e$, 
      MatrixForm[BoxForm`e$]]]},
