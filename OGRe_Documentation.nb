         Close[OGRe`Private`stream]; OGRe`Private`UpdateCodeCompletions[]; 
         OGRe`Private`OGRePrint["Imported all tensor data from ", 
           With[{OGRe`Private`p = AbsoluteFileName[OGRe`Private`path]}, 
            OGRe`Private`CreateButton[OGRe`Private`p, 
             NotebookOpen[OGRe`Private`p]]], "."]; Null]}], "SubValues" -> 
    None, "DefaultValues" -> 
    Information`InformationValueForm[
     DefaultValues, OGRe`TImportAll, {
      SyntaxInformation[OGRe`TImportAll] -> {"ArgumentsPattern" -> {
           Blank[]}}}], "NValues" -> None, "FormatValues" -> None, "Options" -> 
    None, "Attributes" -> {Protected}, "FullName" -> "OGRe`TImportAll"|>, 
   False]]], "Output",
 CellLabel->
  "Out[237]=",ExpressionUUID->"2b75a235-63a4-8744-88e1-12a387829df8"]
}, Open  ]],

Cell[TextData[{
 "Note that ",
 StyleBox["TImportAll", "Input"],
 " will delete any tensors already defined in the current session, whether or \
not they have the same ID as an imported tensor. To keep them, first export \
them into an ",
 StyleBox["Association", "Input"],
 ", ",
 StyleBox["Join", "Input"],
 " it with the ",
 StyleBox["Association", "Input"],
 " you wish to import, and then use ",
 StyleBox["TImportAll", "Input"],
 " on the result - or, alternatively, import the tensors one by one using ",
 StyleBox["TImport", "Input"],
 ". Similarly, any settings configured during the session will be replaced \
with the imported settings. ",
 StyleBox["TImport", "Input"],
 " and ",
 StyleBox["TImportAll", "Input"],
 " will issue a warning when importing data exported by a different OGRe \
version, and the tensors or settings may not be imported correctly in that \
case; when transitioning between versions, it is best to re-define all the \
tensors from scratch."
}], "Text",ExpressionUUID->"374c0982-cafb-364b-ae36-a90f115e115c"],

Cell[TextData[{
 "If a file name is given to ",
 StyleBox["TExportAll", "Input"],
 ", the output will be saved to that file. If a file extension is not \
provided, the extension ",
 StyleBox[".m", "Input"],
 " will be appended, unless the file name explicitly ends with a dot. If only \
the name of the file is given, and not a full path - e.g. ",
 StyleBox["TExportAll[\"OGReTensors.m\"]", "Input"],
 " - then the file will be saved in the current working directory, as given \
by ",
 StyleBox["Directory[]", "Input"],
 ". To change the working directory, use ",
 StyleBox["SetDirectory[]", "Input"],
 " before exporting the file. To import from the file, pass the file name to ",
 StyleBox["TImportAll", "Input"],
 ", e.g. ",
 StyleBox["TImportAll[\"OGReTensors.m\"]", "Input"],
 "."
}], "Text",ExpressionUUID->"0161ac47-020c-b545-96a0-a06ee4d8011a"],

Cell[TextData[{
 "Note that if for some reason you would like to delete all the tensors \
defined so far in the current session, you can simply import an empty ",
 StyleBox["Association", "Input"],
 " as follows: ",
 StyleBox["TImportAll[<||>]", "Input"],
 ". Be careful, as this action is ",
 StyleBox["irreversible",
  FontWeight->Bold],
 "!"
}], "Text",ExpressionUUID->"f0b8f2b6-34ee-9e49-9275-5dc0026db522"],

Cell[TextData[{
 "Lagrangians and affine-parameter geodesic equations are stored internally \
using the placeholder ",
 StyleBox["$CurveParam", "Input"],
 " for the curve parameter. The placeholder is replaced with the \
user-selected curve parameter only when they are displayed or the components \
are retrieved. When exporting tensors using ",
 StyleBox["TExport", "Input"],
 " or ",
 StyleBox["TExportAll", "Input"],
 ", the tensors will be exported with the placeholder, so that when they are \
imported later, they will be imported correctly regardless of which curve \
parameter is currently selected:"
}], "Text",ExpressionUUID->"3ced7a4c-148d-8d46-9619-0f80a48b0b48"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TExport", "[", 
  RowBox[{"TLagrangian", "[", "\"\<Minkowski\>\"", "]"}], "]"}]], "Input",
 CellLabel->
  "In[238]:=",ExpressionUUID->"d17124a7-dfb3-ed40-8c0c-eee24204ede0"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{"\<\"Minkowski->Lagrangian\"\>", "\[Rule]", 
   RowBox[{"\[LeftAssociation]", 
    RowBox[{
     RowBox[{"\<\"Components\"\>", "\[Rule]", 
      RowBox[{"\[LeftAssociation]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", "}"}], ",", "\<\"Cartesian\"\>"}], "}"}], "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", 
           SuperscriptBox[
            RowBox[{
             SuperscriptBox["t", "\[Prime]",
              MultilineFunction->None], "[", "$CurveParam", "]"}], "2"]}], "+", 
          SuperscriptBox[
           RowBox[{
            SuperscriptBox["x", "\[Prime]",
             MultilineFunction->None], "[", "$CurveParam", "]"}], "2"], "+", 
          SuperscriptBox[
           RowBox[{
            SuperscriptBox["y", "\[Prime]",
             MultilineFunction->None], "[", "$CurveParam", "]"}], "2"], "+", 
          SuperscriptBox[
           RowBox[{
            SuperscriptBox["z", "\[Prime]",
             MultilineFunction->None], "[", "$CurveParam", "]"}], "2"]}], 
         "}"}]}], "\[RightAssociation]"}]}], ",", 
     RowBox[{"\<\"DefaultCoords\"\>", "\[Rule]", "\<\"Cartesian\"\>"}], ",", 
     RowBox[{"\<\"DefaultIndices\"\>", "\[Rule]", 
      RowBox[{"{", "}"}]}], ",", 
     RowBox[{"\<\"Metric\"\>", "\[Rule]", "\<\"Minkowski\"\>"}], ",", 
     RowBox[{"\<\"Role\"\>", "\[Rule]", "\<\"Lagrangian\"\>"}], ",", 
     RowBox[{"\<\"Symbol\"\>", "\[Rule]", "\<\"L\"\>"}], ",", 
     RowBox[{"\<\"OGReVersion\"\>", 
      "\[Rule]", "\<\"v2.0.0 (2026-05-02)\"\>"}]}], "\[RightAssociation]"}]}],
   "\[RightAssociation]"}]], "Output",
 CellLabel->
  "Out[238]=",ExpressionUUID->"8dd89314-9526-504c-939a-bb3ad2ece3c5"]
}, Open  ]],

Cell[TextData[{
 StyleBox["TExportAll", "Input"],
 " also exports the choice of user-facing curve parameter separately as part \
of the ",
 StyleBox["Options", "Input"],
 " key, and it is imported when using ",
 StyleBox["TImportAll", "Input"],
 ", so your parameter of choice can persist between sessions."
}], "Text",ExpressionUUID->"bcbbfd75-03c0-b348-8d9f-ca6a6e18c91f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Parallelization", "Section",ExpressionUUID->"ba0d8268-b13a-b14d-b984-b34f69490e48"],

Cell[CellGroupData[{

Cell["Improving performance with parallelization", "Subsection",ExpressionUUID->"292fb7e2-8724-0244-aa24-9a8d7330f607"],

Cell[TextData[{
 "The calculations we have demonstrated so far in this documentation have \
been quite simple, and should not take more than a second to perform on a \
decent computer. However, when doing research, calculations can be much more \
involved, and thus also take more time to complete. Typically, the most \
time-consuming part of any tensor calculation is not the tensor operations \
themselves, but rather the ",
 StyleBox["simplification",
  FontWeight->Bold],
 " of the final result using ",
 StyleBox["FullSimplify", "Input"],
 "."
}], "Text",ExpressionUUID->"bd3638cf-0c2a-974c-9db6-c6002ae0b29c"],

Cell[TextData[{
 "If simplification is taking more than a few seconds, it is highly \
recommended to turn on the ",
 StyleBox["parallelization",
  FontWeight->Bold],
 " feature, which simplifies the components of the tensors in parallel \
instead of one after the other. This can provide a significant performance \
boost, proportional to the number of parallel kernels that can be launched. \
Note that this number is determined by your Mathematica license, and it may \
be less than the number of cores in your CPU."
}], "Text",ExpressionUUID->"11daaecd-e172-fa4c-b91e-f7734b34afd6"],

Cell[TextData[{
 "Since we would like to measure execution time in this section, let us use \
the command ",
 StyleBox["ClearSystemCache", "Input"],
 " to clear Mathematica's cache - since otherwise it will remember the \
results of previous simplifications, which may artificially speed up the \
calculation:"
}], "Text",ExpressionUUID->"3bc13b78-1f80-5e42-bbb6-7646b861b39a"],

Cell[BoxData[
 RowBox[{"ClearSystemCache", "[", "]"}]], "Input",
 CellLabel->
  "In[239]:=",ExpressionUUID->"73d94487-326d-9b40-b6a1-469f3170e508"],

Cell[TextData[{
 "To demonstrate the benefits of parallelization, let us consider the \
following somewhat complicated non-diagonal metric, which depends on an \
abstract function ",
 Cell[BoxData[
  FormBox[
   StyleBox["f", "TI"], TraditionalForm]],ExpressionUUID->
  "898985d8-d421-104c-9681-94757ae13974"],
 ":"
}], "Text",ExpressionUUID->"a4e14e35-821c-0e46-84c7-391084ad4e0e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TShow", "[", 
  RowBox[{"TNewMetric", "[", 
   RowBox[{"\"\<ParallelizationTest\>\"", ",", "\"\<Cartesian\>\"", ",", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"f", "[", 
       RowBox[{"a", " ", "b", " ", "t"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"a", ",", "1", ",", "4"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"b", ",", "1", ",", "4"}], "}"}]}], "]"}]}], "]"}], 
  "]"}]], "Input",
 CellLabel->
  "In[240]:=",ExpressionUUID->"1614b486-bd0b-934a-b81b-62098a65ffb8"],

Cell[BoxData[
 StyleBox[
  TemplateBox[{"\"ParallelizationTest\"", "\":   \"", 
    SubscriptBox["\"g\"", 
     TemplateBox[{"\"\[Mu]\"", "\"\[Nu]\""}, "RowDefault"]], "\"(\"", 
    TemplateBox[{",", "\",\"", "t", "x", "y", "z"}, "RowWithSeparators"], 
    "\")\"", "\" = \"", 
    TagBox[
     RowBox[{"(", "\[NoBreak]", 
       GridBox[{{"f", 
          RowBox[{"f", "[", 
            RowBox[{"2", " ", "t"}], "]"}], 
          RowBox[{"f", "[", 
            RowBox[{"3", " ", "t"}], "]"}], 
          RowBox[{"f", "[", 
            RowBox[{"4", " ", "t"}], "]"}]}, {
          RowBox[{"f", "[", 
            RowBox[{"2", " ", "t"}], "]"}], 
          RowBox[{"f", "[", 
            RowBox[{"4", " ", "t"}], "]"}], 
          RowBox[{"f", "[", 
            RowBox[{"6", " ", "t"}], "]"}], 
          RowBox[{"f", "[", 
            RowBox[{"8", " ", "t"}], "]"}]}, {
          RowBox[{"f", "[", 
            RowBox[{"3", " ", "t"}], "]"}], 
          RowBox[{"f", "[", 
            RowBox[{"6", " ", "t"}], "]"}], 
          RowBox[{"f", "[", 
            RowBox[{"9", " ", "t"}], "]"}], 
          RowBox[{"f", "[", 
            RowBox[{"12", " ", "t"}], "]"}]}, {
          RowBox[{"f", "[", 
            RowBox[{"4", " ", "t"}], "]"}], 
          RowBox[{"f", "[", 
            RowBox[{"8", " ", "t"}], "]"}], 
          RowBox[{"f", "[", 
            RowBox[{"12", " ", "t"}], "]"}], 
          RowBox[{"f", "[", 
            RowBox[{"16", " ", "t"}], "]"}]}}, RowSpacings -> 1, 
        ColumnSpacings -> 1, RowAlignments -> Baseline, ColumnAlignments -> 
        Center], "\[NoBreak]", ")"}], 
     Function[BoxForm`e$, 
      MatrixForm[BoxForm`e$]]]},
   "RowDefault"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"54e5a882-2c22-6045-b33e-f8a518e146ab"]
}, Open  ]],

Cell[TextData[{
 "We first calculate the Christoffel symbols for this metric ",
 StyleBox["without",
  FontWeight->Bold],
 " parallelization, and use ",
 StyleBox["AbsoluteTiming", "Input"],
 " to measure how long it takes:"
}], "Text",ExpressionUUID->"efb1062c-f08c-5a40-ae33-514e4fb8fb0f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"notParallelChristoffel", "=", 
  RowBox[{
   RowBox[{"AbsoluteTiming", "[", 
    RowBox[{"TChristoffel", "[", "\"\<ParallelizationTest\>\"", "]"}], "]"}], 
   "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]}]], "Input",
 CellLabel->
  "In[241]:=",ExpressionUUID->"e21b3994-bf67-6e4c-a6f3-d6282065c35a"],

Cell[BoxData["5.7107332`"], "Output",
 CellLabel->
  "Out[241]=",ExpressionUUID->"545dbb61-eab9-164c-a5f9-80180d7dfb47"]
}, Open  ]],

Cell[TextData[{
 "This is the number of seconds this calculation took on my computer. On your \
computer this duration may be shorter or longer, but the calculation will \
invariably take a non-trivial amount of time on any personal computer. The \
vast majority of that time is spent not on calculating the tensor itself, but \
on ",
 StyleBox["simplifying",
  FontWeight->Bold],
 " the result."
}], "Text",ExpressionUUID->"ee71a0fb-a020-804b-bef9-4b0af51e22fb"],

Cell[TextData[{
 "To turn on parallelization, we use the module ",
 StyleBox["TSetParallelization", "Input"],
 ":"
}], "Text",ExpressionUUID->"668b7e5f-6e46-a844-b0a2-82b2d31045cc"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"?", "TSetParallelization"}]], "Input",
 CellLabel->
  "In[242]:=",ExpressionUUID->"da24cdab-063c-5149-b245-f4a3fcfb32f2"],

Cell[BoxData[
 InterpretationBox[
  StyleBox[
   FrameBox[
    DynamicModuleBox[{System`InformationDump`open$$ = False, 
     System`InformationDump`mouseOver$$ = False}, 
     PaneSelectorBox[{True->
      TagBox[GridBox[{
         {
          ItemBox[
           PaneBox[
            StyleBox[
             TagBox[
