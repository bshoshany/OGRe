Cell[TextData[{
 "Note that the volume element involves the square root of the absolute value \
of the determinant of the metric. If we want the determinant itself, we can \
use ",
 StyleBox["TMetricDeterminant", "Input"],
 ":"
}], "Text",ExpressionUUID->"5ca91bce-8f5e-3e4c-8e98-29d796dac646"],

