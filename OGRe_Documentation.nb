Cell[TextData[{
 "Note that ",
 StyleBox["TGeodesicWithTimeParameter", "Input"],
 " assumes time is the first coordinate, but the coordinate does not need to \
have the symbol ",
 Cell[BoxData[
  FormBox[
   StyleBox["t", "TI"], TraditionalForm]],ExpressionUUID->
  "aaba865e-8921-c340-b4bb-aad8e83d5387"],
 ". As an example, the equations for the FLRW metric in terms of a curve \
parameter are"
}], "Text",ExpressionUUID->"785bb7b1-1775-464e-bf3f-05e0672af212"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TList", "[", 
  RowBox[{
   RowBox[{"TGeodesicFromChristoffel", "[", "\"\<FLRW\>\"", "]"}], 
   ",", "\"\<Cartesian\>\""}], "]"}]], "Input",
 CellLabel->
  "In[224]:=",ExpressionUUID->"6ea6ced8-7db0-f54c-8a79-ef99d3412805"],

Cell[BoxData[
 StyleBox[
  TagBox[GridBox[{
     {
      TemplateBox[{"\"FLRW->GeodesicFromChristoffel\"", "\":\""},
       "RowDefault"]},
     {
      TagBox[GridBox[{
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"0\"", 
              TemplateBox[{"t"}, "RowDefault"]}, "Superscript", SyntaxForm -> 
             SuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           OverscriptBox["t", "\[DoubleDot]"], "+", 
           RowBox[{"a", " ", 
            RowBox[{"(", 
             RowBox[{
              SuperscriptBox[
               OverscriptBox["x", "."], "2"], "+", 
              SuperscriptBox[
               OverscriptBox["y", "."], "2"], "+", 
              SuperscriptBox[
               OverscriptBox["z", "."], "2"]}], ")"}], " ", 
            TemplateBox[{
              SubscriptBox["\"\[PartialD]\"", "t"], "a"},
             "RowDefault"]}]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"0\"", 
              TemplateBox[{"x"}, "RowDefault"]}, "Superscript", SyntaxForm -> 
             SuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           OverscriptBox["x", "\[DoubleDot]"], "+", 
           FractionBox[
            RowBox[{"2", " ", 
             OverscriptBox["t", "."], " ", 
             OverscriptBox["x", "."], " ", 
             TemplateBox[{
               SubscriptBox["\"\[PartialD]\"", "t"], "a"},
              "RowDefault"]}], "a"]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"0\"", 
              TemplateBox[{"y"}, "RowDefault"]}, "Superscript", SyntaxForm -> 
             SuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           OverscriptBox["y", "\[DoubleDot]"], "+", 
           FractionBox[
            RowBox[{"2", " ", 
             OverscriptBox["t", "."], " ", 
             OverscriptBox["y", "."], " ", 
             TemplateBox[{
               SubscriptBox["\"\[PartialD]\"", "t"], "a"},
              "RowDefault"]}], "a"]}]},
         {
          TemplateBox[{"=", "\"=\"", 
            TemplateBox[{"\"0\"", 
              TemplateBox[{"z"}, "RowDefault"]}, "Superscript", SyntaxForm -> 
             SuperscriptBox]},
           "RowWithSeparators"], "\<\"=\"\>", 
          RowBox[{
           OverscriptBox["z", "\[DoubleDot]"], "+", 
           FractionBox[
            RowBox[{"2", " ", 
             OverscriptBox["t", "."], " ", 
             OverscriptBox["z", "."], " ", 
             TemplateBox[{
               SubscriptBox["\"\[PartialD]\"", "t"], "a"},
              "RowDefault"]}], "a"]}]}
        },
        AutoDelete->False,
        GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
        GridBoxItemSize->{
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
       "Grid"]}
    },
    DefaultBaseStyle->"Column",
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
