Cell[TextData[{
 "Note that ",
 StyleBox["TTeXShow", "Input"],
 " and ",
 StyleBox["TTeXList", "Input"],
 " return the TeX output as a string. If we run them in an input cell, the \
string will be placed in an output cell, and if we just select that string \
and copy it, Mathematica will usually mess up the formatting, resulting in \
invalid TeX code. Instead, the best way to copy the TeX output is to use ",
 StyleBox["CopyToClipboard", "Input"],
 " to copy it directly to the clipboard, for example:"
}], "Text",ExpressionUUID->"ca72c706-3ace-474a-94c8-5eb85b3e38ba"],

