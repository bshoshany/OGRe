                    StyleBox[
                    RowBox[{"TGetComponents", "::", "UsingDefault"}], 
                    "MessageName"], ",", "OGRe`Private`usingMessage"}], "]"}],
                     ";"}]}], "]"}], ";", 
                    RowBox[{"OGRe`Private`components", "=", 
