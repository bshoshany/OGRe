Cell[TextData[{
 "The ",
 StyleBox["Ricci scalar",
  FontWeight->Bold],
 " is the trace of the Ricci tensor:"
}], "Text",ExpressionUUID->"f63ab0bb-fe69-1541-bc52-a6ecf478e3b2"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    StyleBox["R", "TI"], "\[LongEqual]", 
    SuperscriptBox[
     StyleBox["R", "TI"], "\[Lambda]"], 
    SubscriptBox["\[Null]", "\[Lambda]"], "\[LongEqual]", 
    SuperscriptBox[
     StyleBox["g", "TI"], "\[Mu]\[Nu]"], 
    SubscriptBox[
     StyleBox["R", "TI"], "\[Mu]\[Nu]"]}], "."}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"57967586-3236-514c-\
80eb-e6b752f4448c"],

Cell["\<\
We can calculate it from the Ricci tensor by taking the trace:\
\>", "Text",ExpressionUUID->"f3ec58a5-fb48-4841-9f6d-72c313ca9941"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TShow", "@", 
  RowBox[{"TCalc", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"TRicci", "[", "\"\<FLRW\>\"", "]"}], "[", "\"\<\[Mu]\[Mu]\>\"", 
     "]"}], ",", "\"\<R\>\""}], "]"}]}]], "Input",
 CellLabel->
  "In[165]:=",ExpressionUUID->"a0ad01f8-3d8e-9444-b0f6-2377b054cc29"],

Cell[BoxData[
 StyleBox[
  TemplateBox[{"\"Result\"", "\":   \"", "\"R\"", "\"(\"", 
    TemplateBox[{",", "\",\"", "t", "r", "\[Theta]", "\[Phi]"}, 
     "RowWithSeparators"], "\")\"", "\" = \"", 
    FractionBox[
     RowBox[{"6", " ", 
       RowBox[{"(", 
         RowBox[{"k", "+", 
           RowBox[{"a", " ", 
             TemplateBox[{
               
               TemplateBox[{"\"\[PartialD]\"", "t", "2"}, "Subsuperscript", 
                SyntaxForm -> SubsuperscriptBox], "a"}, "RowDefault"]}], "+", 
           SuperscriptBox[
            TemplateBox[{"\"(\"", 
              TemplateBox[{
                SubscriptBox["\"\[PartialD]\"", "t"], "a"}, "RowDefault"], 
              "\")\""}, "RowDefault"], "2"]}], ")"}]}], 
     SuperscriptBox["a", "2"]]},
   "RowDefault"], "DisplayFormula",
  StripOnInput->False]], "Output",
 Editable->False,
 CellLabelStyle->Directive["CellLabel", Smaller, 
   RGBColor[0, 0, 1]],
 CellLabel->"OGRe:",ExpressionUUID->"637d695a-d79c-ec48-ba21-f2c9ccb11e8e"]
}, Open  ]],

