                "RowDefault"]]}]},
           "RowWithSeparators"], "\<\"=\"\>", 
          FractionBox[
           RowBox[{"M", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"-", "2"}], " ", "M"}], "+", "r"}], ")"}]}], 
           SuperscriptBox["r", "2"]]},
         {
          TemplateBox[{"=", "\"=\"", 
            SubscriptBox["\"R\"", 
             TemplateBox[{"t", "\[Phi]", "t", "\[Phi]"}, "RowDefault"]], 
            SubscriptBox["\"R\"", 
