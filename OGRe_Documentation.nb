Cell[TextData[{
 "Don't worry - you don't need to write the explicit definition of the \
Riemann tensor every time you want to calculate it. Instead, OGRe offers the \
built-in module ",
 StyleBox["TRiemann", "Input"],
 ":"
}], "Text",ExpressionUUID->"e49ff24a-59ed-084a-9c4c-7ed15095df19"],

